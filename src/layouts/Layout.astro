---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Samudhra Water Solutions – Premium water purification systems, RO plants and water treatment services across Kerala since 2009." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#024095" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/samudhra.favicon image.png" />
    <title>{title}</title>
    <style>
      /* Layout-level overflow guard */
      html, body {
        overflow-x: hidden;
        max-width: 100vw;
      }
      @keyframes fadeUpIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes loadingLine {
        0% { left: -100%; }
        100% { left: 100%; }
      }
      @keyframes slowZoom {
        from { transform: scale(0.95); }
        to { transform: scale(1.05); }
      }
      @keyframes simpleFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
    </style>
  </head>
  <body class="bg-[#FAF9F6] text-black font-['Plus_Jakarta_Sans',sans-serif] antialiased">
    <!-- Splash Screen / Preloader (Homepage only, once per session) -->
    <div id="preloader" class="fixed inset-0 z-[9999] bg-[#FAF9F6] flex items-center justify-center transition-all duration-1000 ease-in-out" style="display:none;">
      <div class="flex flex-col items-center" style="animation: fadeUpIn 1s ease-out forwards;">
        
        <div class="mb-10" style="animation: slowZoom 3.5s ease-out forwards;">
          <img src="/images/samudhra.favicon image.png" alt="Samudhra Water Solutions" class="h-32 sm:h-40 w-auto object-contain" />
        </div>
        
        <div class="w-48 h-[2px] bg-slate-200 relative overflow-hidden rounded-full mb-6">
          <div class="absolute top-0 bottom-0 w-1/2 bg-[#024095]" style="animation: loadingLine 1.5s ease-in-out infinite;"></div>
        </div>

        <div class="text-[9px] sm:text-[10px] font-black uppercase tracking-[0.4em] text-[#024095] opacity-0" style="animation: simpleFadeIn 1s ease-in forwards; animation-delay: 0.6s;">
          Engineering Trust By Volume
        </div>
      </div>
    </div>

    <slot />

    <script>
      (function() {
        const preloader = document.getElementById('preloader');
        if (!preloader) return;

        // Only show on the homepage
        const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';
        // Only show once per session
        const hasSeenSplash = sessionStorage.getItem('splashShown');

        if (isHome && !hasSeenSplash) {
          preloader.style.display = 'flex';
          sessionStorage.setItem('splashShown', 'true');

          window.addEventListener('load', () => {
            setTimeout(() => {
              preloader.style.opacity = '0';
              preloader.style.visibility = 'hidden';
              preloader.style.transform = 'scale(1.05)';
              setTimeout(() => {
                preloader.remove();
              }, 1000);
            }, 2500);
          });
        } else {
          preloader.remove();
        }
      })();
    </script>
  </body>
</html>