---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Samudhra Water Solutions – Premium water purification systems, RO plants and water treatment services across Kerala since 2009." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#024095" />
    
    <!-- Open Graph / Facebook / WhatsApp / Telegram sharing -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Samudhra Water Solutions – Premium water purification systems, RO plants and water treatment services across Kerala since 2009." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content={new URL("/images/logo-preview.png", Astro.url)} />
    <meta property="og:site_name" content="Samudhra Water Solutions" />
    
    <!-- Twitter sharing -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content="Samudhra Water Solutions – Premium water purification systems, RO plants and water treatment services across Kerala since 2009." />
    <meta name="twitter:image" content={new URL("/images/logo-preview.png", Astro.url)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/images/samudhra.favicon image.png" />
    <title>{title}</title>
    <style>
      /* Layout-level overflow guard */
      html, body {
        overflow-x: hidden;
        width: 100%;
        max-width: 100%;
      }
      @keyframes fadeUpIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes loadingLine {
        0% { left: -100%; }
        100% { left: 100%; }
      }
      @keyframes slowZoom {
        from { transform: scale(0.95); }
        to { transform: scale(1.05); }
      }
      @keyframes simpleFadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      .animate-fadeUpIn {
        animation: fadeUpIn 0.8s ease-out forwards;
      }
      .animate-loadingLine {
        animation: loadingLine 1.2s ease-in-out infinite;
      }
      .animate-slowZoom {
        animation: slowZoom 2.5s ease-out forwards;
      }
      .animate-simpleFadeIn {
        animation: simpleFadeIn 0.8s ease-in forwards;
        animation-delay: 0.4s;
      }
    </style>
  </head>
  <body class="bg-[#FAF9F6] text-black font-['Plus_Jakarta_Sans',sans-serif] antialiased">
    <!-- Welcome screen preloader (Homepage only, once per session) -->
    <div id="preloader" class="fixed inset-0 z-[9999] bg-[#FAF9F6] flex flex-col items-center justify-center transition-all duration-700 ease-in-out">
      <script is:inline>
        (function() {
          const isHome = window.location.pathname === '/' || window.location.pathname === '/index.html';
          const hasSeenSplash = sessionStorage.getItem('splashShown');
          if (!isHome || hasSeenSplash) {
            document.getElementById('preloader').style.display = 'none';
            document.getElementById('preloader').remove();
          }
        })();
      </script>
      <div class="flex flex-col items-center animate-fadeUpIn">
        <div class="mb-8 animate-slowZoom">
          <img src="/images/samudhra.favicon image.png" alt="Samudhra Water Solutions" class="h-28 sm:h-36 w-auto object-contain" />
        </div>
        <div class="w-40 h-[2px] bg-slate-200 relative overflow-hidden rounded-full mb-4">
          <div class="absolute top-0 bottom-0 w-1/2 bg-[#024095] animate-loadingLine"></div>
        </div>
        <div class="text-[9px] sm:text-[10px] font-black uppercase tracking-[0.4em] text-[#024095] animate-simpleFadeIn">
          Samudhra Water Solutions
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        const preloader = document.getElementById('preloader');
        if (preloader && preloader.style.display !== 'none') {
          sessionStorage.setItem('splashShown', 'true');
          
          function hidePreloader() {
            preloader.style.opacity = '0';
            preloader.style.visibility = 'hidden';
            preloader.style.transform = 'scale(1.05)';
            setTimeout(() => {
              preloader.remove();
            }, 800);
          }

          // Hide immediately when fully loaded
          window.addEventListener('load', hidePreloader);
          
          // Safety timeout fallback (1.5 seconds max)
          setTimeout(hidePreloader, 1500);
        }
      })();
    </script>

    <!-- Call Popup Modal -->
    <div id="call-popup" class="fixed inset-0 z-[9998] flex items-end sm:items-center justify-center p-4 sm:p-6" style="display:none !important;">
      <!-- Backdrop -->
      <div id="call-popup-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeCallPopup()"></div>

      <!-- Modal Card -->
      <div class="relative w-full max-w-sm bg-white rounded-2xl shadow-2xl overflow-hidden" style="animation: slideUpPopup 0.4s cubic-bezier(0.34,1.56,0.64,1) forwards;">
        <!-- Top accent bar -->
        <div class="h-1.5 bg-gradient-to-r from-[#07bee8] to-[#024095]"></div>

        <!-- Close button -->
        <button onclick="closeCallPopup()" class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full bg-slate-100 hover:bg-slate-200 transition-colors z-10" aria-label="Close">
          <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>

        <div class="p-6 pt-5">
          <!-- Icon + Brand -->
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-gradient-to-br from-[#07bee8] to-[#024095] rounded-xl flex items-center justify-center shadow-md flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <p class="text-[10px] font-black uppercase tracking-widest text-[#07bee8]">Samudhra Water Solutions</p>
              <h3 class="text-base font-black text-[#024095] leading-tight">Free Water Testing<br/>Consultation!</h3>
            </div>
          </div>

          <!-- Message -->
          <p class="text-xs text-slate-500 font-medium mb-5 leading-relaxed">
            Speak directly with our water experts. Get a <strong class="text-slate-700">free water quality analysis</strong> for your home or business — available across Kerala.
          </p>

          <!-- Phone Number Display -->
          <div class="bg-[#eff6ff] rounded-xl px-4 py-3 flex items-center justify-between mb-4">
            <div>
              <p class="text-[9px] font-black uppercase tracking-widest text-[#07bee8] mb-0.5">Call us now</p>
              <p class="text-xl font-black text-[#024095] tracking-tight">+91 96458 30994</p>
            </div>
            <div class="w-10 h-10 bg-[#024095]/10 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-[#024095]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
          </div>

          <!-- Action Buttons -->
          <a href="tel:+919645830994" onclick="closeCallPopup()" class="flex items-center justify-center gap-2 w-full py-3.5 bg-gradient-to-r from-[#07bee8] to-[#024095] text-white font-black text-sm rounded-xl shadow-lg hover:opacity-90 active:scale-95 transition-all mb-2.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Call Now — Free Consultation
          </a>
          <a href="https://wa.me/919645830994?text=Hi%2C%20I%20want%20a%20free%20water%20testing%20consultation" target="_blank" rel="noopener" onclick="closeCallPopup()" class="flex items-center justify-center gap-2 w-full py-3 bg-[#25D366]/10 text-[#128C7E] font-bold text-sm rounded-xl hover:bg-[#25D366]/20 transition-colors border border-[#25D366]/30 mb-3">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Chat on WhatsApp
          </a>

          <!-- Dismiss -->
          <button onclick="closeCallPopup()" class="w-full text-center text-[10px] text-slate-400 hover:text-slate-600 font-semibold mt-3 tracking-wide transition-colors">
            No thanks, I'll browse later
          </button>
        </div>
      </div>
    </div>

    <style>
      @keyframes slideUpPopup {
        from { opacity: 0; transform: translateY(40px) scale(0.96); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }
    </style>

    <script>
      (function() {
        function showPopup() {
          const popup = document.getElementById('call-popup');
          if (popup && (popup.style.display === 'none' || popup.style.display === '')) {
            popup.style.removeProperty('display');
            popup.style.display = 'flex';
            
            // Reset inline styles that might have been added by close animation
            popup.style.opacity = '1';
            popup.style.transform = 'translateY(0)';
          }
        }

        // Show at 10 seconds
        setTimeout(showPopup, 10000);

        // Show every 60 seconds (1 min, 2 min, 3 min...)
        setInterval(showPopup, 60000);

        window.closeCallPopup = function() {
          const popup = document.getElementById('call-popup');
          if (popup) {
            popup.style.opacity = '0';
            popup.style.transform = 'translateY(20px)';
            popup.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
            setTimeout(() => { 
              popup.style.display = 'none'; 
            }, 300);
          }
        };
      })();
    </script>

    <slot />
  </body>
</html>