---
// src/layouts/Layout.astro
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Samudhra Water Solutions – Premium water purification systems, RO plants and water treatment services across Kerala since 2009." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#024095" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/src/styles/global.css" />
    <title>{title}</title>
    <style>
      /* Layout-level overflow guard */
      html, body {
        overflow-x: hidden;
        max-width: 100vw;
      }
    </style>
  </head>
  <body class="bg-white text-black font-['Plus_Jakarta_Sans',sans-serif] antialiased">
    <slot />
  </body>
</html>