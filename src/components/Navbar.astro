---
// src/components/Navbar.astro
interface Props {
  theme?: 'light' | 'dark';
}
const { theme = 'light' } = Astro.props;

const navigationLinks = [
  { label: 'Home',         path: '/' },
  { label: 'About',        path: '/about' },
  { label: 'Services',     path: '/service' },
  { label: 'Testimonials', path: '/testimonial' },
  { label: 'Shop',         path: '/shop' },
  { label: 'Founder',      path: '/founder' },
  { label: 'Contact',      path: '/contact' },
];
---

<nav id="navbar" aria-label="Main navigation" data-theme={theme}
     class="fixed top-0 left-0 w-full z-50 transition-all duration-500 bg-transparent py-3 border-b border-black/0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between">

    <!-- Brand Logo -->
    <a href="/" class="flex items-center min-h-[48px]" aria-label="Samudhra Water Solutions – Home">
      <img src="/images/company logo/SAMUDHRA WATER SOLUTIONS LOGO PNG.png" alt="Samudhra Water Solutions Logo" class="h-14 sm:h-16 w-auto object-contain" />
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden lg:flex items-center gap-6 xl:gap-8 text-[10px] font-extrabold uppercase tracking-[0.28em]" role="menubar">
      {navigationLinks.map((link) => (
        <a href={link.path}
           role="menuitem"
           class="nav-link text-black hover:text-[#024095] transition-colors duration-300 relative group py-2 min-h-[48px] flex items-center">
          {link.label}
          <span class="absolute bottom-0 left-0 w-0 h-[1.5px] bg-[#07bee8] transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </div>

    <!-- Desktop CTA -->
    <div class="hidden lg:flex items-center gap-4">
      <a href="tel:+919645830994" class="nav-text text-[#024095] text-[12px] font-black tracking-[0.1em] hover:text-[#07bee8] transition-colors flex items-center gap-1.5 whitespace-nowrap">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        +91 96458 30994
      </a>
      <a href="https://wa.me/919645830994?text=Hi%2C+I+would+like+to+book+a+free+water+testing+for+my+home%2Fbusiness.+Please+let+me+know+the+next+steps." target="_blank" rel="noopener noreferrer"
         class="px-5 py-3 min-h-[48px] bg-[#024095] text-white text-[10px] font-black uppercase tracking-[0.15em] hover:bg-[#07bee8] transition-all duration-300 rounded-lg shadow-md whitespace-nowrap flex items-center">
        Book Free Water Testing
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button id="menu-toggle"
            aria-label="Open navigation menu"
            aria-expanded="false"
            aria-controls="mobile-drawer"
            class="hamburger lg:hidden flex flex-col gap-[5px] justify-center items-center w-12 h-12 text-[#024095] hover:text-[#07bee8] transition-colors duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#07bee8] rounded">
      <span class="hamburger-bar bar-top"></span>
      <span class="hamburger-bar bar-mid"></span>
      <span class="hamburger-bar bar-bottom"></span>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-drawer"
       role="menu"
       aria-label="Mobile navigation"
       class="lg:hidden w-full bg-white border-b border-slate-200/80 px-4 sm:px-6 shadow-xl overflow-hidden max-h-0 opacity-0 pointer-events-none transition-all duration-300 ease-in-out">
    <div class="flex flex-col gap-1 py-2">
      {navigationLinks.map((link) => (
        <a href={link.path}
           role="menuitem"
           class="mobile-nav-link text-[11px] font-black uppercase tracking-[0.28em] text-black hover:text-[#024095] min-h-[48px] flex items-center border-b border-slate-100 last:border-0 transition-colors">
          {link.label}
        </a>
      ))}
    </div>
    <a href="tel:+919645830994" class="w-full text-center py-2 mt-2 mb-1 text-[#024095] text-[13px] font-black tracking-widest flex items-center justify-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
      +91 96458 30994
    </a>
    <a href="https://wa.me/919645830994?text=Hi%2C+I+would+like+to+book+a+free+water+testing+for+my+home%2Fbusiness.+Please+let+me+know+the+next+steps." target="_blank" rel="noopener noreferrer"
       class="block w-full text-center py-4 mb-4 bg-[#024095] text-white text-[10px] font-black uppercase tracking-[0.15em] hover:bg-[#07bee8] transition-colors rounded-lg min-h-[48px] flex items-center justify-center">
      Book Free Water Testing
    </a>
  </div>
</nav>

<style>
  #navbar[data-theme="dark"]:not(.scrolled) .nav-text {
    color: white !important;
  }
  #navbar[data-theme="dark"]:not(.scrolled) .nav-subtext {
    color: rgba(255, 255, 255, 0.8) !important;
  }
  #navbar[data-theme="dark"]:not(.scrolled) .nav-link {
    color: white !important;
  }
  #navbar[data-theme="dark"]:not(.scrolled) .hamburger {
    color: white !important;
  }
</style>

<script>
  const navbar      = document.getElementById('navbar') as HTMLElement;
  const menuToggle  = document.getElementById('menu-toggle') as HTMLButtonElement;
  const drawer      = document.getElementById('mobile-drawer') as HTMLElement;
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  /* ── Scroll: sticky background ── */
  function onScroll() {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-white/95', 'backdrop-blur-md', 'border-slate-200/60', 'shadow-sm', 'scrolled');
      navbar.classList.remove('bg-transparent', 'border-black/0');
    } else {
      navbar.classList.remove('bg-white/95', 'backdrop-blur-md', 'border-slate-200/60', 'shadow-sm', 'scrolled');
      navbar.classList.add('bg-transparent', 'border-black/0');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // Run on load

  /* ── Toggle drawer ── */
  function openMenu() {
    drawer.classList.remove('max-h-0', 'opacity-0', 'pointer-events-none');
    drawer.classList.add('max-h-[600px]', 'opacity-100', 'pointer-events-auto', 'py-4');
    drawer.classList.add('open');
    menuToggle.classList.add('is-open');
    menuToggle.setAttribute('aria-expanded', 'true');
    menuToggle.setAttribute('aria-label', 'Close navigation menu');
  }

  function closeMenu() {
    drawer.classList.add('max-h-0', 'opacity-0', 'pointer-events-none');
    drawer.classList.remove('max-h-[600px]', 'opacity-100', 'pointer-events-auto', 'py-4');
    drawer.classList.remove('open');
    menuToggle.classList.remove('is-open');
    menuToggle.setAttribute('aria-expanded', 'false');
    menuToggle.setAttribute('aria-label', 'Open navigation menu');
  }

  menuToggle?.addEventListener('click', () => {
    if (drawer.classList.contains('open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  /* ── Close on link click ── */
  mobileLinks.forEach(link => link.addEventListener('click', closeMenu));

  /* ── Close on outside click ── */
  document.addEventListener('click', (e) => {
    if (!navbar.contains(e.target as Node)) {
      closeMenu();
    }
  });

  /* ── Keyboard: close on Escape ── */
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>