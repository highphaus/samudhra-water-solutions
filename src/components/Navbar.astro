---
// src/components/Navbar.astro
const navigationLinks = [
  { label: 'Home',         path: '/' },
  { label: 'About',        path: '/about' },
  { label: 'Services',     path: '/service' },
  { label: 'Testimonials', path: '/testimonial' },
  { label: 'Shop',         path: '/shop' },
  { label: 'Founder',      path: '/founder' },
  { label: 'Contact',      path: '/contact' },
];
---

<nav id="navbar" aria-label="Main navigation"
     class="fixed top-0 left-0 w-full z-50 transition-all duration-500 bg-transparent py-4 border-b border-black/0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between">

    <!-- Brand Logo -->
    <a href="/" class="flex items-center group tracking-tighter select-none min-h-[48px]" aria-label="Samudhra Water Solutions – Home">
      <div class="flex flex-col">
        <span class="text-base sm:text-lg font-black tracking-[0.2em] sm:tracking-[0.25em] text-[#024095] group-hover:text-[#07bee8] transition-colors duration-300">SAMUDHRA</span>
        <span class="text-[8px] sm:text-[9px] font-bold uppercase tracking-[0.3em] text-black -mt-0.5">WATER SOLUTIONS</span>
      </div>
    </a>

    <!-- Desktop Nav Links -->
    <div class="hidden lg:flex items-center gap-6 xl:gap-8 text-[10px] font-extrabold uppercase tracking-[0.28em]" role="menubar">
      {navigationLinks.map((link) => (
        <a href={link.path}
           role="menuitem"
           class="text-black hover:text-[#024095] transition-colors duration-300 relative group py-2 min-h-[48px] flex items-center">
          {link.label}
          <span class="absolute bottom-0 left-0 w-0 h-[1.5px] bg-[#07bee8] transition-all duration-300 group-hover:w-full"></span>
        </a>
      ))}
    </div>

    <!-- Desktop CTA -->
    <div class="hidden lg:flex items-center">
      <a href="https://wa.me/919645830994" target="_blank" rel="noopener noreferrer"
         class="px-5 py-3 min-h-[48px] bg-[#024095] text-white text-[10px] font-black uppercase tracking-[0.22em] hover:bg-[#07bee8] transition-all duration-300 rounded-lg shadow-md whitespace-nowrap flex items-center">
        Book Inspection
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button id="menu-toggle"
            aria-label="Open navigation menu"
            aria-expanded="false"
            aria-controls="mobile-drawer"
            class="hamburger lg:hidden flex flex-col gap-[5px] justify-center items-center w-12 h-12 text-[#024095] hover:text-[#07bee8] transition-colors duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#07bee8] rounded">
      <span class="hamburger-bar bar-top"></span>
      <span class="hamburger-bar bar-mid"></span>
      <span class="hamburger-bar bar-bottom"></span>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-drawer"
       role="menu"
       aria-label="Mobile navigation"
       class="lg:hidden w-full bg-white border-b border-slate-200/80 px-4 sm:px-6 shadow-xl overflow-hidden max-h-0 opacity-0 pointer-events-none transition-all duration-300 ease-in-out">
    <div class="flex flex-col gap-1 py-2">
      {navigationLinks.map((link) => (
        <a href={link.path}
           role="menuitem"
           class="mobile-nav-link text-[11px] font-black uppercase tracking-[0.28em] text-black hover:text-[#024095] min-h-[48px] flex items-center border-b border-slate-100 last:border-0 transition-colors">
          {link.label}
        </a>
      ))}
    </div>
    <a href="https://wa.me/919645830994" target="_blank" rel="noopener noreferrer"
       class="block w-full text-center py-4 mb-4 bg-[#024095] text-white text-[10px] font-black uppercase tracking-[0.22em] hover:bg-[#07bee8] transition-colors rounded-lg min-h-[48px] flex items-center justify-center">
      Book Inspection
    </a>
  </div>
</nav>

<script>
  const navbar      = document.getElementById('navbar') as HTMLElement;
  const menuToggle  = document.getElementById('menu-toggle') as HTMLButtonElement;
  const drawer      = document.getElementById('mobile-drawer') as HTMLElement;
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  /* ── Scroll: sticky background ── */
  function onScroll() {
    if (window.scrollY > 20) {
      navbar.classList.add('bg-white/95', 'backdrop-blur-md', 'border-slate-200/60', 'shadow-sm');
      navbar.classList.remove('bg-transparent', 'border-black/0');
    } else {
      navbar.classList.remove('bg-white/95', 'backdrop-blur-md', 'border-slate-200/60', 'shadow-sm');
      navbar.classList.add('bg-transparent', 'border-black/0');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll(); // Run on load

  /* ── Toggle drawer ── */
  function openMenu() {
    drawer.classList.remove('max-h-0', 'opacity-0', 'pointer-events-none');
    drawer.classList.add('max-h-[600px]', 'opacity-100', 'pointer-events-auto', 'py-4');
    drawer.classList.add('open');
    menuToggle.classList.add('is-open');
    menuToggle.setAttribute('aria-expanded', 'true');
    menuToggle.setAttribute('aria-label', 'Close navigation menu');
  }

  function closeMenu() {
    drawer.classList.add('max-h-0', 'opacity-0', 'pointer-events-none');
    drawer.classList.remove('max-h-[600px]', 'opacity-100', 'pointer-events-auto', 'py-4');
    drawer.classList.remove('open');
    menuToggle.classList.remove('is-open');
    menuToggle.setAttribute('aria-expanded', 'false');
    menuToggle.setAttribute('aria-label', 'Open navigation menu');
  }

  menuToggle?.addEventListener('click', () => {
    if (drawer.classList.contains('open')) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  /* ── Close on link click ── */
  mobileLinks.forEach(link => link.addEventListener('click', closeMenu));

  /* ── Close on outside click ── */
  document.addEventListener('click', (e) => {
    if (!navbar.contains(e.target as Node)) {
      closeMenu();
    }
  });

  /* ── Keyboard: close on Escape ── */
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>