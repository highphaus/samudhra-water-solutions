---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const services = [
  { num: "01", title: "UF Plant Installation & Maintenance", image: "/images/products/Uf Plant.jpg", tag: "Filtration" },
  { num: "02", title: "Swimming Pool Filtration Plant", image: "/images/products/Swimming Pool Filtration Plant.jpeg", tag: "Commercial" },
  { num: "03", title: "Sewage Treatment Plant (STP)", image: "/images/products/Sewage Treatment Plant.jpg", tag: "Infrastructure" },
  { num: "04", title: "Effluent Treatment Plants (ETPs)", image: "/images/products/Effluent Treatment Plant.jpg", tag: "Industrial" },
  { num: "05", title: "De-Mineralizing (DM) Plants", image: "/images/products/DM plant.jpg", tag: "Purification" },
  { num: "06", title: "Desalination Water Filtration Plants", image: "/images/products/Desalination Water Filtration.jpg", tag: "Coastal" },
  { num: "07", title: "100,000 LPH RO Plant", image: "/images/products/100000 LPH RO plant.jpg", tag: "Large Scale" },
  { num: "08", title: "250 LPH RO Plant", image: "/images/products/100LPH-10000LPH RO Plant.jpg", tag: "Commercial" },
  { num: "09", title: "MultiBrand Water Purifier Servicing", image: "/images/products/Multibrand Water Purifiers.jpg", tag: "Servicing" },
  { num: "10", title: "Water Tank Cleaning", image: "/images/products/Stainless steel water tanks.jpg", tag: "Maintenance" },
];

const products = [
  { name: "100000 LPH RO Plant", image: "/images/products/100000 LPH RO plant.jpg", tier: "Industrial Tier", availability: "Built to Order" },
  { name: "100LPH–10000LPH RO Plant", image: "/images/products/100LPH-10000LPH RO Plant.jpg", tier: "Commercial Tier", availability: "Built to Order" },
  { name: "AQUA C3", image: "/images/products/AQUA C3.jpg", tier: "Residential", availability: "In Stock" },
  { name: "AQUA XZORA", image: "/images/products/AQUA XZORA.jpg", tier: "Residential", availability: "In Stock" },
  { name: "AQUA 9090", image: "/images/products/AQUA9090.jpg", tier: "Residential", availability: "In Stock" },
  { name: "BELLA+ & AVA+", image: "/images/products/BELLA+ & AVA+.jpg", tier: "Residential", availability: "In Stock" },
  { name: "DM Plant", image: "/images/products/DM plant.jpg", tier: "Industrial Tier", availability: "Built to Order" },
  { name: "Desalination Filtration", image: "/images/products/Desalination Water Filtration.jpg", tier: "Industrial Tier", availability: "Built to Order" },
  { name: "Effluent Treatment Plant", image: "/images/products/Effluent Treatment Plant.jpg", tier: "Infrastructure", availability: "Built to Order" },
  { name: "Hot & Cold Dispenser", image: "/images/products/HOT AND COLD Water Dispenser.jpg", tier: "Commercial Tier", availability: "In Stock" },
  { name: "Multibrand Purifiers", image: "/images/products/Multibrand Water Purifiers.jpg", tier: "Residential", availability: "In Stock" },
  { name: "PZONE BLACK Purifier", image: "/images/products/PZONE BLACK Water purifier.jpg", tier: "Residential", availability: "In Stock" },
  { name: "SALVADOR RO Purifier", image: "/images/products/SALVADOR RO water purifier.jpg", tier: "Residential", availability: "In Stock" },
  { name: "Sewage Treatment Plant", image: "/images/products/Sewage Treatment Plant.jpg", tier: "Infrastructure", availability: "Built to Order" },
  { name: "Stainless Steel Water Tanks", image: "/images/products/Stainless steel water tanks.jpg", tier: "Storage", availability: "In Stock" },
  { name: "Swimming Pool Filtration", image: "/images/products/Swimming Pool Filtration Plant.jpeg", tier: "Commercial Tier", availability: "Built to Order" },
  { name: "UF Plant", image: "/images/products/Uf Plant.jpg", tier: "Commercial Tier", availability: "Built to Order" },
  { name: "Water Softening Plant", image: "/images/products/Water softening plant.jpg", tier: "Infrastructure", availability: "Built to Order" },
  { name: "Water Treatment Plant", image: "/images/products/Water treatment plant.jpg", tier: "Infrastructure", availability: "Built to Order" },
  { name: "ZEDERA Water Purifiers", image: "/images/products/ZEDERA WATER PURIFIERS.jpg", tier: "Residential", availability: "In Stock" },
];
---

<Layout title="Samudhra Water Solutions | Pure Water Systems & Support">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <style>
    /* ── Page-level responsive overrides ── */

    /* Slider cards - responsive width */
    .svc-card  { flex-shrink: 0; width: min(320px, 82vw); }
    .prod-card { flex-shrink: 0; width: min(288px, 78vw); }

    /* Hero heading fluid */
    .hero-h1 { font-size: clamp(2.4rem, 8vw, 6.5rem); }

    /* Section heading fluid */
    .section-h2 { font-size: clamp(1.8rem, 5vw, 4rem); }

    /* WhatsApp FAB – smaller on mobile */
    @media (max-width: 480px) {
      .wa-fab { width: 52px; height: 52px; bottom: 1.25rem; right: 1.25rem; }
    }

    /* Availability badge colours */
    .badge-stock { background: #ecfdf5; color: #059669; }
    .badge-order { background: #fff7ed; color: #d97706; }

    /* Reveal animation */
    .reveal { opacity: 0; transform: translateY(30px); transition: opacity .7s ease, transform .7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* Hide scrollbars for sliders */
    .scrollbar-none::-webkit-scrollbar { display: none; }
    .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }

    /* Hero blob */
    @keyframes pulse-blob {
      0%,100% { transform: scale(1) translate(0,0); opacity:.6; }
      50%      { transform: scale(1.15) translate(20px,-10px); opacity:.9; }
    }
    .hero-blob { animation: pulse-blob 8s ease-in-out infinite; }
  </style>

  <!-- ======================================================== -->
  <!-- 1. HERO                                                    -->
  <!-- ======================================================== -->
  <section id="home" class="relative min-h-screen flex items-center bg-[#F9F9FB] overflow-hidden pt-20">
    <!-- Decorative blobs -->
    <div class="hero-blob absolute top-[-60px] right-[-40px] w-[300px] h-[300px] sm:w-[520px] sm:h-[520px] rounded-full bg-gradient-to-br from-[#07bee8]/20 to-[#024095]/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="hero-blob absolute bottom-[-80px] left-[-60px] w-[260px] h-[260px] sm:w-[420px] sm:h-[420px] rounded-full bg-gradient-to-tr from-[#024095]/10 to-[#07bee8]/10 blur-3xl pointer-events-none" style="animation-delay:4s" aria-hidden="true"></div>
    <div class="absolute inset-y-0 right-0 w-[30%] bg-[#024095]/4 hidden lg:block pointer-events-none" style="clip-path:polygon(10% 0,100% 0,100% 100%,0% 100%)" aria-hidden="true"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 w-full py-16 sm:py-24 relative z-10">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">

        <!-- Left copy -->
        <div class="lg:col-span-7 space-y-6 sm:space-y-8 text-center lg:text-left">
          <div class="inline-flex items-center gap-3 px-4 py-2 bg-white border-l-4 border-[#07bee8] shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-[#07bee8] animate-pulse"></span>
            <span class="text-[9px] sm:text-[10px] font-black uppercase tracking-[0.3em] text-[#024095]">Kerala's Premium Water Solutions Since 2009</span>
          </div>

          <h1 class="hero-h1 font-black tracking-tighter text-[#024095] leading-[0.92] uppercase">
            PURE WATER.<br/>
            EVERY SINGLE<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#024095] via-[#07bee8] to-slate-400">DROP.</span>
          </h1>

          <p class="text-sm sm:text-base text-black max-w-xl mx-auto lg:mx-0 font-medium leading-relaxed">
            We provide custom water purifiers for houses and high-capacity water plants for businesses. Trusted clean water across Trivandrum.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-3 sm:gap-4">
            <a href="/shop" class="w-full sm:w-auto min-h-[48px] px-8 py-3 bg-[#024095] text-white font-extrabold text-xs uppercase tracking-[0.2em] rounded-md shadow-lg hover:bg-[#07bee8] transition-all duration-300 text-center flex items-center justify-center">
              View Our Products
            </a>
            <a href="/contact" class="w-full sm:w-auto min-h-[48px] px-8 py-3 bg-white border-2 border-[#024095] text-[#024095] font-extrabold text-xs uppercase tracking-[0.2em] rounded-md hover:bg-[#024095] hover:text-white transition-all duration-300 text-center flex items-center justify-center">
              Contact Our Desk
            </a>
          </div>
        </div>

        <!-- Right stats -->
        <div class="lg:col-span-5 grid grid-cols-2 gap-3 sm:gap-4">
          {[
            { label:"Water Purity",   val:"99.7%",    accent:"#024095" },
            { label:"Max Plant Size", val:"100k LPH",  accent:"#07bee8" },
            { label:"Years Active",   val:"17+",       accent:"#07bee8" },
            { label:"Quality Code",   val:"ISO 9001",  accent:"#024095" },
          ].map(s => (
            <div class="bg-white p-4 sm:p-6 border-b-4 shadow-md rounded-md space-y-2 hover:shadow-xl transition-shadow" style={`border-color:${s.accent}`}>
              <p class="text-[8px] sm:text-[9px] font-bold text-black uppercase tracking-widest">{s.label}</p>
              <p class="text-xl sm:text-2xl font-black" style={`color:${s.accent}`}>{s.val}</p>
            </div>
          ))}

          <!-- Quick links row -->
          <div class="col-span-2 bg-white rounded-md shadow-md border border-slate-100 p-3 sm:p-4 flex items-center justify-between gap-2 flex-wrap">
            {[
              {href:"/service", label:"Services"},
              {href:"/shop",    label:"Products"},
              {href:"/about",   label:"About Us"},
              {href:"/contact", label:"Contact"},
            ].map(l => (
              <a href={l.href} class="text-[8px] sm:text-[9px] font-black uppercase tracking-[0.2em] text-black hover:text-[#024095] transition-colors px-2 py-1 min-h-[44px] flex items-center">{l.label}</a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- 2. SERVICES SLIDER                                        -->
  <!-- ======================================================== -->
  <section id="services-carousel" class="bg-[#024095] text-white py-16 sm:py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 mb-10 sm:mb-12 reveal">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 sm:gap-6">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#07bee8] mb-2">What We Do</p>
          <h2 class="section-h2 font-black tracking-tighter uppercase leading-none">Our Services.</h2>
          <p class="text-sm text-white/60 font-light mt-3 max-w-md leading-relaxed">10 specialised water treatment and maintenance services engineered for every scale.</p>
        </div>
        <div class="flex items-center">
          <a href="/service" class="inline-flex items-center gap-2 min-h-[48px] px-5 sm:px-6 py-3 border-2 border-white/30 text-white text-xs font-black uppercase tracking-[0.2em] hover:bg-white hover:text-[#024095] transition-all rounded whitespace-nowrap">
            See All Services &rarr;
          </a>
        </div>
      </div>
    </div>

    <!-- Snapping Slider -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div id="services-slider" class="flex gap-4 sm:gap-6 overflow-x-auto scroll-smooth scrollbar-none snap-x snap-mandatory py-4" style="-webkit-overflow-scrolling:touch;">
        {services.map((svc) => (
          <a href="/service" class="svc-card group snap-start bg-white/[0.03] hover:bg-white/[0.08] border border-white/10 hover:border-[#07bee8] rounded-2xl overflow-hidden transition-all duration-500 backdrop-blur-sm flex flex-col justify-between shadow-lg hover:shadow-2xl hover:-translate-y-1" style="height:clamp(360px,55vw,420px)">
            <div class="relative overflow-hidden bg-white/5" style="height:clamp(160px,30vw,208px)">
              <img src={svc.image} alt={svc.title} loading="lazy" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-transparent opacity-80"></div>
              <div class="absolute top-3 left-3 sm:top-4 sm:left-4">
                <span class="text-[8px] sm:text-[9px] font-black uppercase tracking-widest text-[#07bee8] bg-[#07bee8]/15 border border-[#07bee8]/30 px-2 sm:px-3 py-1 rounded-full">{svc.tag}</span>
              </div>
              <div class="absolute top-3 right-3 sm:top-4 sm:right-4">
                <span class="text-xl sm:text-2xl font-mono font-black text-white/30 group-hover:text-[#07bee8] transition-colors">#{svc.num}</span>
              </div>
            </div>
            <div class="p-4 sm:p-6 flex-1 flex flex-col justify-between bg-gradient-to-b from-transparent to-black/20">
              <div class="space-y-2 sm:space-y-3">
                <h3 class="text-base sm:text-xl font-black uppercase tracking-tight text-white group-hover:text-[#07bee8] transition-colors leading-snug">{svc.title}</h3>
                <p class="text-xs text-white/50 line-clamp-3 leading-relaxed font-light">
                  Professional installation, calibration and service operations. Assured safety standards compliance for clean yields.
                </p>
              </div>
              <div class="pt-3 sm:pt-4 flex items-center justify-between border-t border-white/5">
                <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-widest text-[#07bee8] group-hover:text-white transition-colors">Book Service</span>
                <div class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-white/10 group-hover:bg-[#07bee8] text-white flex items-center justify-center transition-all duration-300 transform group-hover:translate-x-1">
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Dots -->
      <div class="mt-6 sm:mt-8 flex justify-between items-center text-xs font-bold text-white/40">
        <div class="flex gap-1 sm:gap-1.5 flex-wrap" id="services-dots">
          {services.map((_, i) => (
            <button class="w-6 sm:w-8 h-1 rounded bg-white/20 transition-all duration-300 focus:outline-none min-h-[24px]" data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
          ))}
        </div>
        <span id="services-count">01 / 10</span>
      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- 3. PRODUCTS SLIDER                                        -->
  <!-- ======================================================== -->
  <section id="products-carousel" class="bg-[#F9F9FB] text-slate-900 py-16 sm:py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 mb-10 sm:mb-12 reveal">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 sm:gap-6">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#07bee8] mb-2">Shop Products</p>
          <h2 class="section-h2 font-black tracking-tighter uppercase text-[#024095] leading-none">Our Products.</h2>
          <p class="text-sm text-black font-light mt-3 max-w-md leading-relaxed">20 curated water purification systems — from compact home purifiers to 100,000 LPH industrial plants.</p>
        </div>
        <div class="flex items-center">
          <a href="/shop" class="inline-flex items-center gap-2 min-h-[48px] px-5 sm:px-6 py-3 border-2 border-[#024095] text-[#024095] text-xs font-black uppercase tracking-[0.2em] hover:bg-[#024095] hover:text-white transition-all rounded whitespace-nowrap">
            Open Shop &rarr;
          </a>
        </div>
      </div>
    </div>

    <!-- Snapping Slider -->
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div id="products-slider" class="flex gap-4 sm:gap-6 overflow-x-auto scroll-smooth scrollbar-none snap-x snap-mandatory py-4" style="-webkit-overflow-scrolling:touch;">
        {products.map((p) => (
          <a href="/shop" class="prod-card group snap-start bg-white hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] border border-slate-100 hover:border-[#024095]/30 rounded-2xl overflow-hidden transition-all duration-500 flex flex-col justify-between hover:-translate-y-1" style="height:clamp(360px,55vw,420px)">
            <div class="relative bg-gradient-to-b from-[#F9F9FB] to-white flex items-center justify-center p-4 sm:p-6 overflow-hidden border-b border-slate-100/60" style="height:clamp(150px,28vw,192px)">
              <img src={p.image} alt={p.name} loading="lazy" class="max-h-full max-w-full object-contain group-hover:scale-110 transition-transform duration-700 ease-out" />
              <div class="absolute top-3 left-3">
                <span class="text-[8px] font-mono font-black text-[#07bee8] bg-slate-50 border border-slate-100 px-2 py-0.5 rounded-full uppercase tracking-wider">{p.tier}</span>
              </div>
              <div class="absolute top-3 right-3">
                <span class={`text-[8px] font-extrabold uppercase tracking-wider px-2 py-0.5 rounded-full shadow-sm ${p.availability === 'In Stock' ? 'badge-stock' : 'badge-order'}`}>
                  {p.availability}
                </span>
              </div>
            </div>
            <div class="p-4 sm:p-6 flex-1 flex flex-col justify-between">
              <div class="space-y-1 sm:space-y-2">
                <h3 class="text-base sm:text-lg font-black uppercase tracking-tight text-[#024095] group-hover:text-[#07bee8] transition-colors leading-tight line-clamp-2">{p.name}</h3>
                <p class="text-xs text-black font-light leading-relaxed">High-efficiency multi-stage system built using top grade components.</p>
              </div>
              <div class="pt-3 sm:pt-4 flex items-center justify-between border-t border-slate-100">
                <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-widest text-black group-hover:text-[#024095] transition-colors">Inquire Now</span>
                <div class="w-7 h-7 sm:w-8 sm:h-8 rounded-full bg-slate-50 group-hover:bg-[#024095] group-hover:text-white text-black flex items-center justify-center transition-all duration-300 transform group-hover:translate-x-1">
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Dots -->
      <div class="mt-6 sm:mt-8 flex justify-between items-center text-xs font-bold text-black">
        <div class="flex gap-1 sm:gap-1.5 flex-wrap" id="products-dots">
          {products.map((_, i) => (
            <button class="w-4 sm:w-6 h-1 rounded bg-slate-200 transition-all duration-300 focus:outline-none min-h-[24px]" data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
          ))}
        </div>
        <span id="products-count">01 / 20</span>
      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- 4. ABOUT SUMMARY                                          -->
  <!-- ======================================================== -->
  <section id="about-summary" class="bg-white text-slate-900 border-t border-slate-100 py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center reveal">
        <div class="lg:col-span-7 space-y-5 sm:space-y-6">
          <p class="text-[10px] font-bold uppercase tracking-[0.35em] text-[#07bee8]">About Our Company</p>
          <h2 class="section-h2 font-black tracking-tighter text-[#024095] uppercase leading-none">Who We Are.</h2>
          <p class="text-sm text-black font-light leading-relaxed max-w-xl">
            Started in 2009 in Thiruvananthapuram, Samudhra fixes local water problems. We don't sell generic filters — we test your water supply and engineer a custom solution that's always completely clean and safe.
          </p>
          <div class="grid grid-cols-3 gap-3 sm:gap-4 pt-2">
            {[
              { val:"17+", label:"Years Experience" },
              { val:"01",  label:"Showroom TVM" },
              { val:"10+", label:"Service Types" },
            ].map(s => (
              <div class="border border-slate-100 rounded-lg p-3 sm:p-4 text-center hover:border-[#07bee8] transition-colors">
                <p class="text-xl sm:text-2xl font-black text-[#024095]">{s.val}</p>
                <p class="text-[8px] sm:text-[9px] text-black uppercase tracking-wider mt-1 font-bold">{s.label}</p>
              </div>
            ))}
          </div>
          <div class="pt-2">
            <a href="/about" class="inline-flex items-center justify-center min-h-[48px] px-8 py-3 bg-[#024095] text-white font-extrabold text-xs uppercase tracking-[0.2em] rounded-md hover:bg-[#07bee8] transition-all duration-300 shadow-md">
              Read Our Full History &rarr;
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative group">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#024095]/10 to-[#07bee8]/10 rounded-2xl filter blur-xl transform translate-x-2 translate-y-2 opacity-70 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
          <div class="relative overflow-hidden rounded-2xl border border-slate-100 shadow-xl bg-white">
            <img
              src="/images/office image/Samdhura Office.jpg"
              alt="Samudhra Water Solutions Corporate Office, Poojappura, Thiruvananthapuram"
              loading="lazy"
              class="w-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
              style="aspect-ratio: 4/3;"
            />
            <div class="absolute bottom-3 sm:bottom-4 left-3 sm:left-4 bg-white/95 backdrop-blur-sm px-3 sm:px-4 py-2 rounded-lg border border-slate-100 shadow-sm">
              <p class="text-[8px] sm:text-[9px] font-mono font-black text-[#024095] uppercase tracking-wider">// POOJAPPURA HQ</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- 4.5 HOW WE WORK                                           -->
  <!-- ======================================================== -->
  <section id="how-we-work" class="bg-[#F9F9FB] text-slate-900 border-t border-slate-100 py-16 sm:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">

      <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16 space-y-3 sm:space-y-4 reveal">
        <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#07bee8]">Process Integrity</p>
        <h2 class="section-h2 font-black tracking-tighter text-[#024095] uppercase">How We Work.</h2>
        <p class="text-sm text-black font-semibold leading-relaxed">
          From first water testing chemical reviews to precision component selection and ongoing maintenance audit loops.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 reveal">
        {[
          { step: "01", title: "Water Analysis", desc: "Our on-site field technicians chemically audit your source water to measure heavy iron, mineral scales, acidity, and TDS.", highlight: "Chemical Profiling" },
          { step: "02", title: "Custom Design", desc: "We configure components matching multi-brand membranes, sand media filters, softeners, and stabilizers for your target needs.", highlight: "Layout Optimization" },
          { step: "03", title: "Expert Setup", desc: "Certified squads install structural lines, mount valves, adjust booster flows, and run initial calibration testing.", highlight: "Precision Fitting" },
