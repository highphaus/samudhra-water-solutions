      });

      quickBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const queryText = btn.textContent.trim();
          handleUserSubmit(queryText);
        });
      });
    }

    // Initialize carousels for auto scroll and manual drag scroll
    function initCarousel(carouselId, intervalTime = 4000) {
      const container = document.getElementById(carouselId);
      if (!container) return;

      let isDown = false;
      let startX;
      let scrollLeft;
      let intervalId = null;
      let isHovered = false;
      let isTransitioning = false;

      function startAutoScroll() {
        stopAutoScroll();
        intervalId = setInterval(() => {
          if (isHovered || isDown || isTransitioning) return;
          
          if (container.scrollWidth > container.clientWidth + 10) {
            const firstItem = container.firstElementChild;
            if (!firstItem) return;

            const computedStyle = window.getComputedStyle(container);
            const gap = parseFloat(computedStyle.gap) || 24;
            const itemWidth = firstItem.getBoundingClientRect().width + gap;

            isTransitioning = true;
            container.style.scrollSnapType = 'none';

            // Premium ease slide-scale-fade transitions
            const secondItem = firstItem.nextElementSibling;
            firstItem.style.transition = 'opacity 0.6s cubic-bezier(0.25, 1, 0.5, 1), transform 0.6s cubic-bezier(0.25, 1, 0.5, 1)';
            firstItem.style.opacity = '0';
            firstItem.style.transform = 'scale(0.92) translateY(4px)';

            if (secondItem) {
              secondItem.style.transition = 'none';
              secondItem.style.opacity = '0.5';
              secondItem.style.transform = 'scale(0.96)';
              secondItem.offsetHeight; // force repaint
              secondItem.style.transition = 'opacity 0.6s cubic-bezier(0.25, 1, 0.5, 1), transform 0.6s cubic-bezier(0.25, 1, 0.5, 1)';
              secondItem.style.opacity = '1';
              secondItem.style.transform = 'scale(1)';
            }

            container.style.scrollBehavior = 'smooth';
            container.scrollLeft = itemWidth;

            setTimeout(() => {
              // FIFO Ring scroll: move first child to end
              container.appendChild(firstItem);

              // Restore styling states instantly
              firstItem.style.transition = 'none';
              firstItem.style.opacity = '1';
              firstItem.style.transform = 'none';

              if (secondItem) {
                secondItem.style.transition = 'none';
                secondItem.style.opacity = '1';
                secondItem.style.transform = 'none';
              }

              container.style.scrollBehavior = 'auto';
              container.scrollLeft = 0;
              container.style.scrollSnapType = '';
              isTransitioning = false;
            }, 700);
          }
        }, intervalTime);
      }

      function stopAutoScroll() {
        if (intervalId) {
          clearInterval(intervalId);
          intervalId = null;
        }
      }

      // Drag events
      container.addEventListener('mousedown', (e) => {
        if (container.scrollWidth <= container.clientWidth + 10) return;
        isDown = true;
        container.style.cursor = 'grabbing';
        container.style.scrollBehavior = 'auto';
        container.style.scrollSnapType = 'none';
        startX = e.pageX - container.offsetLeft;
        scrollLeft = container.scrollLeft;
      });

      container.addEventListener('mouseleave', () => {
        if (isDown) {
          isDown = false;
          container.style.cursor = '';
          container.style.scrollBehavior = '';
          container.style.scrollSnapType = '';
        }
        isHovered = false;
        startAutoScroll();
      });

      container.addEventListener('mouseenter', () => {
        isHovered = true;
        stopAutoScroll();
      });

      container.addEventListener('mouseup', () => {
        if (isDown) {
          isDown = false;
          container.style.cursor = '';
          container.style.scrollBehavior = '';
          container.style.scrollSnapType = '';
        }
        startAutoScroll();
      });

      container.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - container.offsetLeft;
        const walk = (x - startX) * 1.5;
        container.scrollLeft = scrollLeft - walk;
      });

      // Touch events (for mobile touch pause)
      container.addEventListener('touchstart', () => {
        isHovered = true;
        stopAutoScroll();
      }, { passive: true });

      container.addEventListener('touchend', () => {
        isHovered = false;
        setTimeout(startAutoScroll, 1500);
      }, { passive: true });

      // Initialize
      startAutoScroll();
    }

    // Build list of all 60 client images dynamically
    const clientImages = [];
    for (let i = 1; i <= 60; i++) {
      let ext = 'png';
      if (i === 38) {
        ext = 'webp';
      } else if (i === 6) {
        ext = 'svg';
      } else if (i === 43) {
        ext = 'jpg';
      }
      clientImages.push(`/images/client/client%20image${i}.${ext}`);
    }

    let nextImageIndex = 6;
    let activeSlotIndex = 0;

    function rotateSlot() {
      let attempts = 0;
      let strip = null;
      while (attempts < 6) {
        const checkIndex = (activeSlotIndex + attempts) % 6;
        const candidate = document.querySelector(`.logo-strip[data-slot-index="${checkIndex}"]`);
        if (candidate && candidate.offsetParent !== null) {
          strip = candidate;
          activeSlotIndex = (checkIndex + 1) % 6;
          break;
        }
        attempts++;
      }

      if (!strip) {
        strip = document.querySelector(`.logo-strip[data-slot-index="${activeSlotIndex}"]`);
        activeSlotIndex = (activeSlotIndex + 1) % 6;
      }

      if (!strip) return;

      const nextImgElement = strip.querySelector('.next-img');
      const activeImgElement = strip.querySelector('.active-img');
      if (!nextImgElement || !activeImgElement) return;

      const nextSrc = clientImages[nextImageIndex];
      nextImgElement.src = nextSrc;

      function triggerSlide() {
        nextImgElement.onload = null;
        nextImgElement.onerror = null;

        strip.style.transform = 'translateY(-50%)';

        setTimeout(() => {
          activeImgElement.src = nextSrc;
          strip.style.transition = 'none';
          strip.style.transform = 'translateY(0)';
          
          strip.offsetHeight; // force repaint
          
          setTimeout(() => {
            if (strip) {
              strip.style.transition = 'transform 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
            }
          }, 50);
        }, 650);

        nextImageIndex = (nextImageIndex + 1) % clientImages.length;
      }

      if (nextImgElement.complete) {
        triggerSlide();
      } else {
        nextImgElement.onload = triggerSlide;
        nextImgElement.onerror = triggerSlide;
      }
    }

    function initLogoSlots() {
      document.querySelectorAll('.logo-strip').forEach(el => {
        el.style.transition = 'transform 0.6s cubic-bezier(0.4, 0, 0.2, 1)';
      });
      setInterval(rotateSlot, 3000);
    }

    // Run after DOM content loaded
    document.addEventListener('DOMContentLoaded', () => {
      initChatbot();
      initLogoSlots();
      initCarousel('problems-carousel', 5000);
      initCarousel('products-shop-carousel', 5000);
      initCarousel('solutions-carousel', 5000);
      initCarousel('reviews-carousel', 5000);
      initCarousel('projects-carousel', 4500);
      initCarousel('transforming-carousel', 4000);
    });

    // Also run immediately in case DOMContentLoaded has already fired
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initChatbot();
      initLogoSlots();
      initCarousel('problems-carousel', 5000);
      initCarousel('products-shop-carousel', 5000);
      initCarousel('solutions-carousel', 5000);
      initCarousel('reviews-carousel', 5000);
      initCarousel('projects-carousel', 4500);
      initCarousel('transforming-carousel', 4000);
    }
  </script>

  <Footer />
</Layout>

<style>
  @keyframes chatbotScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-chatbotScroll {
    animation: chatbotScroll 15s linear infinite;
  }
  .animate-chatbotScroll:hover {
    animation-play-state: paused;
  }
</style>
