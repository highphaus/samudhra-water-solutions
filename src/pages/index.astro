  <!-- Scripts -->
  <script is:inline>
    // 1. Scroll Reveal
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // 2. Slider Factory
    function initSlider({ sliderId, dotsId, countId, total, interval: ms }) {
      const slider = document.getElementById(sliderId);
      const countEl = document.getElementById(countId);
      const dotsEl = document.getElementById(dotsId);
      if (!slider) return;

      const dots = dotsEl ? Array.from(dotsEl.children) : [];
      let idx = 0;

      const getCardW = () => {
        const card = slider.querySelector('[class*="snap-start"]');
        if (!card) return 300;
        return card.offsetWidth + parseInt(getComputedStyle(slider).gap || '24');
      };

      const goTo = (i) => {
        idx = i;
        slider.scrollTo({ left: i * getCardW(), behavior: 'smooth' });
        update();
      };

      const update = () => {
        if (countEl) countEl.textContent = `${String(idx + 1).padStart(2,'0')} / ${String(total).padStart(2,'0')}`;
        dots.forEach((d, di) => {
          if (di === idx) {
            d.style.width = '3rem';
            d.style.opacity = '1';
          } else {
            d.style.width = '';
            d.style.opacity = '0.4';
          }
        });
      };

      let timer = setInterval(() => goTo((idx + 1) % total), ms);
      slider.addEventListener('mouseenter', () => clearInterval(timer));
      slider.addEventListener('touchstart',  () => clearInterval(timer), { passive: true });
      slider.addEventListener('mouseleave',  () => { timer = setInterval(() => goTo((idx + 1) % total), ms); });
      slider.addEventListener('touchend',    () => {
        clearInterval(timer);
        timer = setInterval(() => goTo((idx + 1) % total), ms);
      }, { passive: true });
      slider.addEventListener('scroll', () => {
        const w = getCardW();
        if (w > 0) idx = Math.round(slider.scrollLeft / w);
        update();
      }, { passive: true });

      dots.forEach((d, di) => d.addEventListener('click', () => goTo(di)));
      update();
    }

    initSlider({ sliderId: 'services-slider', dotsId: 'services-dots', countId: 'services-count', total: 10, interval: 3000 });
    initSlider({ sliderId: 'products-slider', dotsId: 'products-dots', countId: 'products-count', total: 20, interval: 3500 });
  </script>

