---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const clients = [
  "/images/client/1.jpg",
  "/images/client/2.jpg",
  "/images/client/3.jpg",
  "/images/client/4.jpg",
  "/images/client/5.jpg",
  "/images/client/6.jpg",
  "/images/client/7.jpg",
  "/images/client/8.jpg"
];

const projects = [
  {
    title: "Hospital Water Treatment System",
    location: "Thiruvananthapuram",
    before: "/images/new_home/iron water before.png",
    after: "/images/new_home/iron water after.png",
    systemImage: "/images/products/Uf Plant.jpg",
    desc: "Complete water treatment system for a multi-speciality hospital ensuring safe drinking water for patients."
  },
  {
    title: "Industrial RO Plant Installation",
    location: "Thiruvananthapuram",
    before: "/images/new_home/salt water before.png",
    after: "/images/new_home/salt water after.png",
    systemImage: "/images/products/100000 LPH RO plant.jpg",
    desc: "High capacity RO plant installation for an industrial facility with TDS reduction and consistent water quality."
  },
  {
    title: "STP Installation - 500 KLD",
    location: "Thiruvananthapuram",
    before: "/images/new_home/waste water before.png",
    after: "/images/new_home/waste water after.png",
    systemImage: "/images/products/Sewage Treatment Plant.jpg",
    desc: "Sewage Treatment Plant installed with advanced technology for effective treatment and reuse of water."
  }
];

const treatments = [
  { name: "Iron Removal", before: "/images/new_home/iron water before.png", after: "/images/new_home/iron water after.png" },
  { name: "Hard Water Treatment", before: "/images/new_home/hard water before.png", after: "/images/new_home/hard water after.png" },
  { name: "Tank Cleaning", before: "/images/new_home/water tank cleaning before.png", after: "/images/new_home/water tank cleaning after.png" },
  { name: "Waste Water Treatment", before: "/images/new_home/waste water before.png", after: "/images/new_home/waste water after.png" }
];

const clientLogos = Array.from({ length: 24 }, (_, idx) => {
  const i = idx + 1;
  let ext = 'png';
  if (i === 38) {
    ext = 'webp';
  } else if (i === 6) {
    ext = 'svg';
  } else if (i === 43) {
    ext = 'jpg';
  }
  return `/images/client/client%20image${i}.${ext}`;
});
---

<Layout title="Samudhra Water Solutions | Kerala's Trusted Partner">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <!-- Use a custom navbar style in index if needed, or stick to the global Navbar -->
  <Navbar theme="dark" />

  <!-- HERO SECTION -->
  <section class="relative min-h-[90vh] flex items-center justify-center pt-28 sm:pt-36">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero/hero1.png" alt="Industrial Water Treatment" class="w-full h-full object-cover object-top" />
      <!-- Subtle dark overlay to ensure the white text remains readable -->
      <div class="absolute inset-0 bg-black/40"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 w-full pb-32 sm:pb-36 lg:pb-24">
      <div class="max-w-3xl space-y-6">
        <h1 class="text-[clamp(1.4rem,7vw,2.5rem)] sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] tracking-tight">
          Kerala's Trusted<br />Water Solutions Partner
        </h1>
        <p class="text-sm sm:text-xl text-white font-semibold max-w-xl" style="text-shadow: 0 2px 12px rgba(0,0,0,0.8), 0 1px 4px rgba(0,0,0,0.6);">
          From water testing to complete water treatment systems, we deliver safe, reliable & sustainable water solutions for every need.
        </p>
        <div class="flex flex-row gap-2 sm:gap-4 pt-4">
          <a href="/contact" class="inline-flex items-center justify-center px-3 py-2 sm:px-8 sm:py-3.5 bg-[#07bee8] text-[#024095] font-bold text-xs sm:text-base rounded-md hover:bg-white transition-colors gap-1 sm:gap-2">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            GET FREE WATER TESTING
          </a>
          <a href="tel:+919645830994" class="inline-flex items-center justify-center px-3 py-2 sm:px-8 sm:py-3.5 bg-transparent border-2 border-white text-white font-bold text-xs sm:text-base rounded-md hover:bg-white/10 transition-colors gap-1 sm:gap-2">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            TALK TO AN EXPERT
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR (Flow, Overlapping Hero) -->
  <div class="relative z-30 -mt-16 sm:-mt-20 px-4 sm:px-6 max-w-7xl mx-auto w-full">
    <div class="bg-white rounded-xl shadow-xl p-3 md:p-8 grid grid-cols-5 gap-1 md:gap-6 divide-x divide-slate-100">
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#024095] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138z"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">16+</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">Years<br/>Experience</span>
        </div>
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#07bee8] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">1500+</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">Projects<br/>Delivered</span>
        </div>
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#024095] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">50000+</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">Customers<br/>Served</span>
        </div>
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#07bee8] mb-1 md:mb-2">
            <svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              <path d="M2 12h20"></path>
            </svg>
          </div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">ISO</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">9001:2015<br/>Certified</span>
        </div>
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#024095] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">Govt. & Inst.</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">Projects<br/>Experience</span>
        </div>
      </div>
    </div>
  </div>

  <!-- TRUSTED BY (Moved under Hero) -->
  <section class="pt-10 pb-10 bg-[#eff6ff] overflow-hidden relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 mb-8">
      <h2 class="text-[clamp(0.55rem,2.5vw,0.75rem)] tracking-[0.15em] sm:tracking-[0.3em] font-black text-center text-[#024095] uppercase">
        TRUSTED BY KERALA'S LEADING INSTITUTIONS
      </h2>
    </div>

    <!-- Animated logo slots (No white cards, vertical upward rotation) -->
    <div class="flex items-center justify-center gap-6 sm:gap-10 md:gap-14 max-w-7xl mx-auto px-4 py-4">
      {[...Array(6)].map((_, i) => {
        const initialImgNum = i + 1;
        let ext = 'png';
        if (initialImgNum === 38) {
          ext = 'webp';
        } else if (initialImgNum === 6) {
          ext = 'svg';
        } else if (initialImgNum === 43) {
          ext = 'jpg';
        }
        const initialImg = `/images/client/client%20image${initialImgNum}.${ext}`;
        
        let visibilityClass = "flex";
        if (i >= 3) {
          visibilityClass = "hidden sm:flex";
        }

        return (
          <div class={`logo-slot overflow-hidden h-14 sm:h-16 w-28 sm:w-36 flex-shrink-0 relative ${visibilityClass}`}>
            <div class="logo-strip flex flex-col absolute w-full top-0 left-0" data-slot-index={i}>
              <div class="logo-item h-14 sm:h-16 w-full flex items-center justify-center flex-shrink-0">
                <img src={initialImg} alt="Client Logo" class="max-h-full max-w-full object-contain active-img opacity-95 hover:scale-110 transition-all duration-300 cursor-pointer" />
              </div>
              <div class="logo-item h-14 sm:h-16 w-full flex items-center justify-center flex-shrink-0">
                <img src="" alt="Client Logo" class="max-h-full max-w-full object-contain next-img opacity-95 hover:scale-110 transition-all duration-300" />
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <div class="mt-8 text-center">
      <a href="/testimonial?tab=logos" class="inline-flex items-center justify-center px-6 py-2.5 bg-transparent border-2 border-[#024095] text-[#024095] text-xs font-bold rounded hover:bg-[#024095] hover:text-white transition-colors gap-2 uppercase tracking-wide">
        View All &rarr;
      </a>
    </div>
  </section>

  <style is:global>
    .no-snap {
      scroll-snap-type: none !important;
      scroll-behavior: auto !important;
    }
    @keyframes projectSlide {
      0%, 40% { transform: translateX(0); }
      50%, 90% { transform: translateX(-50%); }
      100% { transform: translateX(0); }
    }
    .slider-animate {
      animation: projectSlide 6s infinite ease-in-out;
    }
    .project-slider:hover .slider-animate {
      animation-play-state: paused;
    }

    .logo-slot {
      position: relative;
    }
    .logo-strip {
      display: flex;
      flex-direction: column;
      width: 100%;
      height: 200%;
    }
    .logo-item {
      width: 100%;
      height: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>



  <!-- COMPLETE WATER SOLUTIONS -->
  <section class="py-20 bg-[#024095] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-[clamp(0.7rem,3.6vw,1.35rem)] max-sm:whitespace-nowrap sm:text-xl lg:text-2xl font-bold text-center mb-8 uppercase">
        COMPLETE <span class="text-[#07bee8]">WATER SOLUTIONS</span> FOR EVERY NEED
      </h2>

      <!-- Carousel wrapper -->
      <div class="relative animate-fadeIn">
        <!-- Scroll container -->
        <div id="solutions-carousel" class="flex lg:grid lg:grid-cols-3 gap-6 overflow-x-auto lg:overflow-x-visible pb-4 lg:pb-0 max-lg:snap-x max-lg:snap-mandatory max-lg:scroll-smooth cursor-default md:cursor-grab lg:cursor-default select-none" style="scrollbar-width:none; -ms-overflow-style:none;">

          <!-- Residential -->
          <div class="snap-start flex-shrink-0 w-[65vw] max-w-[260px] sm:w-72 lg:w-full lg:max-w-none lg:flex-shrink-0 bg-white rounded-xl overflow-hidden group text-slate-900 flex flex-col">
            <div class="h-32 sm:h-44 md:h-52 overflow-hidden relative">
              <img src="/images/new_home/Residential.png" alt="Residential Solutions" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-4 sm:p-6 sm:pt-5 flex flex-col flex-1">
              <div class="w-8 h-8 sm:w-10 sm:h-10 bg-white rounded-full flex items-center justify-center shadow-lg border border-slate-100 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
              </div>
              <h3 class="text-base sm:text-lg lg:text-xl font-black text-[#024095] mb-1.5 sm:mb-2">Residential<br/>Water Solutions</h3>
              <p class="text-[11px] sm:text-xs font-medium text-slate-600 mb-3 sm:mb-4 flex-1">Safe & healthy drinking water for your home and family.</p>
              <a href="/service?filter=residential" class="text-xs font-bold uppercase tracking-wider text-[#024095] hover:text-[#07bee8] transition-colors flex items-center gap-2 mt-auto">
                Explore Solutions &rarr;
              </a>
            </div>
          </div>

          <!-- Commercial -->
          <div class="snap-start flex-shrink-0 w-[65vw] max-w-[260px] sm:w-72 lg:w-full lg:max-w-none lg:flex-shrink-0 bg-white rounded-xl overflow-hidden group text-slate-900 flex flex-col">
            <div class="h-32 sm:h-44 md:h-52 overflow-hidden relative">
              <img src="/images/new_home/Commercial.png" alt="Commercial Solutions" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-4 sm:p-6 sm:pt-5 flex flex-col flex-1">
              <div class="w-8 h-8 sm:w-10 sm:h-10 bg-white rounded-full flex items-center justify-center shadow-lg border border-slate-100 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              </div>
              <h3 class="text-base sm:text-lg lg:text-xl font-black text-[#024095] mb-1.5 sm:mb-2">Commercial<br/>Water Solutions</h3>
              <p class="text-[11px] sm:text-xs font-medium text-slate-600 mb-3 sm:mb-4 flex-1">Reliable water systems for businesses & institutions.</p>
              <a href="/service?filter=commercial" class="text-xs font-bold uppercase tracking-wider text-[#024095] hover:text-[#07bee8] transition-colors flex items-center gap-2 mt-auto">
                Explore Solutions &rarr;
              </a>
            </div>
          </div>

          <!-- Industrial -->
          <div class="snap-start flex-shrink-0 w-[65vw] max-w-[260px] sm:w-72 lg:w-full lg:max-w-none lg:flex-shrink-0 bg-white rounded-xl overflow-hidden group text-slate-900 flex flex-col">
            <div class="h-32 sm:h-44 md:h-52 overflow-hidden relative">
              <img src="/images/new_home/industires.jpg" alt="Industrial Solutions" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-4 sm:p-6 sm:pt-5 flex flex-col flex-1">
              <div class="w-8 h-8 sm:w-10 sm:h-10 bg-white rounded-full flex items-center justify-center shadow-lg border border-slate-100 mb-3 sm:mb-4">
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
              </div>
              <h3 class="text-base sm:text-lg lg:text-xl font-black text-[#024095] mb-1.5 sm:mb-2">Industrial<br/>Water Treatment</h3>
              <p class="text-[11px] sm:text-xs font-medium text-slate-600 mb-3 sm:mb-4 flex-1">Advanced treatment systems for industrial applications.</p>
              <a href="/service?filter=industrial" class="text-xs font-bold uppercase tracking-wider text-[#024095] hover:text-[#07bee8] transition-colors flex items-center gap-2 mt-auto">
                Explore Solutions &rarr;
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- EVERY WATER PROBLEM HAS A SOLUTION -->
  <section class="pt-20 md:pt-32 pb-16 md:pb-24 bg-slate-50 overflow-hidden relative">
    <style>
      #problems-carousel::-webkit-scrollbar {
        display: none;
      }
    </style>
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16 animate-fadeIn">
        <span class="text-[10px] sm:text-xs md:text-sm font-extrabold tracking-widest text-[#07bee8] uppercase block mb-1">Water Quality Check</span>
        <h2 class="text-[clamp(1.1rem,4.5vw,1.75rem)] sm:text-2xl md:text-3xl font-black text-[#024095] uppercase relative inline-block pb-3">
          EVERY <span class="text-[#07bee8]">WATER PROBLEM</span> HAS A SOLUTION
          <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-16 h-[3px] bg-gradient-to-r from-[#07bee8] to-[#024095] rounded-full"></span>
        </h2>
      </div>

      <!-- Carousel wrapper -->
      <div class="relative animate-fadeIn">
        <!-- Scroll container -->
        <div id="problems-carousel" class="flex lg:grid lg:grid-cols-4 gap-6 overflow-x-auto lg:overflow-x-visible pb-4 lg:pb-0 max-lg:snap-x max-lg:snap-mandatory max-lg:scroll-smooth cursor-default md:cursor-grab select-none" style="scrollbar-width:none; -ms-overflow-style:none;">
        
          <!-- Card 1: Hard Water -->
          <div class="snap-start flex-shrink-0 w-[75vw] max-w-[320px] sm:w-80 lg:w-full lg:max-w-none lg:flex-shrink-0 bg-white rounded-3xl border border-slate-100/80 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 overflow-hidden flex flex-col">
          <!-- Split Image Header -->
          <div class="h-32 sm:h-36 relative overflow-hidden flex select-none">
            <!-- Before half -->
            <div class="w-1/2 h-full relative">
              <img src="/images/new_home/hard water before.png" alt="Hard Water Before" class="w-full h-full object-cover pointer-events-none" />
              <span class="absolute top-2 left-2 bg-red-600/80 backdrop-blur-xs text-[8px] font-black text-white px-1.5 py-0.5 rounded-md uppercase tracking-wider">Before</span>
            </div>
            <!-- Vertical Divider Line -->
            <div class="w-0.5 h-full bg-white relative z-10 animate-pulse"></div>
            <!-- After half -->
            <div class="w-1/2 h-full relative">
              <img src="/images/new_home/hard water after.png" alt="Hard Water After" class="w-full h-full object-cover pointer-events-none" />
              <span class="absolute top-2 right-2 bg-emerald-600/80 backdrop-blur-xs text-[8px] font-black text-white px-1.5 py-0.5 rounded-md uppercase tracking-wider">After</span>
            </div>
          </div>
          
          <!-- Card Body -->
