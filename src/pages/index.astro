  <script is:inline>
    (function () {
      function initCarousel(carouselId) {
        const carousel = document.getElementById(carouselId);
        if (!carousel) return;

        const originalCards = Array.from(carousel.querySelectorAll(':scope > .snap-start'));
        if (originalCards.length === 0) return;

        // Clone nodes for infinite scroll
        const firstClone = originalCards[0].cloneNode(true);
        const lastClone = originalCards[originalCards.length - 1].cloneNode(true);

        firstClone.classList.add('carousel-clone');
        lastClone.classList.add('carousel-clone');

        carousel.appendChild(firstClone);
        carousel.insertBefore(lastClone, originalCards[0]);

        const allCards = Array.from(carousel.querySelectorAll(':scope > .snap-start'));
        let currentIdx = 1; // Start at Card 1 (first original)
        let autoTimer;
        let isDragging = false;
        let startX = 0;
        let startScroll = 0;
        let isTransitioning = false;

        function getScrollPosition(idx) {
          if (idx < 0 || idx >= allCards.length) return 0;
          const card = allCards[idx];
          const cardRect = card.getBoundingClientRect();
          const carouselRect = carousel.getBoundingClientRect();
          return carousel.scrollLeft + cardRect.left - carouselRect.left;
        }

        function initScroll() {
          carousel.scrollLeft = getScrollPosition(currentIdx);
        }

        // Initial scroll to Card 1
        setTimeout(initScroll, 50);
        window.addEventListener('resize', initScroll);

        function scrollTo(idx, smooth = true) {
          if (isTransitioning) return;
          currentIdx = idx;
          const targetScroll = getScrollPosition(currentIdx);
          isTransitioning = true;
          carousel.scrollTo({
            left: targetScroll,
            behavior: smooth ? 'smooth' : 'auto'
          });
        }

        function startTimer() {
          autoTimer = setInterval(() => {
            if (isDragging) return;
            carousel.style.scrollBehavior = 'smooth';
            scrollTo(currentIdx + 1, true);
          }, 3000);
        }

        startTimer();

        // Pause on hover
        carousel.addEventListener('mouseenter', () => clearInterval(autoTimer));
        carousel.addEventListener('mouseleave', startTimer);

        // Mouse drag
        carousel.addEventListener('mousedown', (e) => {
          isDragging = true;
          startX = e.pageX;
          startScroll = carousel.scrollLeft;
          if (window.innerWidth >= 768) {
            carousel.style.cursor = 'grabbing';
          }
          carousel.style.scrollBehavior = 'auto';
          clearInterval(autoTimer);
        });

        carousel.addEventListener('mousemove', (e) => {
          if (!isDragging) return;
          e.preventDefault();
          carousel.scrollLeft = startScroll - (e.pageX - startX);
        });

        carousel.addEventListener('mouseup', () => {
          isDragging = false;
          if (window.innerWidth >= 768) {
            carousel.style.cursor = 'grab';
          } else {
            carousel.style.cursor = 'default';
          }
          carousel.style.scrollBehavior = 'smooth';
          startTimer();
        });

        carousel.addEventListener('mouseleave', () => {
          if (isDragging) {
            isDragging = false;
            if (window.innerWidth >= 768) {
              carousel.style.cursor = 'grab';
            } else {
              carousel.style.cursor = 'default';
            }
            carousel.style.scrollBehavior = 'smooth';
            startTimer();
          }
        });

        // Touch drag
        carousel.addEventListener('touchstart', (e) => {
          isDragging = true;
          startX = e.touches[0].pageX;
          startScroll = carousel.scrollLeft;
          carousel.style.scrollBehavior = 'auto';
          clearInterval(autoTimer);
        }, { passive: true });

        carousel.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          carousel.scrollLeft = startScroll - (e.touches[0].pageX - startX);
        }, { passive: true });

        carousel.addEventListener('touchend', () => {
          isDragging = false;
          carousel.style.scrollBehavior = 'smooth';
          startTimer();
        });

        // Scroll loop detection
        let checkTimer;
        carousel.addEventListener('scroll', () => {
          clearTimeout(checkTimer);
          
          const scrollLeft = carousel.scrollLeft;
          const tolerance = 10;
          const maxScroll = carousel.scrollWidth - carousel.clientWidth;

          const posCard1 = getScrollPosition(1);
          const posCardLast = getScrollPosition(allCards.length - 2);

          if (scrollLeft >= maxScroll - tolerance) {
            carousel.classList.add('no-snap');
            carousel.scrollLeft = posCard1;
            currentIdx = 1;
            carousel.offsetHeight; // force reflow
            carousel.classList.remove('no-snap');
            isTransitioning = false;
          } else if (scrollLeft <= tolerance) {
            carousel.classList.add('no-snap');
            carousel.scrollLeft = posCardLast;
            currentIdx = allCards.length - 2;
            carousel.offsetHeight; // force reflow
            carousel.classList.remove('no-snap');
            isTransitioning = false;
          }

          checkTimer = setTimeout(() => {
            isTransitioning = false;
            // Update current index when scroll settles
            const currentScroll = carousel.scrollLeft;
            let closestIdx = 1;
            let minDiff = Infinity;
            for (let i = 1; i <= allCards.length - 2; i++) {
              const pos = getScrollPosition(i);
              const diff = Math.abs(pos - currentScroll);
              if (diff < minDiff) {
                minDiff = diff;
                closestIdx = i;
              }
            }
            currentIdx = closestIdx;
          }, 150);
        });
      }

      // Initialize all carousels
      setTimeout(() => {
        initCarousel('water-carousel');
        initCarousel('solutions-carousel');
        initCarousel('projects-carousel');
        initCarousel('transforming-carousel');
      }, 100);
    })();
  </script>


