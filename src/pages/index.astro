  <!-- Scroll reveal script -->
  <!-- Slider Control and Scroll Reveal Scripts -->
  <script is:inline>
    // 1. Scroll Reveal Observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('visible'); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // 2. Services Slider Setup
    const servicesSlider = document.getElementById('services-slider');
    const servicesCount = document.getElementById('services-count');
    const servicesDots = document.getElementById('services-dots')?.children;

    if (servicesSlider) {
      const getCardWidth = () => {
        const card = servicesSlider.querySelector('.snap-start');
        return card ? card.clientWidth + 24 : 344;
      };

      let servicesIndex = 0;
      const totalServices = 10;

      const scrollToIndex = (idx) => {
        const cardWidth = getCardWidth();
        servicesSlider.scrollTo({ left: idx * cardWidth, behavior: 'smooth' });
        servicesIndex = idx;
      };

      let servicesInterval = setInterval(() => {
        let nextIdx = (servicesIndex + 1) % totalServices;
        scrollToIndex(nextIdx);
      }, 3000);

      servicesSlider.addEventListener('mouseenter', () => clearInterval(servicesInterval));
      servicesSlider.addEventListener('mouseleave', () => {
        servicesInterval = setInterval(() => {
          let nextIdx = (servicesIndex + 1) % totalServices;
          scrollToIndex(nextIdx);
        }, 3000);
      });

      const updateServicesState = () => {
        const cardWidth = getCardWidth();
        const idx = Math.round(servicesSlider.scrollLeft / cardWidth);
        servicesIndex = idx;
        const displayIdx = Math.min(Math.max(idx + 1, 1), totalServices);
        
        if (servicesCount) {
          servicesCount.textContent = `${displayIdx.toString().padStart(2, '0')} / ${totalServices.toString().padStart(2, '0')}`;
        }
        
        if (servicesDots) {
          Array.from(servicesDots).forEach((dot, dIdx) => {
            if (dIdx === idx) {
              dot.classList.remove('bg-white/20');
              dot.classList.add('bg-[#07bee8]', 'w-12');
            } else {
              dot.classList.remove('bg-[#07bee8]', 'w-12');
              dot.classList.add('bg-white/20');
            }
          });
        }
      };

      servicesSlider.addEventListener('scroll', updateServicesState);
      window.addEventListener('resize', updateServicesState);
      updateServicesState();

      if (servicesDots) {
        Array.from(servicesDots).forEach((dot, dIdx) => {
          dot.addEventListener('click', () => {
            scrollToIndex(dIdx);
          });
        });
      }
    }

    // 3. Products Slider Setup
    const productsSlider = document.getElementById('products-slider');
    const productsCount = document.getElementById('products-count');
    const productsDots = document.getElementById('products-dots')?.children;

    if (productsSlider) {
      const getCardWidth = () => {
        const card = productsSlider.querySelector('.snap-start');
        return card ? card.clientWidth + 24 : 312;
      };

      let productsIndex = 0;
      const totalProducts = 20;

      const scrollToIndex = (idx) => {
        const cardWidth = getCardWidth();
        productsSlider.scrollTo({ left: idx * cardWidth, behavior: 'smooth' });
        productsIndex = idx;
      };

      let productsInterval = setInterval(() => {
        let nextIdx = (productsIndex + 1) % totalProducts;
        scrollToIndex(nextIdx);
      }, 3500);

      productsSlider.addEventListener('mouseenter', () => clearInterval(productsInterval));
      productsSlider.addEventListener('mouseleave', () => {
        productsInterval = setInterval(() => {
          let nextIdx = (productsIndex + 1) % totalProducts;
          scrollToIndex(nextIdx);
        }, 3500);
      });

      const updateProductsState = () => {
        const cardWidth = getCardWidth();
        const idx = Math.round(productsSlider.scrollLeft / cardWidth);
        productsIndex = idx;
        const displayIdx = Math.min(Math.max(idx + 1, 1), totalProducts);
        
        if (productsCount) {
          productsCount.textContent = `${displayIdx.toString().padStart(2, '0')} / ${totalProducts.toString().padStart(2, '0')}`;
        }
        
        if (productsDots) {
          Array.from(productsDots).forEach((dot, dIdx) => {
            if (dIdx === idx) {
              dot.classList.remove('bg-slate-200');
              dot.classList.add('bg-[#024095]', 'w-10');
            } else {
              dot.classList.remove('bg-[#024095]', 'w-10');
              dot.classList.add('bg-slate-200');
            }
          });
        }
      };

      productsSlider.addEventListener('scroll', updateProductsState);
      window.addEventListener('resize', updateProductsState);
      updateProductsState();

      if (productsDots) {
        Array.from(productsDots).forEach((dot, dIdx) => {
          dot.addEventListener('click', () => {
            scrollToIndex(dIdx);
          });
        });
      }
    }
  </script>

