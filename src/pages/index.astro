---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const clients = [
  "/images/client/1.jpg",
  "/images/client/2.jpg",
  "/images/client/3.jpg",
  "/images/client/4.jpg",
  "/images/client/5.jpg",
  "/images/client/6.jpg",
  "/images/client/7.jpg",
  "/images/client/8.jpg"
];

const projects = [
  {
    title: "Hospital Water Treatment System",
    location: "Thiruvananthapuram",
    before: "/images/products/DM plant.jpg",
    after: "/images/products/Uf Plant.jpg",
    desc: "Complete water treatment system for a multi-speciality hospital ensuring safe drinking water for patients."
  },
  {
    title: "Industrial RO Plant Installation",
    location: "Ernakulam",
    before: "/images/products/Desalination Water Filtration.jpg",
    after: "/images/products/100000 LPH RO plant.jpg",
    desc: "High capacity RO plant installation for an industrial facility with TDS reduction and consistent water quality."
  },
  {
    title: "STP Installation - 500 KLD",
    location: "Kollam",
    before: "/images/products/Sewage Treatment Plant.jpg",
    after: "/images/products/Effluent Treatment Plant.jpg",
    desc: "Sewage Treatment Plant installed with advanced technology for effective treatment and reuse of water."
  }
];

const treatments = [
  { name: "Iron Removal", before: "/images/new_home/iron_water_1781948634540.png", after: "https://images.unsplash.com/photo-1541336032412-2048a678540d?q=80&w=600&auto=format&fit=crop" },
  { name: "Hard Water Treatment", before: "/images/new_home/hard_water_1781948623171.png", after: "https://images.unsplash.com/photo-1523362628745-0c100150b504?q=80&w=600&auto=format&fit=crop" },
  { name: "Tank Cleaning", before: "/images/how do we work/Inspection and Assessment.jpg", after: "/images/how do we work/Commissioning.jpg" },
  { name: "Waste Water Treatment", before: "/images/new_home/waste_water_1781948670592.png", after: "https://images.unsplash.com/photo-1470509037663-253afd7f0f51?q=80&w=600&auto=format&fit=crop" }
];
---

<Layout title="Samudhra Water Solutions | Kerala's Trusted Partner">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <!-- Use a custom navbar style in index if needed, or stick to the global Navbar -->
  <Navbar theme="dark" />

  <!-- HERO SECTION -->
  <section class="relative min-h-[90vh] flex items-center justify-center pt-20">
    <div class="absolute inset-0 z-0">
      <img src="/images/new_home/hero_bg_1781948610252.png" alt="Industrial Water Treatment" class="w-full h-full object-cover object-top" />
      <!-- Subtle dark overlay to ensure the white text remains readable -->
      <div class="absolute inset-0 bg-black/40"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 w-full pb-32 sm:pb-36 lg:pb-24">
      <div class="max-w-3xl space-y-6">
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] tracking-tight">
          Kerala's Trusted<br />Water Solutions Partner
        </h1>
        <p class="text-lg sm:text-xl text-blue-100 font-medium max-w-xl">
          From water testing to complete water treatment systems, we deliver safe, reliable & sustainable water solutions for every need.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a href="/contact" class="inline-flex items-center justify-center px-8 py-3.5 bg-[#07bee8] text-[#024095] font-bold rounded-md hover:bg-white transition-colors gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            GET FREE WATER TESTING
          </a>
          <a href="tel:+919645830994" class="inline-flex items-center justify-center px-8 py-3.5 bg-transparent border-2 border-white text-white font-bold rounded-md hover:bg-white/10 transition-colors gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            TALK TO AN EXPERT
          </a>
        </div>
      </div>
    </div>

    <!-- STATS BAR (Overlapping) -->
    <div class="absolute bottom-0 left-0 right-0 transform translate-y-1/2 z-20 px-4 sm:px-6 max-w-7xl mx-auto w-full">
      <div class="bg-white rounded-xl shadow-xl p-6 sm:p-8 grid grid-cols-2 md:grid-cols-5 gap-6 divide-x-0 md:divide-x divide-slate-100">
        <div class="flex flex-col items-center text-center px-2">
          <div class="text-[#024095] text-3xl mb-2"><svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg></div>
          <span class="text-2xl font-black text-[#024095]">17+</span>
          <span class="text-xs text-slate-500 font-bold uppercase tracking-wider mt-1">Years<br/>Experience</span>
        </div>
        <div class="flex flex-col items-center text-center px-2">
          <div class="text-[#07bee8] text-3xl mb-2"><svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg></div>
          <span class="text-2xl font-black text-[#024095]">1000+</span>
          <span class="text-xs text-slate-500 font-bold uppercase tracking-wider mt-1">Projects<br/>Delivered</span>
        </div>
        <div class="flex flex-col items-center text-center px-2">
          <div class="text-[#024095] text-3xl mb-2"><svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg></div>
          <span class="text-2xl font-black text-[#024095]">10000+</span>
          <span class="text-xs text-slate-500 font-bold uppercase tracking-wider mt-1">Customers<br/>Served</span>
        </div>
        <div class="flex flex-col items-center text-center px-2">
          <div class="text-[#07bee8] text-3xl mb-2"><svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
          <span class="text-2xl font-black text-[#024095]">ISO</span>
          <span class="text-xs text-slate-500 font-bold uppercase tracking-wider mt-1">9001:2015<br/>Certified</span>
        </div>
        <div class="flex flex-col items-center text-center px-2 col-span-2 md:col-span-1">
          <div class="text-[#024095] text-3xl mb-2"><svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"></path></svg></div>
          <span class="text-2xl font-black text-[#024095]">Govt. & Inst.</span>
          <span class="text-xs text-slate-500 font-bold uppercase tracking-wider mt-1">Projects<br/>Experience</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUSTED BY (Moved under Hero) -->
  <section class="pt-40 sm:pt-36 md:pt-32 pb-16 bg-[#024095]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-xl sm:text-2xl font-bold text-center text-white mb-10 uppercase tracking-widest">
        TRUSTED BY KERALA'S LEADING INSTITUTIONS
      </h2>

      <div class="flex flex-wrap justify-center items-center gap-6 sm:gap-10">
        {clients.slice(0, 8).map(client => (
          <div class="bg-white p-3 rounded shadow-md flex items-center justify-center w-28 h-20">
            <img src={client} alt="Client Logo" class="max-w-full max-h-full object-contain filter grayscale hover:grayscale-0 transition-all duration-300" />
          </div>
        ))}
      </div>
      
      <div class="text-center mt-8">
        <span class="inline-block px-4 py-1.5 bg-[#024095] border border-white/30 text-white text-xs font-bold rounded-full">
          &amp; 100+ MORE CLIENTS
        </span>
      </div>
    </div>
  </section>

  <!-- EVERY WATER PROBLEM HAS A SOLUTION -->
  <section class="pt-40 pb-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-bold text-center text-[#024095] mb-12 uppercase">
        EVERY <span class="text-[#07bee8]">WATER PROBLEM</span> HAS A SOLUTION
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 group">
          <div class="h-48 overflow-hidden relative rounded-t-xl">
            <img src="/images/new_home/hard_water_1781948623171.png" alt="Hard Water" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-[#024095]/20"></div>
          </div>
          <div class="px-6 pt-6 pb-6">
            <div class="flex justify-center mb-4">
              <div class="w-12 h-12 bg-[#024095] rounded-full flex items-center justify-center shadow-lg">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
              </div>
            </div>
            <h3 class="text-xl font-bold text-[#024095] mb-3 text-center">Hard Water</h3>
            <ul class="space-y-2 text-sm text-slate-600 font-medium">
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Bathroom stains</li>
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Pipe scaling</li>
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Appliance damage</li>
            </ul>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 group">
          <div class="h-48 overflow-hidden relative rounded-t-xl">
            <img src="/images/new_home/iron_water_1781948634540.png" alt="Iron Water" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-[#024095]/20"></div>
          </div>
          <div class="px-6 pt-6 pb-6">
            <div class="flex justify-center mb-4">
              <div class="w-12 h-12 bg-[#024095] rounded-full flex items-center justify-center shadow-lg">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>
              </div>
            </div>
            <h3 class="text-xl font-bold text-[#024095] mb-3 text-center">Iron Water</h3>
            <ul class="space-y-2 text-sm text-slate-600 font-medium">
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Brown water</li>
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Bad smell</li>
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Health concerns</li>
            </ul>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 group">
          <div class="h-48 overflow-hidden relative rounded-t-xl">
            <img src="/images/new_home/salty_water_1781948658809.png" alt="Salty Water" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-[#024095]/20"></div>
          </div>
          <div class="px-6 pt-6 pb-6">
            <div class="flex justify-center mb-4">
              <div class="w-12 h-12 bg-[#024095] rounded-full flex items-center justify-center shadow-lg">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
            </div>
            <h3 class="text-xl font-bold text-[#024095] mb-3 text-center">Salty Water</h3>
            <ul class="space-y-2 text-sm text-slate-600 font-medium">
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Coastal areas</li>
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> High TDS</li>
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Poor taste</li>
            </ul>
          </div>
        </div>

        <!-- Card 4 -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 group">
          <div class="h-48 overflow-hidden relative rounded-t-xl">
            <img src="/images/new_home/waste_water_1781948670592.png" alt="Waste Water" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-[#024095]/20"></div>
          </div>
          <div class="px-6 pt-6 pb-6">
            <div class="flex justify-center mb-4">
              <div class="w-12 h-12 bg-[#024095] rounded-full flex items-center justify-center shadow-lg">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
              </div>
            </div>
            <h3 class="text-xl font-bold text-[#024095] mb-3 text-center">Waste Water</h3>
            <ul class="space-y-2 text-sm text-slate-600 font-medium">
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Industrial discharge</li>
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Recycling challenges</li>
              <li class="flex items-start gap-2"><span class="text-[#07bee8] mt-1">•</span> Compliance issues</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-3 bg-transparent border-2 border-[#024095] text-[#024095] font-bold rounded-md hover:bg-[#024095] hover:text-white transition-colors gap-2 uppercase tracking-wide">
          Book Free Water Testing &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- COMPLETE WATER SOLUTIONS -->
  <section class="py-20 bg-[#024095] text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl sm:text-4xl font-bold text-center mb-12 uppercase">
        COMPLETE <span class="text-[#07bee8]">WATER SOLUTIONS</span> FOR EVERY NEED
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Residential -->
        <div class="bg-white rounded-xl overflow-hidden group text-slate-900 flex flex-col">
          <div class="h-64 overflow-hidden relative">
            <img src="/images/new_home/residential_home_1781948726505.png" alt="Residential Solutions" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-8 pt-6 flex flex-col flex-1">
            <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-lg border border-slate-100 mb-6">
              <svg class="w-7 h-7 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            </div>
            <h3 class="text-2xl font-black text-[#024095] mb-3">Residential<br/>Water Solutions</h3>
            <p class="text-sm font-medium text-slate-600 mb-6 flex-1">Safe & healthy drinking water for your home and family.</p>
            <a href="/service" class="text-xs font-bold uppercase tracking-wider text-[#024095] hover:text-[#07bee8] transition-colors flex items-center gap-2 mt-auto">
              Explore Solutions &rarr;
            </a>
          </div>
        </div>

        <!-- Commercial -->
        <div class="bg-white rounded-xl overflow-hidden group text-slate-900 flex flex-col">
          <div class="h-64 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1470&auto=format&fit=crop" alt="Commercial Solutions" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-8 pt-6 flex flex-col flex-1">
            <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-lg border border-slate-100 mb-6">
              <svg class="w-7 h-7 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            </div>
            <h3 class="text-2xl font-black text-[#024095] mb-3">Commercial<br/>Water Solutions</h3>
            <p class="text-sm font-medium text-slate-600 mb-6 flex-1">Reliable water systems for businesses & institutions.</p>
            <a href="/service" class="text-xs font-bold uppercase tracking-wider text-[#024095] hover:text-[#07bee8] transition-colors flex items-center gap-2 mt-auto">
              Explore Solutions &rarr;
            </a>
          </div>
        </div>

        <!-- Industrial -->
        <div class="bg-white rounded-xl overflow-hidden group text-slate-900 flex flex-col">
          <div class="h-64 overflow-hidden relative">
            <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=1470&auto=format&fit=crop" alt="Industrial Solutions" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-8 pt-6 flex flex-col flex-1">
            <div class="w-14 h-14 bg-white rounded-full flex items-center justify-center shadow-lg border border-slate-100 mb-6">
              <svg class="w-7 h-7 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            </div>
            <h3 class="text-2xl font-black text-[#024095] mb-3">Industrial<br/>Water Treatment</h3>
            <p class="text-sm font-medium text-slate-600 mb-6 flex-1">Advanced treatment systems for industrial applications.</p>
            <a href="/service" class="text-xs font-bold uppercase tracking-wider text-[#024095] hover:text-[#07bee8] transition-colors flex items-center gap-2 mt-auto">
              Explore Solutions &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>



  <!-- FOUNDER SECTION -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <!-- Profile Card -->
        <div class="lg:col-span-4 space-y-6 border-l-4 border-[#024095] bg-slate-50 p-6 sm:p-8 rounded-r-xl shadow-sm">
          <div class="w-full rounded-lg overflow-hidden border border-slate-200 shadow-md">
