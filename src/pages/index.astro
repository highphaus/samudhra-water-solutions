---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const services = [
  { num: "01", title: "UF Plant Installation & Maintenance", image: "/images/products/Uf Plant.jpg", tag: "Filtration" },
  { num: "02", title: "Swimming Pool Filtration Plant", image: "/images/products/Swimming Pool Filtration Plant.jpeg", tag: "Commercial" },
  { num: "03", title: "Sewage Treatment Plant (STP)", image: "/images/products/Sewage Treatment Plant.jpg", tag: "Infrastructure" },
  { num: "04", title: "Effluent Treatment Plants (ETPs)", image: "/images/products/Effluent Treatment Plant.jpg", tag: "Industrial" },
  { num: "05", title: "De-Mineralizing (DM) Plants", image: "/images/products/DM plant.jpg", tag: "Purification" },
  { num: "06", title: "Desalination Water Filtration Plants", image: "/images/products/Desalination Water Filtration.jpg", tag: "Coastal" },
  { num: "07", title: "100,000 LPH RO Plant", image: "/images/products/100000 LPH RO plant.jpg", tag: "Large Scale" },
  { num: "08", title: "250 LPH RO Plant", image: "/images/products/100LPH-10000LPH RO Plant.jpg", tag: "Commercial" },
  { num: "09", title: "MultiBrand Water Purifier Servicing", image: "/images/products/Multibrand Water Purifiers.jpg", tag: "Servicing" },
  { num: "10", title: "Water Tank Cleaning", image: "/images/products/Stainless steel water tanks.jpg", tag: "Maintenance" },
];

const products = [
  { name: "100000 LPH RO Plant", image: "/images/products/100000 LPH RO plant.jpg", tier: "Industrial Tier", availability: "Built to Order" },
  { name: "100LPH–10000LPH RO Plant", image: "/images/products/100LPH-10000LPH RO Plant.jpg", tier: "Commercial Tier", availability: "Built to Order" },
  { name: "AQUA C3", image: "/images/products/AQUA C3.jpg", tier: "Residential", availability: "In Stock" },
  { name: "AQUA XZORA", image: "/images/products/AQUA XZORA.jpg", tier: "Residential", availability: "In Stock" },
  { name: "AQUA 9090", image: "/images/products/AQUA9090.jpg", tier: "Residential", availability: "In Stock" },
  { name: "BELLA+ & AVA+", image: "/images/products/BELLA+ & AVA+.jpg", tier: "Residential", availability: "In Stock" },
  { name: "DM Plant", image: "/images/products/DM plant.jpg", tier: "Industrial Tier", availability: "Built to Order" },
  { name: "Desalination Filtration", image: "/images/products/Desalination Water Filtration.jpg", tier: "Industrial Tier", availability: "Built to Order" },
  { name: "Effluent Treatment Plant", image: "/images/products/Effluent Treatment Plant.jpg", tier: "Infrastructure", availability: "Built to Order" },
  { name: "Hot & Cold Dispenser", image: "/images/products/HOT AND COLD Water Dispenser.jpg", tier: "Commercial Tier", availability: "In Stock" },
  { name: "Multibrand Purifiers", image: "/images/products/Multibrand Water Purifiers.jpg", tier: "Residential", availability: "In Stock" },
  { name: "PZONE BLACK Purifier", image: "/images/products/PZONE BLACK Water purifier.jpg", tier: "Residential", availability: "In Stock" },
  { name: "SALVADOR RO Purifier", image: "/images/products/SALVADOR RO water purifier.jpg", tier: "Residential", availability: "In Stock" },
  { name: "Sewage Treatment Plant", image: "/images/products/Sewage Treatment Plant.jpg", tier: "Infrastructure", availability: "Built to Order" },
  { name: "Stainless Steel Water Tanks", image: "/images/products/Stainless steel water tanks.jpg", tier: "Storage", availability: "In Stock" },
  { name: "Swimming Pool Filtration", image: "/images/products/Swimming Pool Filtration Plant.jpeg", tier: "Commercial Tier", availability: "Built to Order" },
  { name: "UF Plant", image: "/images/products/Uf Plant.jpg", tier: "Commercial Tier", availability: "Built to Order" },
  { name: "Water Softening Plant", image: "/images/products/Water softening plant.jpg", tier: "Infrastructure", availability: "Built to Order" },
  { name: "Water Treatment Plant", image: "/images/products/Water treatment plant.jpg", tier: "Infrastructure", availability: "Built to Order" },
  { name: "ZEDERA Water Purifiers", image: "/images/products/ZEDERA WATER PURIFIERS.jpg", tier: "Residential", availability: "In Stock" },
];
---

<Layout title="Samudhra Water Solutions | Pure Water Systems & Support">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <style>
    /* Hide scrollbar for Chrome, Safari and Opera */
    .scrollbar-none::-webkit-scrollbar {
      display: none !important;
    }
    /* Hide scrollbar for IE, Edge and Firefox */
    .scrollbar-none {
      -ms-overflow-style: none !important;  /* IE and Edge */
      scrollbar-width: none !important;  /* Firefox */
    }

    /* ── Hero gradient pulse ── */
    @keyframes pulse-blob {
      0%, 100% { transform: scale(1) translate(0, 0); opacity: .6; }
      50%       { transform: scale(1.15) translate(20px, -10px); opacity: .9; }
    }
    .hero-blob { animation: pulse-blob 8s ease-in-out infinite; }

    /* ── Counter number animation ── */
    @keyframes count-up {
      from { opacity:0; transform: translateY(10px); }
      to   { opacity:1; transform: translateY(0); }
    }
    .stat-num { animation: count-up .6s ease-out both; }

    /* ── Section fade-in on scroll ── */
    .reveal { opacity:0; transform:translateY(30px); transition: opacity .7s ease, transform .7s ease; }
    .reveal.visible { opacity:1; transform:translateY(0); }

    /* ── Availability badge ── */
    .badge-stock   { background:#ecfdf5; color:#059669; }
    .badge-order   { background:#fff7ed; color:#d97706; }
  </style>

  <!-- ======================================================== -->
  <!-- 1. HERO -->
  <!-- ======================================================== -->
  <section id="home" class="relative min-h-screen flex items-center bg-[#F9F9FB] overflow-hidden pt-20">
    <!-- Decorative blobs -->
    <div class="hero-blob absolute top-[-80px] right-[-60px] w-[520px] h-[520px] rounded-full bg-gradient-to-br from-[#07bee8]/20 to-[#024095]/10 blur-3xl pointer-events-none"></div>
    <div class="hero-blob absolute bottom-[-100px] left-[-80px] w-[420px] h-[420px] rounded-full bg-gradient-to-tr from-[#024095]/10 to-[#07bee8]/10 blur-3xl pointer-events-none" style="animation-delay:4s"></div>
    <div class="absolute inset-y-0 right-0 w-[30%] bg-[#024095]/4 hidden lg:block" style="clip-path:polygon(10% 0,100% 0,100% 100%,0% 100%)"></div>

    <div class="max-w-7xl mx-auto px-6 w-full py-24 relative z-10">
      <div class="grid lg:grid-cols-12 gap-12 items-center">

        <!-- Left copy -->
        <div class="lg:col-span-7 space-y-8 text-center lg:text-left">
          <div class="inline-flex items-center gap-3 px-4 py-2 bg-white border-l-4 border-[#07bee8] shadow-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-[#07bee8] animate-pulse"></span>
            <span class="text-[10px] font-black uppercase tracking-[0.35em] text-[#024095]">Kerala's Premium Water Solutions Since 2009</span>
          </div>

          <h1 class="text-5xl sm:text-7xl lg:text-8xl font-black tracking-tighter text-[#024095] leading-[0.92] uppercase">
            PURE WATER.<br/>
            WITHOUT THE<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#024095] via-[#07bee8] to-slate-400">PLASTIC WASTE.</span>
          </h1>

          <p class="text-base sm:text-lg text-slate-600 max-w-xl mx-auto lg:mx-0 font-medium leading-relaxed">
            We provide custom water purifiers for houses and high-capacity water plants for businesses. Trusted clean water across Trivandrum.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4 pt-2">
            <a href="/shop" class="w-full sm:w-auto px-8 py-4 bg-[#024095] text-white font-extrabold text-xs uppercase tracking-[0.2em] rounded-md shadow-lg hover:bg-[#07bee8] transition-all duration-300 text-center">
              View Our Products
            </a>
            <a href="/contact" class="w-full sm:w-auto px-8 py-4 bg-white border-2 border-[#024095] text-[#024095] font-extrabold text-xs uppercase tracking-[0.2em] rounded-md hover:bg-[#024095] hover:text-white transition-all duration-300 text-center">
              Contact Our Desk
            </a>
          </div>
        </div>

        <!-- Right stats -->
        <div class="lg:col-span-5 grid grid-cols-2 gap-4">
          {[
            { label:"Water Purity",   val:"99.7%",    accent:"#024095" },
            { label:"Max Plant Size", val:"100k LPH",  accent:"#07bee8" },
            { label:"Years Active",   val:"17+",       accent:"#07bee8" },
            { label:"Quality Code",   val:"ISO 9001",  accent:"#024095" },
          ].map(s => (
            <div class={`bg-white p-6 border-b-4 shadow-md rounded-md space-y-2 hover:shadow-xl transition-shadow`} style={`border-color:${s.accent}`}>
              <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">{s.label}</p>
              <p class="text-2xl font-black" style={`color:${s.accent}`}>{s.val}</p>
            </div>
          ))}

          <!-- Quick links row -->
          <div class="col-span-2 bg-white rounded-md shadow-md border border-slate-100 p-4 flex items-center justify-between gap-2 flex-wrap">
            {[
              {href:"/service", label:"Services"},
              {href:"/shop",    label:"Products"},
              {href:"/about",   label:"About Us"},
              {href:"/contact", label:"Contact"},
            ].map(l => (
              <a href={l.href} class="text-[9px] font-black uppercase tracking-[0.2em] text-slate-400 hover:text-[#024095] transition-colors px-2 py-1">{l.label}</a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- 2. SERVICES SLIDER -->
  <!-- ======================================================== -->
  <section id="services-carousel" class="bg-[#024095] text-white py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 mb-12 reveal">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#07bee8] mb-2">What We Do</p>
          <h2 class="text-4xl sm:text-6xl font-black tracking-tighter uppercase leading-none">Our Services.</h2>
          <p class="text-sm text-white/60 font-light mt-3 max-w-md leading-relaxed">10 specialised water treatment and maintenance services engineered for every scale.</p>
        </div>
        <div class="flex items-center">
          <a href="/service" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/30 text-white text-xs font-black uppercase tracking-[0.2em] hover:bg-white hover:text-[#024095] transition-all rounded whitespace-nowrap">
            See All Services &rarr;
          </a>
        </div>
      </div>
    </div>

    <!-- Snapping Slider Container -->
    <div class="relative max-w-7xl mx-auto px-6">
      <div id="services-slider" class="flex gap-6 overflow-x-auto scroll-smooth scrollbar-none snap-x snap-mandatory py-4">
        {services.map((svc) => (
          <a href="/service" class="group snap-start flex-shrink-0 w-80 bg-white/[0.03] hover:bg-white/[0.08] border border-white/10 hover:border-[#07bee8] rounded-2xl overflow-hidden transition-all duration-500 backdrop-blur-sm flex flex-col justify-between h-[420px] shadow-lg hover:shadow-2xl hover:-translate-y-1">
            <div class="relative h-52 overflow-hidden bg-white/5">
              <img src={svc.image} alt={svc.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out" />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/20 to-transparent opacity-80"></div>
              <div class="absolute top-4 left-4">
                <span class="text-[9px] font-black uppercase tracking-widest text-[#07bee8] bg-[#07bee8]/15 border border-[#07bee8]/30 px-3 py-1 rounded-full">{svc.tag}</span>
              </div>
              <div class="absolute top-4 right-4">
                <span class="text-2xl font-mono font-black text-white/30 group-hover:text-[#07bee8] transition-colors">#{svc.num}</span>
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col justify-between bg-gradient-to-b from-transparent to-black/20">
              <div class="space-y-3">
                <h3 class="text-xl font-black uppercase tracking-tight text-white group-hover:text-[#07bee8] transition-colors leading-snug">{svc.title}</h3>
                <p class="text-xs text-white/50 line-clamp-3 leading-relaxed font-light">
                  Professional installation, calibration and service operations. Assured safety standards compliance for clean yields.
                </p>
              </div>
              <div class="pt-4 flex items-center justify-between border-t border-white/5">
                <span class="text-[10px] font-extrabold uppercase tracking-widest text-[#07bee8] group-hover:text-white transition-colors">Book Service</span>
                <div class="w-8 h-8 rounded-full bg-white/10 group-hover:bg-[#07bee8] text-white flex items-center justify-center transition-all duration-300 transform group-hover:translate-x-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Slider indicator / dots -->
      <div class="mt-8 flex justify-between items-center text-xs font-bold text-white/40">
        <div class="flex gap-1.5 flex-wrap" id="services-dots">
          {services.map((_, i) => (
            <button class="w-8 h-1 rounded bg-white/20 transition-all duration-300 focus:outline-none" data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
          ))}
        </div>
        <span id="services-count">01 / 10</span>
      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- 3. PRODUCTS SLIDER -->
  <!-- ======================================================== -->
  <section id="products-carousel" class="bg-[#F9F9FB] text-slate-900 py-24 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 mb-12 reveal">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#07bee8] mb-2">Shop Products</p>
          <h2 class="text-4xl sm:text-6xl font-black tracking-tighter uppercase text-[#024095] leading-none">Our Products.</h2>
          <p class="text-sm text-slate-500 font-light mt-3 max-w-md leading-relaxed">20 curated water purification systems — from compact home purifiers to 100,000 LPH industrial plants.</p>
        </div>
        <div class="flex items-center">
          <a href="/shop" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-[#024095] text-[#024095] text-xs font-black uppercase tracking-[0.2em] hover:bg-[#024095] hover:text-white transition-all rounded whitespace-nowrap">
            Open Shop &rarr;
          </a>
        </div>
      </div>
    </div>

    <!-- Snapping Slider Container -->
    <div class="relative max-w-7xl mx-auto px-6">
      <div id="products-slider" class="flex gap-6 overflow-x-auto scroll-smooth scrollbar-none snap-x snap-mandatory py-4">
        {products.map((p) => (
          <a href="/shop" class="group snap-start flex-shrink-0 w-72 bg-white hover:shadow-[0_20px_40px_rgba(0,0,0,0.06)] border border-slate-100 hover:border-[#024095]/30 rounded-2xl overflow-hidden transition-all duration-500 flex flex-col justify-between h-[420px] hover:-translate-y-1">
            <div class="relative h-48 bg-gradient-to-b from-[#F9F9FB] to-white flex items-center justify-center p-6 overflow-hidden border-b border-slate-100/60">
              <img src={p.image} alt={p.name} class="max-h-full max-w-full object-contain group-hover:scale-110 transition-transform duration-700 ease-out" />
              <div class="absolute top-4 left-4">
                <span class="text-[8px] font-mono font-black text-[#07bee8] bg-slate-50 border border-slate-100 px-2.5 py-1 rounded-full uppercase tracking-wider">{p.tier}</span>
              </div>
              <div class="absolute top-4 right-4">
                <span class={`text-[8px] font-extrabold uppercase tracking-wider px-2.5 py-1 rounded-full shadow-sm ${p.availability === 'In Stock' ? 'badge-stock' : 'badge-order'}`}>
                  {p.availability}
                </span>
              </div>
            </div>
            <div class="p-6 flex-1 flex flex-col justify-between">
              <div class="space-y-2">
                <h3 class="text-lg font-black uppercase tracking-tight text-[#024095] group-hover:text-[#07bee8] transition-colors leading-tight line-clamp-2">{p.name}</h3>
                <p class="text-xs text-slate-500 font-light leading-relaxed">
                  High-efficiency multi-stage system built using top grade components. Perfect for pure water demands.
                </p>
              </div>
              <div class="pt-4 flex items-center justify-between border-t border-slate-100">
                <span class="text-[10px] font-extrabold uppercase tracking-widest text-slate-400 group-hover:text-[#024095] transition-colors">Inquire Now</span>
                <div class="w-8 h-8 rounded-full bg-slate-50 group-hover:bg-[#024095] group-hover:text-white text-slate-600 flex items-center justify-center transition-all duration-300 transform group-hover:translate-x-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Slider indicator / dots -->
      <div class="mt-8 flex justify-between items-center text-xs font-bold text-slate-400">
        <div class="flex gap-1.5 flex-wrap" id="products-dots">
          {products.map((_, i) => (
            <button class="w-6 h-1 rounded bg-slate-200 transition-all duration-300 focus:outline-none" data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
          ))}
        </div>
        <span id="products-count">01 / 20</span>
      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- 4. ABOUT SUMMARY -->
  <!-- ======================================================== -->
  <section id="about-summary" class="bg-white text-slate-900 border-t border-slate-100 py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-12 items-center reveal">
        <div class="lg:col-span-7 space-y-6">
          <p class="text-[10px] font-bold uppercase tracking-[0.35em] text-[#07bee8]">About Our Company</p>
          <h2 class="text-4xl sm:text-6xl font-black tracking-tighter text-[#024095] uppercase leading-none">Who We Are.</h2>
          <p class="text-sm text-slate-500 font-light leading-relaxed max-w-xl">
            Started in 2009 in Thiruvananthapuram, Samudhra fixes local water problems. We don't sell generic filters — we test your water supply and engineer a custom solution that's always completely clean and safe.
          </p>
          <div class="grid grid-cols-3 gap-4 pt-2">
            {[
              { val:"17+", label:"Years Experience" },
              { val:"02",  label:"Showrooms TVM" },
              { val:"10+", label:"Service Types" },
            ].map(s => (
              <div class="border border-slate-100 rounded-lg p-4 text-center hover:border-[#07bee8] transition-colors">
                <p class="text-2xl font-black text-[#024095]">{s.val}</p>
                <p class="text-[9px] text-slate-400 uppercase tracking-wider mt-1 font-bold">{s.label}</p>
              </div>
            ))}
          </div>
          <div class="pt-4">
            <a href="/about" class="inline-block text-center px-8 py-4 bg-[#024095] text-white font-extrabold text-xs uppercase tracking-[0.2em] rounded-md hover:bg-[#07bee8] transition-all duration-300 shadow-md shadow-[#024095]/10">
              Read Our Full History &rarr;
            </a>
          </div>
        </div>
        <div class="lg:col-span-5 relative group">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#024095]/10 to-[#07bee8]/10 rounded-2xl filter blur-xl transform translate-x-2 translate-y-2 opacity-70 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative overflow-hidden rounded-2xl border border-slate-100 shadow-xl bg-white">
            <img 
              src="/images/office image/Samdhura Office.jpg" 
              alt="Samudhra Water Solutions Corporate Office Interior" 
              class="w-full h-80 object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
            />
            <div class="absolute bottom-4 left-4 bg-white/95 backdrop-blur-sm px-4 py-2 rounded-lg border border-slate-100 shadow-sm">
              <p class="text-[9px] font-mono font-black text-[#024095] uppercase tracking-wider">// POOJAPPURA HQ</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======================================================== -->
  <!-- 4.5 HOW WE WORK -->
  <!-- ======================================================== -->
  <section id="how-we-work" class="bg-[#F9F9FB] text-slate-900 border-t border-slate-100 py-24">
    <div class="max-w-7xl mx-auto px-6">
      
      <!-- Section Header -->
      <div class="text-center max-w-2xl mx-auto mb-16 space-y-4 reveal">
        <p class="text-[10px] font-bold uppercase tracking-[0.4em] text-[#07bee8]">Process Integrity</p>
        <h2 class="text-4xl sm:text-5xl font-black tracking-tighter text-[#024095] uppercase">How We Work.</h2>
        <p class="text-sm text-black font-semibold leading-relaxed">
          From first water testing chemical reviews to precision component selection and ongoing maintenance audit loops.
        </p>
      </div>

      <!-- Steps Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 reveal">
        {[
          {
            step: "01",
            title: "Water Analysis",
            desc: "Our on-site field technicians chemically audit your source water to measure heavy iron, mineral scales, acidity, and TDS.",
            highlight: "Chemical Profiling"
          },
          {
            step: "02",
            title: "Custom Design",
            desc: "We configure components matching multi-brand membranes, sand media filters, softeners, and stabilizers for your target needs.",
            highlight: "Layout Optimization"
          },
          {
            step: "03",
            title: "Expert Setup",
            desc: "Certified squads install structural lines, mount valves, adjust booster flows, and run initial calibration testing.",
            highlight: "Precision Fitting"
          },
          {
            step: "04",
            title: "AMC Maintenance",
            desc: "We perform AMC flushes, sanitization routines, and keep automated audit records to secure long term water yield.",
            highlight: "Lifecycle Support"
          }
        ].map((item, idx) => (
          <div class="bg-white border border-slate-100 rounded-2xl p-8 shadow-sm hover:shadow-xl hover:border-[#07bee8]/40 transition-all duration-500 flex flex-col justify-between hover:-translate-y-1 group relative overflow-hidden">
            <!-- Accent gradient line on hover -->
            <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-[#024095] to-[#07bee8] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="space-y-4">
              <div class="flex items-center justify-between">
                <span class="text-4xl font-black font-mono text-[#024095]/15 group-hover:text-[#07bee8] transition-colors duration-500">{item.step}</span>
                <span class="text-[8px] font-mono font-bold text-[#07bee8] uppercase bg-[#07bee8]/10 px-2 py-0.5 rounded-full">{item.highlight}</span>
              </div>
              <h3 class="text-lg font-black uppercase tracking-tight text-[#024095] mt-2">{item.title}</h3>
              <p class="text-xs text-black font-semibold leading-relaxed">{item.desc}</p>
            </div>
            
            <div class="pt-6 mt-6 border-t border-slate-100 flex items-center justify-between text-[10px] font-bold text-[#024095] transition-colors">
              <span>STEP {item.step} INTACT</span>
              <span class="text-[#024095] group-hover:translate-x-1 transition-transform">&rarr;</span>
            </div>
          </div>
