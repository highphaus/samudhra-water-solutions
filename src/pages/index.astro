---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const clients = [
  "/images/client/1.jpg",
  "/images/client/2.jpg",
  "/images/client/3.jpg",
  "/images/client/4.jpg",
  "/images/client/5.jpg",
  "/images/client/6.jpg",
  "/images/client/7.jpg",
  "/images/client/8.jpg"
];

const projects = [
  {
    title: "Hospital Water Treatment System",
    location: "Thiruvananthapuram",
    before: "/images/products/DM plant.jpg",
    after: "/images/products/Uf Plant.jpg",
    desc: "Complete water treatment system for a multi-speciality hospital ensuring safe drinking water for patients."
  },
  {
    title: "Industrial RO Plant Installation",
    location: "Ernakulam",
    before: "/images/products/Desalination Water Filtration.jpg",
    after: "/images/products/100000 LPH RO plant.jpg",
    desc: "High capacity RO plant installation for an industrial facility with TDS reduction and consistent water quality."
  },
  {
    title: "STP Installation - 500 KLD",
    location: "Kollam",
    before: "/images/products/Sewage Treatment Plant.jpg",
    after: "/images/products/Effluent Treatment Plant.jpg",
    desc: "Sewage Treatment Plant installed with advanced technology for effective treatment and reuse of water."
  }
];

const treatments = [
  { name: "Iron Removal", before: "/images/new_home/iron_water_1781948634540.png", after: "https://images.unsplash.com/photo-1541336032412-2048a678540d?q=80&w=600&auto=format&fit=crop" },
  { name: "Hard Water Treatment", before: "/images/new_home/hard_water_1781948623171.png", after: "https://images.unsplash.com/photo-1523362628745-0c100150b504?q=80&w=600&auto=format&fit=crop" },
  { name: "Tank Cleaning", before: "/images/how do we work/Inspection and Assessment.jpg", after: "/images/how do we work/Commissioning.jpg" },
  { name: "Waste Water Treatment", before: "/images/new_home/waste_water_1781948670592.png", after: "https://images.unsplash.com/photo-1470509037663-253afd7f0f51?q=80&w=600&auto=format&fit=crop" }
];
---

<Layout title="Samudhra Water Solutions | Kerala's Trusted Partner">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <!-- Use a custom navbar style in index if needed, or stick to the global Navbar -->
  <Navbar theme="dark" />

  <!-- HERO SECTION -->
  <section class="relative min-h-[90vh] flex items-center justify-center pt-20">
    <div class="absolute inset-0 z-0">
      <img src="/images/hero/hero1.png" alt="Industrial Water Treatment" class="w-full h-full object-cover object-top lg:object-contain lg:scale-90 origin-center" />
      <!-- Subtle dark overlay to ensure the white text remains readable -->
      <div class="absolute inset-0 bg-black/40"></div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 w-full pb-32 sm:pb-36 lg:pb-24">
      <div class="max-w-3xl space-y-6">
        <h1 class="text-[clamp(1.4rem,7vw,2.5rem)] sm:text-5xl md:text-6xl lg:text-7xl font-bold text-white leading-[1.1] tracking-tight">
          Kerala's Trusted<br />Water Solutions Partner
        </h1>
        <p class="text-sm sm:text-xl text-white font-semibold max-w-xl" style="text-shadow: 0 2px 12px rgba(0,0,0,0.8), 0 1px 4px rgba(0,0,0,0.6);">
          From water testing to complete water treatment systems, we deliver safe, reliable & sustainable water solutions for every need.
        </p>
        <div class="flex flex-row gap-2 sm:gap-4 pt-4">
          <a href="/contact" class="inline-flex items-center justify-center px-3 py-2 sm:px-8 sm:py-3.5 bg-[#07bee8] text-[#024095] font-bold text-xs sm:text-base rounded-md hover:bg-white transition-colors gap-1 sm:gap-2">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            GET FREE WATER TESTING
          </a>
          <a href="tel:+919645830994" class="inline-flex items-center justify-center px-3 py-2 sm:px-8 sm:py-3.5 bg-transparent border-2 border-white text-white font-bold text-xs sm:text-base rounded-md hover:bg-white/10 transition-colors gap-1 sm:gap-2">
            <svg class="w-3.5 h-3.5 sm:w-5 sm:h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            TALK TO AN EXPERT
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAR (Flow, Overlapping Hero) -->
  <div class="relative z-30 -mt-16 sm:-mt-20 px-4 sm:px-6 max-w-7xl mx-auto w-full">
    <div class="bg-white rounded-xl shadow-xl p-3 md:p-8 grid grid-cols-5 gap-1 md:gap-6 divide-x divide-slate-100">
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#024095] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138z"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">17+</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">Years<br/>Experience</span>
        </div>
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#07bee8] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">1000+</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">Projects<br/>Delivered</span>
        </div>
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#024095] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">10000+</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">Customers<br/>Served</span>
        </div>
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#07bee8] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">ISO</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">9001:2015<br/>Certified</span>
        </div>
        <div class="flex flex-col items-center text-center py-1">
          <div class="text-[#024095] mb-1 md:mb-2"><svg class="w-4 h-4 sm:w-5 sm:h-5 md:w-8 md:h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"></path></svg></div>
          <span class="text-[10px] sm:text-sm md:text-2xl font-black text-[#024095] leading-tight">Govt. & Inst.</span>
          <span class="text-[6px] sm:text-[8px] md:text-xs text-slate-500 font-bold uppercase tracking-wide mt-0.5 leading-tight">Projects<br/>Experience</span>
        </div>
      </div>
    </div>
  </div>

  <!-- TRUSTED BY (Moved under Hero) -->
  <section class="pt-10 pb-10 bg-[#eff6ff] overflow-hidden relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-[clamp(0.55rem,2.5vw,0.75rem)] tracking-[0.15em] sm:tracking-[0.3em] font-black text-center text-[#024095] mb-6 uppercase">
        TRUSTED BY KERALA'S LEADING INSTITUTIONS
      </h2>

      <!-- MOBILE ONLY: 4 animated logo slots (visible on < md) -->
      <div class="flex md:hidden items-center justify-center gap-2">

        <!-- Slot 1: logo 1 → client image1 -->
        <div class="logo-slot overflow-hidden h-10 w-[70px] flex-shrink-0">
          <div class="logo-strip slot-1">
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/1.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90" />
            </div>
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/client%20image1.png" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90" />
            </div>
          </div>
        </div>

        <!-- Slot 2: logo 2 → client image2 -->
        <div class="logo-slot overflow-hidden h-10 w-[70px] flex-shrink-0">
          <div class="logo-strip slot-2">
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/2.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90" />
            </div>
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/client%20image2.png" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90" />
            </div>
          </div>
        </div>

        <!-- Slot 3: logo 3 → client image3 -->
        <div class="logo-slot overflow-hidden h-10 w-[70px] flex-shrink-0">
          <div class="logo-strip slot-3">
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/3.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90" />
            </div>
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/client%20image3.png" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90" />
            </div>
          </div>
        </div>

        <!-- Slot 4: logo 4 → client image4 -->
        <div class="logo-slot overflow-hidden h-10 w-[70px] flex-shrink-0">
          <div class="logo-strip slot-4">
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/4.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90" />
            </div>
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/client%20image4.webp" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90" />
            </div>
          </div>
        </div>

      </div>

      <!-- DESKTOP ONLY: 7 animated slots in one line (visible on md+) -->
      <div class="hidden md:flex items-center justify-center gap-8 lg:gap-12">

        <!-- D-Slot 1: logo 1 → client image1 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-1">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/1.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/client%20image1.png" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
          </div>
        </div>

        <!-- D-Slot 2: logo 2 → client image2 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-2">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/2.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/client%20image2.png" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
          </div>
        </div>

        <!-- D-Slot 3: logo 3 → client image3 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-3">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/3.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/client%20image3.png" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
          </div>
        </div>

        <!-- D-Slot 4: logo 4 → client image4 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-4">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/4.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/client%20image4.webp" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
          </div>
        </div>

        <!-- D-Slot 5: logo 5 → logo 1 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-5">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/5.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/1.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
          </div>
        </div>

        <!-- D-Slot 6: logo 6 → logo 2 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-6">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/6.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/2.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
          </div>
        </div>

        <!-- D-Slot 7: logo 7 → logo 3 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-7">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/7.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/3.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain opacity-90 hover:opacity-100 transition-opacity duration-300" />
            </div>
          </div>
        </div>

      </div>

      <div class="mt-10 text-center relative z-30">
        <a href="/testimonial" class="inline-flex items-center justify-center px-6 py-2.5 bg-transparent border-2 border-[#024095] text-[#024095] text-xs font-bold rounded hover:bg-[#024095] hover:text-white transition-colors gap-2 uppercase tracking-wide">
          View All &rarr;
        </a>
      </div>

    </div>
  </section>

  <style is:global>
    .logo-slot {
      position: relative;
    }
    .logo-strip {
      display: flex;
      flex-direction: column;
      will-change: transform;
    }
    .logo-item {
      width: 100%;
      flex-shrink: 0;
    }

    /* Mobile slots (4) */
    .slot-1 { animation: logoFlip 10s ease-in-out 0s infinite; }
    .slot-2 { animation: logoFlip 10s ease-in-out 2.5s infinite; }
    .slot-3 { animation: logoFlip 10s ease-in-out 5s infinite; }
    .slot-4 { animation: logoFlip 10s ease-in-out 7.5s infinite; }

    /* Desktop slots (7) — evenly spaced across 10s cycle */
    .slot-d-1 { animation: logoFlip 10s ease-in-out 0s infinite; }
    .slot-d-2 { animation: logoFlip 10s ease-in-out 1.43s infinite; }
    .slot-d-3 { animation: logoFlip 10s ease-in-out 2.86s infinite; }
    .slot-d-4 { animation: logoFlip 10s ease-in-out 4.29s infinite; }
    .slot-d-5 { animation: logoFlip 10s ease-in-out 5.71s infinite; }
    .slot-d-6 { animation: logoFlip 10s ease-in-out 7.14s infinite; }
    .slot-d-7 { animation: logoFlip 10s ease-in-out 8.57s infinite; }

    @keyframes logoFlip {
      0%   { transform: translateY(0); }
      35%  { transform: translateY(0); }
      50%  { transform: translateY(-50%); }
      85%  { transform: translateY(-50%); }
      100% { transform: translateY(0); }
    }
    @media (min-width: 1024px) {
      .carousel-clone {
        display: none !important;
      }
    }
    .no-snap {
      scroll-snap-type: none !important;
      scroll-behavior: auto !important;
    }
  </style>



  <!-- EVERY WATER PROBLEM HAS A SOLUTION -->
  <section class="pt-20 md:pt-40 pb-10 md:pb-20 bg-slate-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 md:mb-20 animate-fadeIn">
        <span class="text-[10px] sm:text-xs md:text-sm font-extrabold tracking-widest text-[#07bee8] uppercase block mb-1">Water Quality Check</span>
        <h2 class="text-[clamp(1.1rem,4.5vw,1.75rem)] sm:text-2xl md:text-3xl font-black text-[#024095] uppercase relative inline-block pb-3">
          EVERY <span class="text-[#07bee8]">WATER PROBLEM</span> HAS A SOLUTION
          <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-16 h-[3px] bg-gradient-to-r from-[#07bee8] to-[#024095] rounded-full"></span>
        </h2>
      </div>

      <!-- Carousel wrapper -->
      <div class="relative animate-fadeIn">
        <!-- Scroll container -->
        <div id="water-carousel" class="flex lg:grid lg:grid-cols-4 gap-6 overflow-x-auto lg:overflow-x-visible pb-4 lg:pb-0 max-lg:snap-x max-lg:snap-mandatory max-lg:scroll-smooth cursor-default md:cursor-grab lg:cursor-default select-none" style="scrollbar-width:none; -ms-overflow-style:none;">

          <!-- Card 1: Hard Water -->
          <div class="relative snap-start flex-shrink-0 w-[70vw] max-w-[280px] sm:w-72 lg:w-full lg:max-w-none bg-gradient-to-br from-white to-slate-50/50 rounded-2xl shadow-md hover:shadow-xl border border-slate-100 hover:border-slate-200/60 transform hover:-translate-y-2 transition-all duration-300 group overflow-hidden flex flex-col">
            <div class="h-[130px] sm:h-40 md:h-44 overflow-hidden relative">
              <img src="/images/new_home/hard_water_1781948623171.png" alt="Hard Water" class="w-full h-full object-cover transform group-hover:scale-108 transition-transform duration-700 ease-out" />
              <div class="absolute inset-0 bg-gradient-to-t from-[#024095]/40 via-transparent to-transparent opacity-85 group-hover:opacity-60 transition-opacity duration-300"></div>
              <div class="absolute inset-0 bg-[#024095]/10 mix-blend-overlay"></div>
            </div>
            <div class="p-5 pt-0 pb-6 text-center flex flex-col items-center flex-1 relative">
