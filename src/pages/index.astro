  <script>
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
      const button = item.querySelector('button');
      const content = item.querySelector('.faq-content');
      const icon = item.querySelector('.faq-icon svg');

      if (button && content && icon) {
        button.addEventListener('click', () => {
          const isOpen = button.getAttribute('aria-expanded') === 'true';

          // Close all other open items
          faqItems.forEach(otherItem => {
            if (otherItem !== item) {
              const otherButton = otherItem.querySelector('button');
              const otherContent = otherItem.querySelector('.faq-content');
              const otherIcon = otherItem.querySelector('.faq-icon svg');
              if (otherButton && otherContent && otherIcon) {
                otherButton.setAttribute('aria-expanded', 'false');
                otherContent.style.maxHeight = null;
                otherIcon.style.transform = null;
                otherItem.classList.remove('bg-white', 'border-[#024095]/20', 'shadow-lg');
                otherItem.classList.add('bg-slate-50/50', 'border-slate-100');
              }
            }
          });

          // Toggle current item
          if (isOpen) {
            button.setAttribute('aria-expanded', 'false');
            content.style.maxHeight = null;
            icon.style.transform = null;
            item.classList.remove('bg-white', 'border-[#024095]/20', 'shadow-lg');
            item.classList.add('bg-slate-50/50', 'border-slate-100');
          } else {
            button.setAttribute('aria-expanded', 'true');
            content.style.maxHeight = content.scrollHeight + 'px';
            icon.style.transform = 'rotate(45deg)';
            item.classList.add('bg-white', 'border-[#024095]/20', 'shadow-lg');
            item.classList.remove('bg-slate-50/50', 'border-slate-100');
          }
        });
      }
    });
  </script>

