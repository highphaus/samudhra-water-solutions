---
// src/pages/service.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const services = [
  {
    num: "01",
    title: "UF Plant Installation & Maintenance",
    description: "A UF plant is an effective water treatment solution for removing suspended solids, bacteria, and other particles from water. It is widely used in municipal, industrial, and wastewater treatment applications, as well as in pre-treatment for RO systems. Its low energy consumption and ability to produce consistent water quality make it a popular choice in many industries, but it requires proper maintenance to prevent fouling and ensure long-term efficiency. Used as a standalone treatment or as a pre-treatment for processes like reverse osmosis (RO) or other filtration methods.",
    scope: "<p><strong>Municipal Water Treatment:</strong> Used in large-scale municipal facilities to provide safe, clear drinking water by removing pathogens and suspended solids.</p><p><strong>Industrial Wastewater:</strong> Essential for processing and recycling industrial effluent, ensuring compliance with environmental discharge standards.</p><p><strong>Pre-treatment for RO Systems:</strong> Acts as a highly effective barrier to protect sensitive Reverse Osmosis membranes from fouling, extending their lifespan.</p><p><strong>Food and Beverage Industry:</strong> Utilized for liquid separation and purification to meet strict health and safety standards without using heat or chemicals.</p>",
    image: "/images/products/Uf Plant.jpg"
  },
  {
    num: "02",
    title: "Swimming Pool Filtration Plant",
    description: "<p>The filtration plant typically consists of several components, including pumps, filters, chemical dosing systems, and sanitizers, all of which work together to circulate, filter, and disinfect pool water.</p><p>A swimming pool filtration plant is essential for maintaining clean, safe, and hygienic water in residential, commercial, and public swimming pools. It consists of pumps, filters, chemical dosing systems, and sanitizers that work together to circulate, filter, and disinfect the pool water. With proper maintenance and monitoring, a filtration plant ensures a healthy swimming environment while reducing the need for frequent manual cleaning and chemical adjustments.</p>",
    scope: "<p><strong>Residential Pools:</strong> Pool filtration plants are used in residential homes to ensure clean, safe, and aesthetically pleasing pool water for family and guest use.</p><p><strong>Commercial Pools:</strong> High-traffic pools in hotels, resorts, and clubs require powerful filtration systems to handle the larger volume of swimmers and maintain water quality.</p><p><strong>Public Pools:</strong> Public pools, community centers, and water parks use large-scale filtration plants to keep the water hygienic for many users.</p><p><strong>Health and Fitness Facilities:</strong> Fitness centers, spas, and wellness clubs use filtration systems to maintain clean water in pools and hot tubs.</p><p><strong>Competition and Olympic Pools:</strong> Competitive swimming pools require advanced filtration systems to maintain optimal water clarity and hygiene for athletes.</p>",
    image: "/images/products/Swimming Pool Filtration Plant.jpeg"
  },
  {
    num: "03",
    title: "Sewage Treatment Plant (STP)",
    description: "<p>A Sewage Treatment Plant (STP) is a vital facility for treating wastewater, protecting public health, and safeguarding the environment. By removing contaminants and pathogens from sewage, STPs ensure that treated water is safe for discharge or reuse. Various treatment methods, including physical, biological, and chemical processes, are employed in STPs to achieve the desired water quality.</p><p>While there are challenges in managing STPs, their benefits in terms of public health and environmental protection make them essential components of modern wastewater management systems.</p>",
    scope: "<p><strong>Urban Wastewater Management:</strong> STPs are essential in urban areas to treat domestic sewage from households, commercial establishments, and industries before discharge.</p><p><strong>Industrial Wastewater Treatment:</strong> Industries generate wastewater containing various pollutants. STPs can be designed to handle specific industrial effluents, ensuring compliance with environmental regulations and safe disposal.</p>",
    image: "/images/products/Sewage Treatment Plant.jpg"
  },
  {
    num: "04",
    title: "Effluent Treatment Plants (ETPs)",
    description: "<p>Effluents refer to liquid waste discharged from industrial or commercial activities, and they often contain harmful pollutants such as heavy metals, chemicals, oils, organic matter, and other toxic substances that can harm water bodies and ecosystems if not properly treated.</p><p>ETPs play a critical role in industrial pollution management and are vital for sustainable environmental practices.</p>",
    scope: "<p>Effluent Treatment Plants (ETPs) are essential for industries and municipalities to manage wastewater in a sustainable and eco-friendly manner. Their application is widespread across various sectors, aiming to treat and safely discharge wastewater or reuse it in different processes.</p>",
    image: "/images/products/Effluent Treatment Plant.jpg"
  },
  {
    num: "05",
    title: "De-Mineralizing (DM) Plants",
    description: "<p>De-Mineralizing (DM) plants are specialized water treatment systems designed to remove dissolved minerals, salts, and ions from water to produce highly purified or demineralized water. These plants are commonly used in industries that require high-quality water, such as pharmaceuticals, power generation, electronics manufacturing, and laboratories.</p><p>De-Mineralizing plants are vital for producing ultra-pure water in industries where even trace levels of dissolved minerals can compromise product quality, process efficiency, or equipment longevity.</p>",
    scope: "<p>A Demineralization (DM) Plant has various applications across multiple industries that require high-purity water free from dissolved minerals and salts. These applications are essential for preventing scaling, corrosion, contamination, and ensuring the proper functioning of industrial equipment and processes.</p>",
    image: "/images/products/DM plant.jpg"
  },
  {
    num: "06",
    title: "Desalination Water Filtration Plants",
    description: "<p>Desalination water filtration provides a critical solution to water scarcity, particularly in regions with limited access to freshwater. By removing salts and impurities from seawater or brackish water, desalination plants offer a reliable source of drinking water and industrial supply. However, the process is energy-intensive and has environmental challenges, particularly related to brine disposal and marine impact. Advances in energy efficiency and renewable energy integration are helping make desalination more sustainable and cost-effective.</p><p>It is particularly essential in arid regions or coastal areas with limited freshwater resources. The desalination process is primarily driven by two methods: thermal desalination and membrane-based desalination (reverse osmosis).</p>",
    scope: "<p>Desalination water filtration plants provide a reliable source of freshwater by converting seawater or brackish water into potable water, which is used for various purposes across different sectors.</p>",
    image: "/images/products/Desalination Water Filtration.jpg"
  },
  {
    num: "07",
    title: "100,000 LPH RO Plant",
    description: "<p>A 100,000 LPH RO plant is a high-capacity reverse osmosis system designed for large-scale water treatment applications. It is capable of producing high-purity water for municipal, industrial, agricultural, and commercial uses.</p><p>While the plant offers a reliable solution for water-scarce regions, it requires careful management of operational costs, energy use, and brine disposal to ensure sustainable and efficient performance.</p>",
    scope: "<p>This type of RO plant is typically used in industrial, municipal, and large-scale commercial applications.</p>",
    image: "/images/products/100000 LPH RO plant.jpg"
  },
  {
    num: "08",
    title: "250 LPH RO Plant",
    description: "<p>A 250 LPH RO plant is a versatile water purification solution designed for small to medium-scale commercial, industrial, and institutional applications. It provides high-quality water for drinking, industrial processes, and other uses by removing contaminants, salts, and impurities.</p><p>Its compact design, cost-effectiveness, and efficiency make it a popular choice for applications requiring moderate volumes of clean water daily. However, it requires proper maintenance, including membrane cleaning and careful management of wastewater.</p>",
    scope: "<p>This plant is commonly used for commercial, small industrial, and institutional purposes where a moderate amount of clean water is required daily.</p>",
    image: "/images/products/100LPH-10000LPH RO Plant.jpg"
  },
  {
    num: "09",
    title: "MultiBrand Water Purifier Servicing",
    description: "<p>MultiBrand water purifier servicing refers to maintenance, repair, and service offerings for water purifiers of various brands by a single service provider. This type of service is particularly useful for users who have water purifiers from different brands or those seeking a convenient, one-stop solution for maintenance and repairs without relying on individual brand service centers.</p><p>Routine cleaning of essential components like filters, RO membranes, UV lamps, and water storage tanks. Checking for water leakage, ensuring all fittings and pipes are securely in place. Inspection and calibration of pressure pumps and other mechanical components to maintain optimal performance.</p>",
    scope: "<p>This type of service helps extend the life of your water purifier, ensuring it provides clean, safe drinking water reliably across various brand models.</p>",
    image: "/images/products/Multibrand Water Purifiers.jpg"
  },
  {
    num: "10",
    title: "Water Tank Cleaning",
    description: "<p>A clean water tank ensures efficient water flow throughout the plumbing system and prevents clogging of filters and other components. This can improve water pressure and overall water system performance.</p><p>In summary, regular water tank cleaning is a proactive measure that ensures safe, clean, and healthy water for your household, while also protecting your water storage system from damage and extending its lifespan.</p>",
    scope: "<p><strong>Residential Households:</strong> Regular tank cleaning ensures families have access to safe, hygienic drinking and utility water free from sediment and bacterial buildup.</p><p><strong>Commercial & Industrial Facilities:</strong> Offices, factories, and institutions rely on clean storage tanks to maintain water quality standards and avoid operational disruptions.</p><p><strong>Hospitals & Healthcare:</strong> Clean water tanks are critical in healthcare settings to prevent waterborne diseases and maintain strict hygiene protocols.</p><p><strong>Hotels & Hospitality:</strong> Ensuring spotless water storage tanks preserves guest safety and upholds the establishment's reputation for quality and cleanliness.</p>",
    image: "/images/products/Stainless steel water tanks.jpg"
  }
];
---

<Layout title="Our Purification Services | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <section class="bg-[#F9F9FB] text-slate-900 pt-36 pb-16 border-b border-slate-200/60">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <span class="h-[1px] w-12 bg-[#024095]"></span>
        <span class="text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">OPERATIONS / LIFE CYCLE MATRIX</span>
      </div>
      <h1 class="text-4xl sm:text-6xl font-black tracking-tighter text-[#024095] leading-none uppercase">Our Purification Services.</h1>
      <p class="text-sm text-slate-500 font-light max-w-xl mt-4 leading-relaxed">We provide absolute engineering lifecycle support for commercial and domestic water systems, ensuring uniform parameter execution across Kerala.</p>
    </div>
  </section>

  <section class="bg-white text-slate-900 py-12">
    <div class="max-w-5xl mx-auto px-6">
      {services.map((item) => (
        <div class="group border border-slate-200/60 rounded-xl overflow-hidden bg-white hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row mb-8">
          {item.image && (
            <div class="md:w-2/5 overflow-hidden bg-[#F9F9FB] flex items-center justify-center border-b md:border-b-0 md:border-r border-slate-200/60 p-6">
              <img src={item.image} alt={item.title} class="w-full h-full object-contain rounded shadow-sm group-hover:scale-[1.02] transition-transform duration-500" />
            </div>
          )}
          <div class={`p-8 md:p-12 flex flex-col justify-center ${item.image ? 'md:w-3/5' : 'w-full'}`}>
            <div class="flex justify-between items-start mb-6">
               <span class="text-[10px] font-mono font-bold text-[#07bee8] uppercase tracking-widest bg-[#07bee8]/10 px-3 py-1 rounded-full">Service {item.num}</span>
               <a href={`https://wa.me/919447XXXXXX?text=Hi, I would like to book a consultation for ${item.title}.`} target="_blank" class="hidden md:inline-block px-5 py-2.5 bg-[#024095] text-white text-[9px] font-black uppercase tracking-[0.2em] hover:bg-[#07bee8] transition-all rounded shadow-md">Book Now</a>
            </div>
            <h3 class="text-3xl font-black tracking-tighter text-[#024095] uppercase mb-4">{item.title}</h3>
            <div class="text-sm text-slate-500 font-light leading-relaxed mb-6 space-y-3" set:html={item.description}></div>
            <div class="mt-auto border-t border-slate-100 pt-6">
               <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-3">Target Scope & Applications</p>
               <div class="text-xs font-medium text-slate-700 space-y-2" set:html={item.scope}></div>
            </div>
            <a href={`https://wa.me/919447XXXXXX?text=Hi, I would like to book a consultation for ${item.title}.`} target="_blank" class="md:hidden mt-6 text-center w-full px-5 py-3 bg-[#024095] text-white text-[9px] font-black uppercase tracking-[0.2em] hover:bg-[#07bee8] transition-all rounded shadow-md">Book Now</a>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>