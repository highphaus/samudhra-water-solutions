---
// src/pages/service.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    num: "01",
    title: "UF Plant Installation & Maintenance",
    description: "<p>A UF plant is an effective water treatment solution for removing suspended solids, bacteria, and other particles from water. It is widely used in municipal, industrial, and wastewater treatment applications, as well as in pre-treatment for RO systems. Its low energy consumption and ability to produce consistent water quality make it a popular choice in many industries, but it requires proper maintenance to prevent fouling and ensure long-term efficiency.</p>",
    scope: "<p><strong>Municipal Water Treatment:</strong> Used in large-scale municipal facilities to provide safe, clear drinking water by removing pathogens and suspended solids.</p><p><strong>Industrial Wastewater:</strong> Essential for processing and recycling industrial effluent, ensuring compliance with environmental discharge standards.</p><p><strong>Pre-treatment for RO Systems:</strong> Acts as a highly effective barrier to protect sensitive Reverse Osmosis membranes from fouling.</p><p><strong>Food and Beverage Industry:</strong> Utilized for liquid separation and purification to meet strict health and safety standards.</p>",
    image: "/images/products/Uf Plant.jpg"
  },
  {
    num: "02",
    title: "Swimming Pool Filtration Plant",
    description: "<p>A swimming pool filtration plant is essential for maintaining clean, safe, and hygienic water in residential, commercial, and public swimming pools. It consists of pumps, filters, chemical dosing systems, and sanitizers that work together to circulate, filter, and disinfect the pool water.</p>",
    scope: "<p><strong>Residential Pools:</strong> Pool filtration plants are used in residential homes to ensure clean, safe, and aesthetically pleasing pool water.</p><p><strong>Commercial Pools:</strong> High-traffic pools in hotels, resorts, and clubs require powerful filtration systems to handle the larger volume of swimmers.</p><p><strong>Public Pools:</strong> Public pools, community centers, and water parks use large-scale filtration plants.</p><p><strong>Health and Fitness Facilities:</strong> Fitness centers, spas, and wellness clubs use filtration systems for pools and hot tubs.</p>",
    image: "/images/products/Swimming Pool Filtration Plant.jpeg"
  },
  {
    num: "03",
    title: "Sewage Treatment Plant (STP)",
    description: "<p>A Sewage Treatment Plant (STP) is a vital facility for treating wastewater, protecting public health, and safeguarding the environment. By removing contaminants and pathogens from sewage, STPs ensure that treated water is safe for discharge or reuse.</p>",
    scope: "<p><strong>Urban Wastewater Management:</strong> STPs are essential in urban areas to treat domestic sewage from households and commercial establishments before discharge.</p><p><strong>Industrial Wastewater Treatment:</strong> Industries generate wastewater containing various pollutants. STPs can be designed to handle specific industrial effluents, ensuring compliance with environmental regulations.</p>",
    image: "/images/products/Sewage Treatment Plant.jpg"
  },
  {
    num: "04",
    title: "Effluent Treatment Plants (ETPs)",
    description: "<p>Effluents refer to liquid waste discharged from industrial or commercial activities, and they often contain harmful pollutants such as heavy metals, chemicals, oils, organic matter, and other toxic substances that can harm water bodies and ecosystems if not properly treated.</p><p>ETPs play a critical role in industrial pollution management and are vital for sustainable environmental practices.</p>",
    scope: "<p>Effluent Treatment Plants (ETPs) are essential for industries and municipalities to manage wastewater in a sustainable and eco-friendly manner. Their application is widespread across various sectors, aiming to treat and safely discharge wastewater or reuse it in different processes.</p>",
    image: "/images/products/Effluent Treatment Plant.jpg"
  },
  {
    num: "05",
    title: "De-Mineralizing (DM) Plants",
    description: "<p>De-Mineralizing (DM) plants are specialized water treatment systems designed to remove dissolved minerals, salts, and ions from water to produce highly purified or demineralized water. These plants are commonly used in industries that require high-quality water, such as pharmaceuticals, power generation, electronics manufacturing, and laboratories.</p>",
    scope: "<p>A Demineralization (DM) Plant has various applications across multiple industries that require high-purity water free from dissolved minerals and salts. These applications are essential for preventing scaling, corrosion, contamination, and ensuring the proper functioning of industrial equipment.</p>",
    image: "/images/products/DM plant.jpg"
  },
  {
    num: "06",
    title: "Desalination Water Filtration Plants",
    description: "<p>Desalination water filtration provides a critical solution to water scarcity, particularly in regions with limited access to freshwater. By removing salts and impurities from seawater or brackish water, desalination plants offer a reliable source of drinking water and industrial supply.</p>",
    scope: "<p>Desalination water filtration plants provide a reliable source of freshwater by converting seawater or brackish water into potable water, which is used for various purposes across different sectors.</p>",
    image: "/images/products/Desalination Water Filtration.jpg"
  },
  {
    num: "07",
    title: "100,000 LPH RO Plant",
    description: "<p>A 100,000 LPH RO plant is a high-capacity reverse osmosis system designed for large-scale water treatment applications. It is capable of producing high-purity water for municipal, industrial, agricultural, and commercial uses.</p>",
    scope: "<p>This type of RO plant is typically used in industrial, municipal, and large-scale commercial applications.</p>",
    image: "/images/products/100000 LPH RO plant.jpg"
  },
  {
    num: "08",
    title: "250 LPH RO Plant",
    description: "<p>A 250 LPH RO plant is a versatile water purification solution designed for small to medium-scale commercial, industrial, and institutional applications. It provides high-quality water for drinking, industrial processes, and other uses by removing contaminants, salts, and impurities.</p>",
    scope: "<p>This plant is commonly used for commercial, small industrial, and institutional purposes where a moderate amount of clean water is required daily.</p>",
    image: "/images/products/100LPH-10000LPH RO Plant.jpg"
  },
  {
    num: "09",
    title: "MultiBrand Water Purifier Servicing",
    description: "<p>MultiBrand water purifier servicing refers to maintenance, repair, and service offerings for water purifiers of various brands by a single service provider. This type of service is particularly useful for users who have water purifiers from different brands or those seeking a convenient, one-stop solution for maintenance and repairs.</p>",
    scope: "<p>This type of service helps extend the life of your water purifier, ensuring it provides clean, safe drinking water reliably across various brand models.</p>",
    image: "/images/products/Multibrand Water Purifiers.jpg"
  },
  {
    num: "10",
    title: "Water Tank Cleaning",
    description: "<p>A clean water tank ensures efficient water flow throughout the plumbing system and prevents clogging of filters and other components. Regular water tank cleaning is a proactive measure that ensures safe, clean, and healthy water for your household, while also protecting your water storage system from damage.</p>",
    scope: "<p><strong>Residential Households:</strong> Regular tank cleaning ensures families have access to safe, hygienic drinking and utility water.</p><p><strong>Commercial & Industrial Facilities:</strong> Offices, factories, and institutions rely on clean storage tanks to maintain water quality standards.</p><p><strong>Hospitals & Healthcare:</strong> Clean water tanks are critical in healthcare settings to prevent waterborne diseases.</p><p><strong>Hotels & Hospitality:</strong> Ensuring spotless water storage tanks preserves guest safety and establishment reputation.</p>",
    image: "/images/products/Stainless steel water tanks.jpg"
  }
];
---

<Layout title="Our Purification Services | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="bg-[#FAF9F6] text-slate-900 pt-28 sm:pt-36 pb-12 sm:pb-16 border-b border-slate-200/60">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-5 sm:mb-6">
        <span class="h-[1px] w-10 sm:w-12 bg-[#024095]"></span>
        <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">OPERATIONS / LIFE CYCLE MATRIX</span>
      </div>
      <h1 class="text-[clamp(1.25rem,6vw,3rem)] max-sm:whitespace-nowrap sm:text-5xl lg:text-6xl font-black tracking-tighter text-[#024095] leading-none uppercase">Our Purification Services.</h1>
      <p class="text-sm text-black font-light max-w-xl mt-4 leading-relaxed">We provide absolute engineering lifecycle support for commercial and domestic water systems, ensuring uniform parameter execution across Kerala.</p>
    </div>
  </section>

  <!-- SERVICES LIST -->
  <section class="bg-[#FAF9F6] text-slate-900 py-10 sm:py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      {services.map((item) => (
        <div class="group border border-slate-200/60 rounded-xl overflow-hidden bg-white hover:shadow-xl transition-all duration-300 flex flex-col md:flex-row mb-6 sm:mb-8">
          {item.image && (
            <div class="md:w-2/5 overflow-hidden bg-[#F9F9FB] flex items-center justify-center border-b md:border-b-0 md:border-r border-slate-200/60 p-4 sm:p-6" style="min-height:200px">
              <img src={item.image} alt={item.title} loading="lazy"
                   class="w-full h-auto object-contain rounded shadow-sm group-hover:scale-[1.02] transition-transform duration-500"
                   style="max-height:260px" />
            </div>
          )}
          <div class={`p-6 sm:p-8 md:p-10 flex flex-col justify-center ${item.image ? 'md:w-3/5' : 'w-full'}`}>
            <div class="flex flex-wrap justify-between items-start gap-3 mb-5 sm:mb-6">
              <span class="text-[10px] font-mono font-bold text-[#07bee8] uppercase tracking-widest bg-[#07bee8]/10 px-3 py-1 rounded-full">Service {item.num}</span>
              <a href={`https://wa.me/919645830994?text=Hi, I would like to book a consultation for ${item.title}.`}
                 target="_blank"
                 class="min-h-[44px] px-4 sm:px-5 py-2 bg-[#024095] text-white text-[9px] font-black uppercase tracking-[0.2em] hover:bg-[#07bee8] transition-all rounded shadow-md flex items-center">
                Book Now
              </a>
            </div>
            <h3 class="text-xl sm:text-2xl lg:text-3xl font-black tracking-tighter text-[#024095] uppercase mb-4 leading-tight">{item.title}</h3>
            <div class="text-sm text-black font-light leading-relaxed mb-5 sm:mb-6 space-y-3" set:html={item.description}></div>
            <div class="mt-auto border-t border-slate-100 pt-5 sm:pt-6">
              <p class="text-[9px] font-bold text-black uppercase tracking-widest mb-3">Target Scope &amp; Applications</p>
              <div class="text-xs font-medium text-black space-y-2" set:html={item.scope}></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
  <Footer />
</Layout>