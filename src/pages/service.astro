---
// src/pages/service.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { services } from '../utils/services-data.js';
---

<Layout title="Our Purification Services | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="bg-gradient-to-b from-[#e0f7fc] to-[#FAF9F6] text-slate-900 pt-28 sm:pt-36 pb-12 sm:pb-20 border-b border-slate-200/60 relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#07bee8]/10 rounded-full blur-3xl -mr-20 -mt-20"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-[#024095]/5 rounded-full blur-3xl -ml-20 -mb-20"></div>
    
    <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="flex items-center gap-3 mb-4 sm:mb-6">
        <span class="h-[2px] w-12 bg-gradient-to-r from-[#024095] to-[#07bee8]"></span>
        <span class="text-[10px] sm:text-xs font-black uppercase tracking-[0.35em] text-[#07bee8]">Industrial & Domestic Engineering</span>
      </div>
      <h1 class="text-[clamp(2.25rem,6vw,4rem)] font-black tracking-tight text-[#024095] leading-none uppercase mb-6">
        Professional Water<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-[#024095] to-[#07bee8]">Treatment Solutions</span>
      </h1>
      <p class="text-base sm:text-lg text-slate-700 font-normal max-w-2xl leading-relaxed">
        We provide complete engineering lifecycle support for industrial and domestic water systems, ensuring uniform parameter execution and absolute safety across Kerala since 2009.
      </p>
    </div>
  </section>

  <!-- FILTER TABS -->
  <section class="bg-[#FAF9F6] py-6 sticky top-[80px] z-30 border-b border-slate-200/40 backdrop-blur-md bg-[#FAF9F6]/90 transition-all duration-300">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="flex flex-nowrap items-center justify-start md:justify-center gap-2 overflow-x-auto whitespace-nowrap pb-2 md:pb-0 scrollbar-none">
        <button data-filter="all" class="filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 shadow-sm bg-[#024095] text-white">
          All Systems
        </button>
        <button data-filter="residential" class="filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 text-slate-600 hover:text-[#024095] hover:bg-slate-100 bg-white border border-slate-200">
          Residential
        </button>
        <button data-filter="commercial" class="filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 text-slate-600 hover:text-[#024095] hover:bg-slate-100 bg-white border border-slate-200">
          Commercial
        </button>
        <button data-filter="industrial" class="filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 text-slate-600 hover:text-[#024095] hover:bg-slate-100 bg-white border border-slate-200">
          Industrial
        </button>
        <button data-filter="hard-water" class="filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 text-slate-600 hover:text-[#024095] hover:bg-slate-100 bg-white border border-slate-200">
          Hard Water
        </button>
        <button data-filter="iron-water" class="filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 text-slate-600 hover:text-[#024095] hover:bg-slate-100 bg-white border border-slate-200">
          Iron Water
        </button>
        <button data-filter="salty-water" class="filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 text-slate-600 hover:text-[#024095] hover:bg-slate-100 bg-white border border-slate-200">
          Salty Water
        </button>
        <button data-filter="waste-water" class="filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 text-slate-600 hover:text-[#024095] hover:bg-slate-100 bg-white border border-slate-200">
          Wastewater
        </button>
      </div>
    </div>
  </section>

  <!-- SERVICES LIST -->
  <section class="bg-[#FAF9F6] py-12 sm:py-16 min-h-[60vh]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((item) => (
          <div class="service-card flex flex-col bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 border border-slate-100 opacity-0 translate-y-6 animate-fade-in-up"
               id={item.slug}
               data-categories={item.categories.join(',')}>
            
            <!-- Image & Badge Container -->
            <div class="relative aspect-video overflow-hidden bg-slate-50 border-b border-slate-100">
              <img src={item.image} alt={item.title} loading="lazy"
                   class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" />
              <span class="absolute top-4 left-4 bg-[#024095] text-white text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-full shadow-sm">
                SYSTEM {item.num}
              </span>
            </div>

            <!-- Content Area -->
            <div class="p-6 flex flex-col flex-grow">
              <h3 class="text-xl font-bold tracking-tight text-[#024095] mb-2 leading-tight min-h-[56px] flex items-center">
                {item.title}
              </h3>
              
              <p class="text-sm text-slate-600 font-light leading-relaxed mb-5 line-clamp-3">
                {item.shortDescription}
              </p>

              <!-- Ideal For Section -->
              <div class="mb-5">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-2">Ideal For</span>
                <div class="flex flex-wrap gap-1.5">
                  {item.idealFor.map((ideal) => (
                    <span class="text-[10px] font-semibold text-slate-600 bg-slate-100 border border-slate-200/50 px-2 py-0.5 rounded-md">
                      {ideal}
                    </span>
                  ))}
                </div>
              </div>

              <!-- Key Benefits Checklist -->
              <div class="border-t border-slate-100 pt-4 mb-6">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider block mb-3">Key Advantages</span>
                <ul class="space-y-2">
                  {item.benefits.slice(0, 5).map((benefit) => (
                    <li class="flex items-start gap-2.5 text-xs text-slate-700 font-medium">
                      <svg class="w-4 h-4 text-[#07bee8] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                      <span>{benefit}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <!-- CTA Actions Group -->
              <div class="mt-auto flex flex-col sm:flex-row gap-2.5">
                <a href={`/services/${item.slug}`} 
                   class="flex-1 inline-flex items-center justify-center min-h-[44px] bg-slate-100 hover:bg-slate-200 text-slate-800 font-extrabold text-[10px] uppercase tracking-widest rounded-lg transition-colors">
                  Learn More
                </a>
                <a href={`https://wa.me/919645830994?text=Hi,%20I%20would%20like%20to%20book%20a%20free%20consultation%20for%20${encodeURIComponent(item.title)}.`}
                   target="_blank"
                   rel="noopener noreferrer"
                   class="flex-1 inline-flex items-center justify-center min-h-[44px] bg-[#024095] hover:bg-[#07bee8] text-white font-extrabold text-[10px] uppercase tracking-widest rounded-lg transition-all shadow-sm hover:shadow active:scale-[0.98]">
                  Consultation
                </a>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Interactive Scroll-to-Reveal Animation & Filter script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const btns = document.querySelectorAll('.filter-tab-btn');
      const cards = document.querySelectorAll('.service-card');

      // Scroll reveal trigger
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('opacity-0', 'translate-y-6');
            entry.target.classList.add('opacity-100', 'translate-y-0');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.05 });

      cards.forEach(card => observer.observe(card));

      function filterServices(filterValue) {
        // Toggle buttons active classes
        btns.forEach(btn => {
          if (btn.getAttribute('data-filter') === filterValue) {
            btn.className = 'filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 shadow-sm bg-[#024095] text-white';
          } else {
            btn.className = 'filter-tab-btn px-5 py-2.5 text-xs font-extrabold uppercase tracking-wider rounded-xl transition-all duration-300 text-slate-600 hover:text-[#024095] hover:bg-slate-100 bg-white border border-slate-200';
          }
        });

        // Filter cards
        cards.forEach(card => {
          const cardCats = card.getAttribute('data-categories').split(',');
          if (filterValue === 'all' || cardCats.includes(filterValue)) {
            card.style.display = 'flex';
            setTimeout(() => {
              card.style.opacity = '1';
              card.style.transform = 'translateY(0)';
            }, 10);
          } else {
            card.style.opacity = '0';
            card.style.transform = 'translateY(12px)';
            setTimeout(() => {
              if (card.style.opacity === '0') {
                card.style.display = 'none';
              }
            }, 300);
          }
        });
      }

      // Add click handler to buttons
      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filterValue = btn.getAttribute('data-filter');
          // Update URL parameter without reloading page
          const url = new URL(window.location.href);
          if (filterValue === 'all') {
            url.searchParams.delete('filter');
          } else {
            url.searchParams.set('filter', filterValue);
          }
          window.history.pushState({}, '', url);
          filterServices(filterValue);
        });
      });

      // Handle popstate
      window.addEventListener('popstate', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const currentFilter = urlParams.get('filter') || 'all';
        filterServices(currentFilter);
      });

      // Apply initial filter
      const urlParams = new URLSearchParams(window.location.search);
      const initialFilter = urlParams.get('filter') || 'all';
      filterServices(initialFilter);
    });
  </script>

  <Footer />
</Layout>