---
// src/pages/testimonial.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Initials are derived from client names — no fake photos
const reviews = [
  {
    client: "Dr. K. Raghavan",
    entity: "Private Clinical Center, TVM",
    statement: "Samudhra precision-engineered our full 50,000 LPH reverse osmosis layout with absolute corporate standard clean lines. Their custom media filter parameters handled our hard water iron properties flawlessly. Purity remains total.",
    rating: "★★★★★",
    initials: "KR",
    color: "#024095"
  },
  {
    client: "Meera Nair",
    entity: "Residential Villa, Kowdiar",
    statement: "We completely bypassed generic retail options and had Samudhra customize an automated brine softener and multi-brand copper infusion system for our whole house. The white scale buildup inside our piping networks was instantly eliminated.",
    rating: "★★★★★",
    initials: "MN",
    color: "#07bee8"
  },
  {
    client: "Thomas Kurian",
    entity: "Commercial Complex, Thampanoor",
    statement: "Managing high-volume commercial properties requires absolute direct service accountability. Samudhra's maintenance contract team performs rigorous membrane audits and parameter inspections like clockwork.",
    rating: "★★★★★",
    initials: "TK",
    color: "#024095"
  },
  {
    client: "Anil Kumar",
    entity: "Factory Director, Kazhakkoottam",
    statement: "Excellent service and prompt response. The team installed a commercial RO plant in our factory near Kazhakkoottam. Very professional and highly recommended for industrial water purification needs.",
    rating: "★★★★★",
    initials: "AK",
    color: "#0ea5e9"
  },
  {
    client: "Remya Krishnan",
    entity: "Home Owner, Kowdiar",
    statement: "I bought a domestic water purifier (Aqua C3) from Samudhra. Excellent follow up, and water tank cleaning service was done very neatly. Excellent behaviour from Rajesh and staff.",
    rating: "★★★★★",
    initials: "RK",
    color: "#07bee8"
  },
  {
    client: "George Mathew",
    entity: "Resident, Pattom",
    statement: "We had severe iron content in our well water. They analyzed the water test report and designed a custom iron removal filter. Now the water is crystal clear. 24x7 support is very helpful.",
    rating: "★★★★★",
    initials: "GM",
    color: "#024095"
  },
  {
    client: "Sajeev S.",
    entity: "Store Owner, Poojappura",
    statement: "Best service for multibrand water purifiers in Trivandrum. They repaired my Kent RO purifier within 2 hours. Reasonable charges and genuine spares. Highly satisfied!",
    rating: "★★★★★",
    initials: "SS",
    color: "#0ea5e9"
  },
  {
    client: "Deepa Nair",
    entity: "Apartment Association, Sasthamangalam",
    statement: "Professional water treatment plants setup. Installed swimming pool filtration plant for our building association. Excellent design, timely execution, and reliable maintenance.",
    rating: "★★★★★",
    initials: "DN",
    color: "#07bee8"
  }
];
---

<Layout title="Client Testimonials & Case Logs | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="bg-[#FAF9F6] text-slate-900 pt-28 sm:pt-36 pb-12 sm:pb-16 border-b border-slate-200/60">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-5 sm:mb-6">
        <span class="h-[1px] w-10 sm:w-12 bg-[#024095]"></span>
        <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">VERIFIED STATUS / CLIENT CASE STUDIES</span>
      </div>
      <h1 class="text-[clamp(1.1rem,5.5vw,3rem)] max-sm:whitespace-nowrap sm:text-5xl lg:text-6xl font-black tracking-tighter text-[#024095] leading-none uppercase">Client Testimonials &amp; Case Logs.</h1>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mt-4">
        <p class="text-sm text-black font-light max-w-xl leading-relaxed">Review real operational logs and performance validation records from our cross-brand installation client network across Kerala. Rated <strong>4.9 / 5</strong> on Google.</p>
        <a href="https://www.google.com/maps/search/?api=1&query=Samudhra+Water+Solutions+Poojappura+Thiruvananthapuram" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 justify-center min-h-[48px] px-6 py-3 bg-[#024095] text-white hover:bg-[#07bee8] transition-colors text-xs font-black uppercase tracking-[0.2em] rounded-md shadow-md whitespace-nowrap self-start md:self-auto">
          <!-- Google G icon -->
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#fff"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#fff"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#fff"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#fff"/>
          </svg>
          Write a Google Review
        </a>
      </div>
    </div>
  </section>

  <!-- GOOGLE RATING BADGE -->
  <section class="bg-[#024095] text-white py-8 sm:py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center gap-6 sm:gap-10">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center shadow-md">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-black tracking-tighter">4.9</p>
          <p class="text-[#07bee8] text-sm font-black tracking-widest">★★★★★</p>
        </div>
      </div>
      <div class="border-t sm:border-t-0 sm:border-l border-white/20 pt-6 sm:pt-0 pl-0 sm:pl-10 text-center sm:text-left w-full sm:w-auto">
        <p class="text-xl sm:text-2xl font-black uppercase tracking-tight">Google Verified Rating</p>
        <p class="text-white/60 text-xs font-bold uppercase tracking-widest mt-1">Based on customer reviews — Poojappura, Thiruvananthapuram</p>
      </div>
    </div>
  </section>

  <!-- REVIEWS GRID: 1-col mobile, 2-col tablet, 3-col desktop -->
  <section class="bg-[#FAF9F6] text-slate-900 py-14 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {reviews.map((rev) => (
          <div class="p-6 sm:p-8 lg:p-10 bg-white border-l-4 border-[#024095] rounded-r-md flex flex-col justify-between shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <div class="space-y-4">
              <!-- Google icon + rating row -->
              <div class="flex items-center justify-between">
                <div class="text-[#07bee8] text-xs font-black tracking-widest">{rev.rating}</div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-label="Google" class="opacity-50">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
              <p class="text-sm text-black font-light leading-relaxed italic">"{rev.statement}"</p>
            </div>
            <!-- Reviewer: initials avatar + name (same style as Google Maps) -->
            <div class="pt-6 sm:pt-8 border-t border-slate-200/60 mt-6 sm:mt-8 flex items-center gap-3">
              <div style={`background:${rev.color}`} class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 shadow-sm">
                <span class="text-white text-xs font-black">{rev.initials}</span>
              </div>
              <div>
                <p class="text-sm font-black text-[#024095] tracking-tight uppercase">{rev.client}</p>
                <p class="text-[10px] font-bold text-black uppercase tracking-widest mt-0.5">{rev.entity}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Bottom CTA -->
      <div class="mt-12 sm:mt-16 text-center">
        <a href="https://www.google.com/maps/search/?api=1&query=Samudhra+Water+Solutions+Poojappura+Thiruvananthapuram" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 min-h-[48px] px-8 py-3 bg-[#024095] text-white hover:bg-[#07bee8] transition-all text-xs font-black uppercase tracking-[0.2em] rounded-md shadow-md">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#fff"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#fff"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#fff"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#fff"/>
          </svg>
          See All Google Reviews &amp; Write One
        </a>
      </div>
    </div>
  </section>

  <!-- TRUSTED BY -->
  <section class="pt-10 pb-10 bg-white border-t border-slate-200/60 overflow-hidden relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="text-[clamp(0.55rem,2.5vw,0.75rem)] tracking-[0.15em] sm:tracking-[0.3em] font-black text-center text-[#024095] mb-6 uppercase">
        TRUSTED BY KERALA'S LEADING INSTITUTIONS
      </h2>

      <!-- MOBILE ONLY: 4 animated logo slots (visible on < md) -->
      <div class="flex md:hidden items-center justify-center gap-2">

        <!-- Slot 1: logo 1 → client image1 -->
        <div class="logo-slot overflow-hidden h-10 w-[70px] flex-shrink-0">
          <div class="logo-strip slot-1">
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/1.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 mix-blend-multiply" />
            </div>
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/client%20image1.png" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- Slot 2: logo 2 → client image2 -->
        <div class="logo-slot overflow-hidden h-10 w-[70px] flex-shrink-0">
          <div class="logo-strip slot-2">
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/2.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 mix-blend-multiply" />
            </div>
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/client%20image2.png" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- Slot 3: logo 3 → client image3 -->
        <div class="logo-slot overflow-hidden h-10 w-[70px] flex-shrink-0">
          <div class="logo-strip slot-3">
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/3.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 mix-blend-multiply" />
            </div>
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/client%20image3.png" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- Slot 4: logo 4 → client image4 -->
        <div class="logo-slot overflow-hidden h-10 w-[70px] flex-shrink-0">
          <div class="logo-strip slot-4">
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/4.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 mix-blend-multiply" />
            </div>
            <div class="logo-item h-10 flex items-center justify-center">
              <img src="/images/client/client%20image4.webp" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 mix-blend-multiply" />
            </div>
          </div>
        </div>

      </div>

      <!-- DESKTOP ONLY: 7 animated slots in one line (visible on md+) -->
      <div class="hidden md:flex items-center justify-center gap-8 lg:gap-12">

        <!-- D-Slot 1: logo 1 → client image1 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-1">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/1.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/client%20image1.png" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- D-Slot 2: logo 2 → client image2 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-2">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/2.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/client%20image2.png" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- D-Slot 3: logo 3 → client image3 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-3">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/3.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/client%20image3.png" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- D-Slot 4: logo 4 → client image4 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-4">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/4.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/client%20image4.webp" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- D-Slot 5: logo 5 → logo 1 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-5">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/5.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/1.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- D-Slot 6: logo 6 → logo 2 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-6">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/6.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/2.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
          </div>
        </div>

        <!-- D-Slot 7: logo 7 → logo 3 -->
        <div class="logo-slot overflow-hidden h-14 w-36 flex-shrink-0">
          <div class="logo-strip slot-d-7">
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/7.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
            <div class="logo-item h-14 flex items-center justify-center">
              <img src="/images/client/3.jpg" alt="Client Logo" class="max-w-full max-h-full object-contain grayscale opacity-60 hover:opacity-100 transition-opacity duration-300 mix-blend-multiply" />
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <style>
    .logo-slot { position: relative; }
    .logo-strip { display: flex; flex-direction: column; will-change: transform; }
    .logo-item { width: 100%; flex-shrink: 0; }
    .slot-1 { animation: logoFlip 10s ease-in-out 0s infinite; }
    .slot-2 { animation: logoFlip 10s ease-in-out 2.5s infinite; }
    .slot-3 { animation: logoFlip 10s ease-in-out 5s infinite; }
    .slot-4 { animation: logoFlip 10s ease-in-out 7.5s infinite; }
    .slot-d-1 { animation: logoFlip 10s ease-in-out 0s infinite; }
    .slot-d-2 { animation: logoFlip 10s ease-in-out 1.43s infinite; }
    .slot-d-3 { animation: logoFlip 10s ease-in-out 2.86s infinite; }
    .slot-d-4 { animation: logoFlip 10s ease-in-out 4.29s infinite; }
    .slot-d-5 { animation: logoFlip 10s ease-in-out 5.71s infinite; }
    .slot-d-6 { animation: logoFlip 10s ease-in-out 7.14s infinite; }
    .slot-d-7 { animation: logoFlip 10s ease-in-out 8.57s infinite; }
    @keyframes logoFlip {
      0%   { transform: translateY(0); }
      35%  { transform: translateY(0); }
      50%  { transform: translateY(-50%); }
      85%  { transform: translateY(-50%); }
      100% { transform: translateY(0); }
    }
  </style>

  <Footer />
</Layout>