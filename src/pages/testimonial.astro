---
// src/pages/testimonial.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const reviews = [
  {
    client: "Dr. K. Raghavan",
    entity: "Private Clinical Center, TVM",
    statement: "Samudhra precision-engineered our full 50,000 LPH reverse osmosis layout with absolute corporate standard clean lines. Their custom media filter parameters handled our hard water iron properties flawlessly. Purity remains total.",
    rating: "★★★★★"
  },
  {
    client: "Meera Nair",
    entity: "Residential Villa, Kowdiar",
    statement: "We completely bypassed generic retail options and had Samudhra customize an automated brine softener and multi-brand copper infusion system for our whole house. The white scale buildup inside our piping networks was instantly eliminated.",
    rating: "★★★★★"
  },
  {
    client: "Thomas Kurian",
    entity: "Commercial Complex, Thampanoor",
    statement: "Managing high-volume commercial properties requires absolute direct service accountability. Samudhra's maintenance contract team performs rigorous membrane audits and parameter inspections like clockwork.",
    rating: "★★★★★"
  }
];
---

<Layout title="Client Testimonials & Case Logs | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="bg-[#F9F9FB] text-slate-900 pt-28 sm:pt-36 pb-12 sm:pb-16 border-b border-slate-200/60">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-5 sm:mb-6">
        <span class="h-[1px] w-10 sm:w-12 bg-[#024095]"></span>
        <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">VERIFIED STATUS / CLIENT CASE STUDIES</span>
      </div>
      <h1 class="text-3xl sm:text-5xl lg:text-6xl font-black tracking-tighter text-[#024095] leading-none uppercase">Client Testimonials &amp; Case Logs.</h1>
      <p class="text-sm text-black font-light max-w-xl mt-4 leading-relaxed">Review real operational logs and performance validation records from our cross-brand installation client network across Kerala.</p>
    </div>
  </section>

  <!-- REVIEWS GRID: 1-col mobile, 2-col tablet, 3-col desktop -->
  <section class="bg-white text-slate-900 py-14 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {reviews.map((rev) => (
          <div class="p-6 sm:p-8 lg:p-10 bg-[#F9F9FB] border-l-4 border-[#024095] rounded-r-md flex flex-col justify-between shadow-sm hover:bg-slate-50/50 transition-all duration-300">
            <div class="space-y-4">
              <div class="text-[#07bee8] text-xs font-black tracking-widest">{rev.rating} AUDIT LOG</div>
              <p class="text-sm text-black font-light leading-relaxed italic">"{rev.statement}"</p>
            </div>
            <div class="pt-6 sm:pt-8 border-t border-slate-200/60 mt-6 sm:mt-8">
              <p class="text-sm font-black text-[#024095] tracking-tight uppercase">{rev.client}</p>
              <p class="text-[10px] font-bold text-black uppercase tracking-widest mt-0.5">{rev.entity}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>