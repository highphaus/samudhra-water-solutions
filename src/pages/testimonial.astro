---
// src/pages/testimonial.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Initials are derived from client names — no fake photos
const reviews = [
  {
    client: "Dr. K. Raghavan",
    entity: "Private Clinical Center, TVM",
    statement: "Samudhra precision-engineered our full 50,000 LPH reverse osmosis layout with absolute corporate standard clean lines. Their custom media filter parameters handled our hard water iron properties flawlessly. Purity remains total.",
    rating: "★★★★★",
    initials: "KR",
    color: "#024095"
  },
  {
    client: "Meera Nair",
    entity: "Residential Villa, Kowdiar",
    statement: "We completely bypassed generic retail options and had Samudhra customize an automated brine softener and multi-brand copper infusion system for our whole house. The white scale buildup inside our piping networks was instantly eliminated.",
    rating: "★★★★★",
    initials: "MN",
    color: "#07bee8"
  },
  {
    client: "Thomas Kurian",
    entity: "Commercial Complex, Thampanoor",
    statement: "Managing high-volume commercial properties requires absolute direct service accountability. Samudhra's maintenance contract team performs rigorous membrane audits and parameter inspections like clockwork.",
    rating: "★★★★★",
    initials: "TK",
    color: "#024095"
  },
  {
    client: "Anil Kumar",
    entity: "Factory Director, Kazhakkoottam",
    statement: "Excellent service and prompt response. The team installed a commercial RO plant in our factory near Kazhakkoottam. Very professional and highly recommended for industrial water purification needs.",
    rating: "★★★★★",
    initials: "AK",
    color: "#0ea5e9"
  },
  {
    client: "Remya Krishnan",
    entity: "Home Owner, Kowdiar",
    statement: "I bought a domestic water purifier (Aqua C3) from Samudhra. Excellent follow up, and water tank cleaning service was done very neatly. Excellent behaviour from Rajesh and staff.",
    rating: "★★★★★",
    initials: "RK",
    color: "#07bee8"
  },
  {
    client: "George Mathew",
    entity: "Resident, Pattom",
    statement: "We had severe iron content in our well water. They analyzed the water test report and designed a custom iron removal filter. Now the water is crystal clear. Their support is very helpful.",
    rating: "★★★★★",
    initials: "GM",
    color: "#024095"
  },
  {
    client: "Sajeev S.",
    entity: "Store Owner, Poojappura",
    statement: "Best service for multibrand water purifiers in Trivandrum. They repaired my Kent RO purifier within 2 hours. Reasonable charges and genuine spares. Highly satisfied!",
    rating: "★★★★★",
    initials: "SS",
    color: "#0ea5e9"
  },
  {
    client: "Deepa Nair",
    entity: "Apartment Association, Sasthamangalam",
    statement: "Professional water treatment plants setup. Installed swimming pool filtration plant for our building association. Excellent design, timely execution, and reliable maintenance.",
    rating: "★★★★★",
    initials: "DN",
    color: "#07bee8"
  }
];

// Build list of all 60 client images dynamically
const clientLogos = [];
for (let i = 1; i <= 60; i++) {
  let ext = 'png';
  if (i === 38) {
    ext = 'webp';
  } else if (i === 6) {
    ext = 'svg';
  } else if (i === 43) {
    ext = 'jpg';
  }
  clientLogos.push(`/images/client/client%20image${i}.${ext}`);
}
---

<Layout title="Client Testimonials & Case Logs | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="bg-[#FAF9F6] text-slate-900 pt-28 sm:pt-36 pb-12 sm:pb-16 border-b border-slate-200/60">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-5 sm:mb-6">
        <span class="h-[1px] w-10 sm:w-12 bg-[#024095]"></span>
        <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">VERIFIED STATUS / CLIENT CASE STUDIES</span>
      </div>
      <h1 class="text-[clamp(1.1rem,5.5vw,3rem)] max-sm:whitespace-nowrap sm:text-5xl lg:text-6xl font-black tracking-tighter text-[#024095] leading-none uppercase">Client Testimonials &amp; Case Logs.</h1>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mt-4">
        <p class="text-sm text-black font-light max-w-xl leading-relaxed">Review real operational logs and performance validation records from our cross-brand installation client network across Kerala. Rated <strong>4.9 / 5</strong> on Google.</p>
        <button id="btn-write-review" class="trigger-reviews-tab hover:cursor-pointer inline-flex items-center gap-2 justify-center min-h-[48px] px-6 py-3 bg-[#024095] text-white hover:bg-[#07bee8] transition-colors text-xs font-black uppercase tracking-[0.2em] rounded-md shadow-md whitespace-nowrap self-start md:self-auto">
          <!-- Google G icon -->
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#fff"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#fff"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#fff"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#fff"/>
          </svg>
          Write a Google Review
        </button>
      </div>
    </div>
  </section>

  <!-- GOOGLE RATING BADGE -->
  <section id="rating-badge-trigger" class="trigger-reviews-tab hover:cursor-pointer hover:bg-[#024095]/95 transition-colors bg-[#024095] text-white py-8 sm:py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center gap-6 sm:gap-10">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-full bg-white flex items-center justify-center shadow-md">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-black tracking-tighter">4.9</p>
          <p class="text-[#07bee8] text-sm font-black tracking-widest">★★★★★</p>
        </div>
      </div>
      <div class="border-t sm:border-t-0 sm:border-l border-white/20 pt-6 sm:pt-0 pl-0 sm:pl-10 text-center sm:text-left w-full sm:w-auto">
        <p class="text-xl sm:text-2xl font-black uppercase tracking-tight">Google Verified Rating</p>
        <p class="text-white/60 text-xs font-bold uppercase tracking-widest mt-1">Based on customer reviews — Poojappura, Thiruvananthapuram</p>
      </div>
    </div>
  </section>

  <!-- TAB SWITCHER -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 mt-8 sm:mt-12 flex justify-center relative z-30">
    <div class="inline-flex p-1.5 bg-blue-50/80 backdrop-blur-sm rounded-full border border-blue-100 shadow-sm">
      <button 
        id="tab-reviews"
        class="px-6 py-2.5 rounded-full text-xs sm:text-sm font-black uppercase tracking-wider transition-all duration-300 flex items-center gap-2 text-[#024095] hover:text-[#07bee8] bg-transparent"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        Customer Reviews
      </button>
      <button 
        id="tab-logos"
        class="px-6 py-2.5 rounded-full text-xs sm:text-sm font-black uppercase tracking-wider transition-all duration-300 flex items-center gap-2 bg-[#024095] text-white shadow-sm"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
        Trusted Clients ({clientLogos.length})
      </button>
      <button 
        id="tab-videos"
        class="px-6 py-2.5 rounded-full text-xs sm:text-sm font-black uppercase tracking-wider transition-all duration-300 flex items-center gap-2 bg-transparent text-[#024095] hover:text-[#07bee8]"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
        Video Reviews
      </button>
    </div>
  </div>

  <!-- REVIEWS GRID PANEL -->
  <section id="reviews-section" class="hidden bg-[#FAF9F6] text-slate-900 py-14 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        {reviews.map((rev) => (
          <a 
            href="https://www.google.com/maps/search/?api=1&query=Samudhra+Water+Solutions+Poojappura+Thiruvananthapuram"
            target="_blank"
            rel="noopener noreferrer"
            class="p-6 sm:p-8 lg:p-10 bg-white border-l-4 border-[#024095] rounded-r-md flex flex-col justify-between shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300 cursor-pointer block text-left"
          >
            <div class="space-y-4">
              <!-- Google icon + rating row -->
              <div class="flex items-center justify-between">
                <div class="text-[#07bee8] text-xs font-black tracking-widest">{rev.rating}</div>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-label="Google" class="opacity-50">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              </div>
              <p class="text-sm text-black font-light leading-relaxed italic">"{rev.statement}"</p>
            </div>
            <!-- Reviewer: initials avatar + name (same style as Google Maps) -->
            <div class="pt-6 sm:pt-8 border-t border-slate-200/60 mt-6 sm:mt-8 flex items-center gap-3">
              <div style={`background:${rev.color}`} class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 shadow-sm">
                <span class="text-white text-xs font-black">{rev.initials}</span>
              </div>
              <div>
                <p class="text-sm font-black text-[#024095] tracking-tight uppercase">{rev.client}</p>
                <p class="text-[10px] font-bold text-black uppercase tracking-widest mt-0.5">{rev.entity}</p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Bottom CTA -->
      <div class="mt-12 sm:mt-16 text-center">
        <a href="https://www.google.com/maps/search/?api=1&query=Samudhra+Water+Solutions+Poojappura+Thiruvananthapuram" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 min-h-[48px] px-8 py-3 bg-[#024095] text-white hover:bg-[#07bee8] transition-all text-xs font-black uppercase tracking-[0.2em] rounded-md shadow-md">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#fff"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#fff"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#fff"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#fff"/>
          </svg>
          See All Google Reviews &amp; Write One
        </a>
      </div>
    </div>
  </section>

  <!-- LOGOS GRID PANEL -->
  <section id="logos-section" class="bg-[#FAF9F6] text-slate-900 py-14 sm:py-20 border-t border-slate-200/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-[clamp(1rem,4.5vw,1.75rem)] sm:text-2xl md:text-3xl font-black text-[#024095] uppercase relative inline-block pb-3">
          Our Trusted Clients &amp; Partners
          <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-16 h-[3px] bg-gradient-to-r from-[#07bee8] to-[#024095] rounded-full"></span>
        </h2>
        <p class="text-sm text-black font-light leading-relaxed max-w-xl mx-auto mt-4">
          We are proud to serve over 60 of Kerala's leading clinics, hospitals, hotels, residences, and institutions with pristine water purification solutions.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 xl:grid-cols-7 gap-4 sm:gap-6">
        {clientLogos.map((logo, index) => (
          <div class="bg-white p-3 rounded-2xl shadow-sm border border-slate-100/80 hover:border-[#024095]/30 hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex items-center justify-center h-20 sm:h-24 group overflow-hidden">
            <img 
              src={logo} 
              alt={`Client Logo ${index + 1}`} 
              class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-500" 
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VIDEOS GRID PANEL -->
  <section id="videos-section" class="hidden bg-[#FAF9F6] text-slate-900 py-14 sm:py-20 border-t border-slate-200/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-[clamp(1rem,4.5vw,1.75rem)] sm:text-2xl md:text-3xl font-black text-[#024095] uppercase relative inline-block pb-3">
          Video Testimonials &amp; Reviews
          <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-16 h-[3px] bg-gradient-to-r from-[#07bee8] to-[#024095] rounded-full"></span>
        </h2>
        <p class="text-sm text-black font-light leading-relaxed max-w-xl mx-auto mt-4">
          Watch real customer video reviews and installation walkthroughs demonstrating our treatment systems across Kerala.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 justify-center max-w-4xl mx-auto">
        <!-- Video 1 -->
        <div class="bg-white p-4 rounded-3xl border border-slate-100 shadow-sm flex flex-col items-center">
          <div class="relative w-full aspect-[9/16] rounded-2xl overflow-hidden border border-slate-200/80 shadow-md bg-black">
            <iframe 
              class="w-full h-full"
              src="https://www.youtube.com/embed/NaS81NLs_4w" 
              title="Samudhra Water Solutions Video Review 1" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              allowfullscreen>
            </iframe>
          </div>
          <div class="text-center mt-4">
            <p class="text-xs font-black text-[#024095] uppercase tracking-wide">Client Review — Iron Removal Plant</p>
            <p class="text-[10px] text-slate-500 font-bold uppercase mt-1">Verified Installation</p>
          </div>
        </div>

        <!-- Video 2 -->
        <div class="bg-white p-4 rounded-3xl border border-slate-100 shadow-sm flex flex-col items-center">
          <div class="relative w-full aspect-[9/16] rounded-2xl overflow-hidden border border-slate-200/80 shadow-md bg-black">
            <iframe 
              class="w-full h-full"
              src="https://www.youtube.com/embed/itPpt6hUtP0" 
              title="Samudhra Water Solutions Video Review 2" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              allowfullscreen>
            </iframe>
          </div>
          <div class="text-center mt-4">
            <p class="text-xs font-black text-[#024095] uppercase tracking-wide">Client Review — Domestic RO Filter</p>
            <p class="text-[10px] text-slate-500 font-bold uppercase mt-1">Verified Installation</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const tabReviews = document.getElementById('tab-reviews');
    const tabLogos = document.getElementById('tab-logos');
    const tabVideos = document.getElementById('tab-videos');
    const reviewsSection = document.getElementById('reviews-section');
    const logosSection = document.getElementById('logos-section');
    const videosSection = document.getElementById('videos-section');

    if (tabReviews && tabLogos && tabVideos && reviewsSection && logosSection && videosSection) {
      tabReviews.addEventListener('click', () => {
        // Toggle button styles
        tabReviews.classList.add('bg-[#024095]', 'text-white', 'shadow-sm');
        tabReviews.classList.remove('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        tabLogos.classList.remove('bg-[#024095]', 'text-white', 'shadow-sm');
        tabLogos.classList.add('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        tabVideos.classList.remove('bg-[#024095]', 'text-white', 'shadow-sm');
        tabVideos.classList.add('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        // Toggle content visibility
        reviewsSection.classList.remove('hidden');
        logosSection.classList.add('hidden');
        videosSection.classList.add('hidden');
      });

      tabLogos.addEventListener('click', () => {
        // Toggle button styles
        tabLogos.classList.add('bg-[#024095]', 'text-white', 'shadow-sm');
        tabLogos.classList.remove('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        tabReviews.classList.remove('bg-[#024095]', 'text-white', 'shadow-sm');
        tabReviews.classList.add('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        tabVideos.classList.remove('bg-[#024095]', 'text-white', 'shadow-sm');
        tabVideos.classList.add('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        // Toggle content visibility
        reviewsSection.classList.add('hidden');
        logosSection.classList.remove('hidden');
        videosSection.classList.add('hidden');
      });

      tabVideos.addEventListener('click', () => {
        // Toggle button styles
        tabVideos.classList.add('bg-[#024095]', 'text-white', 'shadow-sm');
        tabVideos.classList.remove('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        tabReviews.classList.remove('bg-[#024095]', 'text-white', 'shadow-sm');
        tabReviews.classList.add('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        tabLogos.classList.remove('bg-[#024095]', 'text-white', 'shadow-sm');
        tabLogos.classList.add('text-[#024095]', 'hover:text-[#07bee8]', 'bg-transparent');

        // Toggle content visibility
        reviewsSection.classList.add('hidden');
        logosSection.classList.add('hidden');
        videosSection.classList.remove('hidden');
      });

      // Bind click triggers for Write Review / rating badge to switch to Customer Reviews tab
      const reviewsTriggers = document.querySelectorAll('.trigger-reviews-tab');
      reviewsTriggers.forEach(el => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          tabReviews.click();
          reviewsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      });

      // Check URL query parameter for active tab initialization (default is logos first)
      const urlParams = new URLSearchParams(window.location.search);
      const tabParam = urlParams.get('tab');
      if (tabParam === 'reviews') {
        tabReviews.click();
      } else if (tabParam === 'videos') {
        tabVideos.click();
        if (window.location.hash === '#videos-section') {
          setTimeout(() => {
            videosSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 100);
        }
      } else {
        tabLogos.click();
      }
    }
  </script>

  <Footer />
</Layout>
