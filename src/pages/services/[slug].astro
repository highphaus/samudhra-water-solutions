---
// src/pages/services/[slug].astro
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { services, getServiceBySlug, whySamudhra, testimonials } from '../../utils/services-data.js';

export async function getStaticPaths() {
  return services.map(service => ({
    params: { slug: service.slug },
    props: { service }
  }));
}

const { service } = Astro.props;

// Format the FAQ schema JSON-LD
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": service.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

// SVG Icon Helper Component/Function to keep templates clean
const getFeatureIcon = (iconName) => {
  switch (iconName) {
    case 'efficiency':
      return `<svg class="w-8 h-8 text-[#07bee8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`;
    case 'maintenance':
      return `<svg class="w-8 h-8 text-[#07bee8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`;
    case 'energy':
      return `<svg class="w-8 h-8 text-[#07bee8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`;
    case 'lifespan':
      return `<svg class="w-8 h-8 text-[#07bee8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`;
    case 'custom':
      return `<svg class="w-8 h-8 text-[#07bee8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>`;
    case 'install':
      return `<svg class="w-8 h-8 text-[#07bee8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`;
    default:
      return `<svg class="w-8 h-8 text-[#07bee8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
  }
};

const getTrustIcon = (iconName) => {
  switch (iconName) {
    case 'trophy':
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 2H5a2 2 0 00-2 2v4a2 2 0 002 2h4m0-8h6m-6 0v8m6-8h4a2 2 0 012 2v4a2 2 0 01-2 2h-4m0-8v8m0 0v6m-6-6v6m6 0H9m3 0v0"/></svg>`;
    case 'check-circle':
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
    case 'users':
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`;
    case 'settings':
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`;
    case 'wrench':
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`;
    case 'shield':
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`;
    case 'headset':
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M21 3v6h-6M3 12h.01M3 12a9 9 0 0115-6.708M3 12a9 9 0 0015 6.708m-1.5-6.708A6 6 0 1112 18m0-12a6 6 0 00-6 6M12 18a6 6 0 006-6m-6 6v.01M6.343 5.636a9 9 0 000 12.728m0 0l2.829-2.829m-2.829 2.829L3 21"/></svg>`;
    case 'tag':
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>`;
    default:
      return `<svg class="w-8 h-8 text-[#024095]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;
  }
};

---

<Layout title={service.metaTitle}>
  <!-- Schema markup injection -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- 1. HERO SECTION -->
  <section class="relative min-h-[75vh] flex items-center justify-center pt-28 sm:pt-36 pb-16 sm:pb-24 overflow-hidden">
    <!-- Overlay & Background Image -->
    <div class="absolute inset-0 z-0">
      <img src={service.heroImage} alt={service.title} class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-black/75"></div>
    </div>
    
    <!-- Dynamic particle decorations -->
    <div class="absolute top-0 right-0 w-80 h-80 bg-[#07bee8]/20 rounded-full blur-3xl"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 w-full text-white">
      <div class="max-w-3xl space-y-6">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight leading-tight uppercase">
          {service.title}
        </h1>
        <p class="text-base sm:text-xl text-slate-200 leading-relaxed font-light">
          {service.tagline}
        </p>
        <div class="flex flex-col sm:flex-row gap-3 pt-4">
          <a href="#quote-form" 
             class="inline-flex items-center justify-center px-8 py-3.5 bg-[#07bee8] hover:bg-white text-[#024095] font-black text-xs uppercase tracking-widest rounded-lg transition-all shadow-md active:scale-95">
            Get Quote
          </a>
          <a href={`https://wa.me/919645830994?text=Hi,%20I%20want%20to%20book%20a%20FREE%20water%20testing%20consultation%20for%20${encodeURIComponent(service.title)}.`}
             target="_blank"
             rel="noopener noreferrer"
             class="inline-flex items-center justify-center px-8 py-3.5 bg-transparent border-2 border-white hover:bg-white hover:text-[#024095] text-white font-black text-xs uppercase tracking-widest rounded-lg transition-all active:scale-95">
            Book Free Water Testing
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. PROBLEM → SOLUTION -->
  <section class="bg-[#FAF9F6] py-16 sm:py-24 border-b border-slate-200/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 sm:gap-16 items-center">
        <!-- Problem Card -->
        <div class="bg-white p-8 sm:p-10 rounded-2xl border border-red-100 shadow-sm relative overflow-hidden transition-transform duration-300 hover:scale-[1.01]">
          <div class="absolute top-0 left-0 w-full h-1.5 bg-red-500"></div>
          <div class="w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <h3 class="text-xl font-extrabold text-slate-900 mb-4 tracking-tight">The Problem</h3>
          <p class="text-sm sm:text-base text-slate-600 leading-relaxed font-light">
            {service.problem.description}
          </p>
        </div>

        <!-- Solution Card -->
        <div class="bg-white p-8 sm:p-10 rounded-2xl border border-emerald-100 shadow-sm relative overflow-hidden transition-transform duration-300 hover:scale-[1.01]">
          <div class="absolute top-0 left-0 w-full h-1.5 bg-emerald-500"></div>
          <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-xl font-extrabold text-slate-900 mb-4 tracking-tight">The Solution</h3>
          <p class="text-sm sm:text-base text-slate-600 leading-relaxed font-light">
            {service.solution.description}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. WHY CHOOSE THIS SERVICE (6 Feature Cards) -->
  <section class="bg-white py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-black text-[#024095] tracking-tight uppercase mb-4">
          Core Capabilities & Features
        </h2>
        <p class="text-sm sm:text-base text-slate-600 font-light leading-relaxed">
          Engineered for performance, safety, and operational simplicity to ensure continuous high-quality water flow.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {service.features.map((feat) => (
          <div class="bg-[#FAF9F6] p-8 rounded-2xl border border-slate-100/50 hover:shadow-md transition-all duration-300">
            <div class="mb-5" set:html={getFeatureIcon(feat.icon)} />
            <h3 class="text-lg font-bold text-slate-950 tracking-tight mb-3">{feat.title}</h3>
            <p class="text-xs sm:text-sm text-slate-600 leading-relaxed font-light">{feat.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. APPLICATIONS -->
  <section class="bg-[#FAF9F6] py-16 sm:py-24 border-t border-b border-slate-200/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-black text-[#024095] tracking-tight uppercase mb-4">
          Target Sectors & Applications
        </h2>
        <p class="text-sm sm:text-base text-slate-600 font-light leading-relaxed">
          Versatile layouts configured specifically for diverse application fields across Kerala.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {service.applications.map((app) => (
          <div class="bg-white p-5 sm:p-6 rounded-xl border border-slate-200/40 text-center shadow-xs hover:border-[#07bee8] hover:shadow transition-all duration-300">
            <span class="text-sm sm:text-base font-bold text-[#024095] tracking-tight">{app}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. WORKING PROCESS (Horizontal Timeline) -->
  <section class="bg-white py-16 sm:py-24 overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-black text-[#024095] tracking-tight uppercase mb-4">
          Our Operational Workflow
        </h2>
        <p class="text-sm sm:text-base text-slate-600 font-light leading-relaxed">
          A systematic, engineered approach from initial test analysis to ongoing lifecycle support.
        </p>
      </div>

      <!-- Process timeline: horizontal on desktop, vertical on mobile -->
      <div class="relative">
        <!-- Connecting Line -->
        <div class="hidden lg:block absolute top-[59px] left-[5%] right-[5%] h-[2px] bg-gradient-to-r from-[#024095] to-[#07bee8] z-0"></div>

        <div class="grid grid-cols-1 lg:grid-cols-6 gap-8 relative z-10">
          {service.process.map((step) => (
            <div class="flex flex-col items-center text-center group">
              <!-- Step number icon -->
              <div class="w-14 h-14 bg-white border-2 border-[#024095] text-[#024095] font-black text-lg rounded-full flex items-center justify-center shadow-sm group-hover:bg-[#024095] group-hover:text-white transition-all duration-300 mb-5 relative">
                {step.step}
                <!-- Small connecting arrow/line for mobile -->
                <div class="lg:hidden absolute -bottom-5 left-1/2 -translate-x-1/2 w-[2px] h-4 bg-slate-200"></div>
              </div>
              <h3 class="text-sm sm:text-base font-bold text-slate-900 tracking-tight mb-2 uppercase">{step.title}</h3>
              <p class="text-xs text-slate-500 leading-relaxed font-light max-w-[200px]">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 7. TECHNICAL SPECIFICATIONS -->
  <section class="bg-[#FAF9F6] py-16 sm:py-24 border-t border-b border-slate-200/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-black text-[#024095] tracking-tight uppercase mb-4">
          Technical Specifications
        </h2>
        <p class="text-sm sm:text-base text-slate-600 font-light leading-relaxed">
          Standard parameter configurations. Custom layouts engineered upon requirement check.
        </p>
      </div>

      <div class="bg-white rounded-2xl border border-slate-200/60 overflow-hidden shadow-sm">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="px-6 py-4 text-xs font-black uppercase tracking-wider text-[#024095]">Configuration Criteria</th>
              <th class="px-6 py-4 text-xs font-black uppercase tracking-wider text-slate-700">Parameters / Specifications</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 text-xs sm:text-sm">
            <tr class="hover:bg-slate-50/50">
              <td class="px-6 py-4 font-bold text-slate-900">Standard Capacities</td>
              <td class="px-6 py-4 text-slate-600">{service.specs.capacity.join(' | ')}</td>
            </tr>
            <tr class="hover:bg-slate-50/50">
              <td class="px-6 py-4 font-bold text-slate-900">Source Parameters</td>
              <td class="px-6 py-4 text-slate-600">{service.specs.waterSource.join(' | ')}</td>
            </tr>
            <tr class="hover:bg-slate-50/50">
              <td class="px-6 py-4 font-bold text-slate-900">Application Sectors</td>
              <td class="px-6 py-4 text-slate-600">{service.specs.applications.join(' | ')}</td>
            </tr>
            <tr class="hover:bg-slate-50/50">
              <td class="px-6 py-4 font-bold text-slate-900">Operation Control</td>
              <td class="px-6 py-4 text-slate-600">Manual / Semi-Automatic / Fully Automated PLC Skid</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 8. BENEFITS SECTION -->
  <section class="bg-white py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-black text-[#024095] tracking-tight uppercase mb-4">
          Core Operational Benefits
        </h2>
        <p class="text-sm sm:text-base text-slate-600 font-light leading-relaxed">
          Explore the fundamental outcomes of deploying our customized water treatment systems.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {service.benefitCards.map((benefit) => (
          <div class="bg-[#FAF9F6] p-6 rounded-xl border border-slate-100 shadow-xs hover:shadow transition-all duration-300">
            <h4 class="text-base font-bold text-slate-950 tracking-tight mb-2">{benefit.title}</h4>
            <p class="text-xs text-slate-500 leading-relaxed font-light">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 9. WHY SAMUDHRA WATER SOLUTIONS -->
  <section class="bg-[#FAF9F6] py-16 sm:py-24 border-t border-b border-slate-200/50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl font-black text-[#024095] tracking-tight uppercase mb-4">
          Why Samudhra Water Solutions
        </h2>
        <p class="text-sm sm:text-base text-slate-600 font-light leading-relaxed">
          Kerala's leading corporate-grade water engineers providing lifetime lifecycle support.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {whySamudhra.map((item) => (
          <div class="bg-white p-6 rounded-xl border border-slate-100 text-center shadow-xs hover:border-[#07bee8] transition-all duration-300">
            <div class="w-12 h-12 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4" set:html={getTrustIcon(item.icon)} />
