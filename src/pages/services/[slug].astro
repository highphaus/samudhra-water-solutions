  <script is:inline>
    // FAQ Accordion logic
    function toggleFaq(index) {
      const headers = document.querySelectorAll('.faq-accordion-header');
      const bodies = document.querySelectorAll('.faq-accordion-body');
      const icons = document.querySelectorAll('.faq-icon');
      
      const body = bodies[index];
      const icon = icons[index];
      const isOpen = body.style.maxHeight && body.style.maxHeight !== '0px';

      // Close all first for clean UX
      bodies.forEach((b, i) => {
        b.style.maxHeight = '0px';
        icons[i].classList.remove('rotate-180');
      });

      // Toggle requested one
      if (!isOpen) {
        body.style.maxHeight = body.scrollHeight + 'px';
        icon.classList.add('rotate-180');
      }
    }
  </script>
  
