---
// src/pages/shop.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const products = [
  { name: "100000 LPH RO Plant", image: "/images/products/100000 LPH RO plant.jpg", tier: "Industrial Tier", specs: "High Capacity RO Filtration", contaminants: "Heavy TDS, Pathogens, Minerals", suitability: "Large Scale Industries, Factories", availability: "Built to Order" },
  { name: "100LPH-10000LPH RO Plant", image: "/images/products/100LPH-10000LPH RO Plant.jpg", tier: "Commercial Tier", specs: "Customizable Output", contaminants: "TDS, Pathogens, Silt", suitability: "Hospitals, Offices, Institutions", availability: "Built to Order" },
  { name: "AQUA C3", image: "/images/products/AQUA C3.jpg", tier: "Residential Purity", specs: "Advanced Purification", contaminants: "Pathogens, Hardness", suitability: "Home and Apartment use", availability: "In Stock" },
  { name: "AQUA XZORA", image: "/images/products/AQUA XZORA.jpg", tier: "Residential Purity", specs: "Multi-Stage Filtration", contaminants: "TDS, Chemicals, Odor", suitability: "Home, Municipal Water", availability: "In Stock" },
  { name: "AQUA9090", image: "/images/products/AQUA9090.jpg", tier: "Residential Purity", specs: "Premium Water Purifier", contaminants: "Pathogens, Heavy Metals", suitability: "Home use", availability: "In Stock" },
  { name: "BELLA+ & AVA+", image: "/images/products/BELLA+ & AVA+.jpg", tier: "Residential Purity", specs: "Compact Modern Purifiers", contaminants: "Bacteria, Cysts, Silt", suitability: "Kitchen, Small Office", availability: "In Stock" },
  { name: "DM Plant", image: "/images/products/DM plant.jpg", tier: "Industrial Tier", specs: "Demineralization System", contaminants: "Dissolved Mineral Salts", suitability: "Laboratories, Power Plants", availability: "Built to Order" },
  { name: "Desalination Water Filtration", image: "/images/products/Desalination Water Filtration.jpg", tier: "Industrial Tier", specs: "Seawater Desalination", contaminants: "High Salt Content", suitability: "Coastal Resorts, Marine Applications", availability: "Built to Order" },
  { name: "Effluent Treatment Plant", image: "/images/products/Effluent Treatment Plant.jpg", tier: "Infrastructure Tier", specs: "Industrial Wastewater Processing", contaminants: "Chemicals, Effluents", suitability: "Factories, Manufacturing Units", availability: "Built to Order" },
  { name: "Hot and Cold Water Dispenser", image: "/images/products/HOT AND COLD Water Dispenser.jpg", tier: "Commercial Tier", specs: "Temperature Controlled Dispensing", contaminants: "Integrated Filtration Options", suitability: "Offices, Clinics, Waiting Areas", availability: "In Stock" },
  { name: "Multibrand Water Purifiers", image: "/images/products/Multibrand Water Purifiers.jpg", tier: "Residential/Commercial", specs: "Various Top Brands", contaminants: "All Water Issues", suitability: "Homes, Shops, Offices", availability: "In Stock" },
  { name: "PZONE BLACK Water Purifier", image: "/images/products/PZONE BLACK Water purifier.jpg", tier: "Residential Purity", specs: "Elegant Black Design, RO+UV", contaminants: "TDS, Bacteria", suitability: "Modern Kitchens", availability: "In Stock" },
  { name: "SALVADOR RO Water Purifier", image: "/images/products/SALVADOR RO water purifier.jpg", tier: "Residential Purity", specs: "RO Technology", contaminants: "Hard Water, Chemicals", suitability: "Household Drinking Water", availability: "In Stock" },
  { name: "Sewage Treatment Plant", image: "/images/products/Sewage Treatment Plant.jpg", tier: "Infrastructure Tier", specs: "Sewage and Wastewater Recycling", contaminants: "Organic Waste, Pathogens", suitability: "Apartments, Hotels, Municipalities", availability: "Built to Order" },
  { name: "Stainless Steel Water Tanks", image: "/images/products/Stainless steel water tanks.jpg", tier: "Storage Solutions", specs: "Food Grade SS 304/316", contaminants: "Prevents Algae and Rust", suitability: "Residential, Commercial Storage", availability: "In Stock" },
  { name: "Swimming Pool Filtration Plant", image: "/images/products/Swimming Pool Filtration Plant.jpeg", tier: "Commercial Tier", specs: "Sand and Cartridge Filtration", contaminants: "Debris, Algae, Bacteria", suitability: "Hotels, Resorts, Public Pools", availability: "Built to Order" },
  { name: "UF Plant", image: "/images/products/Uf Plant.jpg", tier: "Commercial Tier", specs: "Ultrafiltration Technology", contaminants: "Suspended Solids, Bacteria", suitability: "Pre-treatment, Municipal Water", availability: "Built to Order" },
  { name: "Water Softening Plant", image: "/images/products/Water softening plant.jpg", tier: "Infrastructure Tier", specs: "Ion-Exchange Process", contaminants: "Calcium, Magnesium (Hardness)", suitability: "Whole House, Laundries, Boilers", availability: "Built to Order" },
  { name: "Water Treatment Plant", image: "/images/products/Water treatment plant.jpg", tier: "Infrastructure Tier", specs: "Comprehensive Water Treatment", contaminants: "Multiple Contaminants", suitability: "Large Scale Supply, Factories", availability: "Built to Order" },
  { name: "ZEDERA Water Purifiers", image: "/images/products/ZEDERA WATER PURIFIERS.jpg", tier: "Residential Purity", specs: "Advanced Home Filtration", contaminants: "Common Impurities", suitability: "Home use", availability: "In Stock" }
];
---

<Layout title="Advanced Product Portfolio | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="bg-[#F9F9FB] text-slate-900 pt-28 sm:pt-36 pb-12 sm:pb-16 border-b border-slate-200/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-5 sm:mb-6">
        <span class="h-[1px] w-10 sm:w-12 bg-[#024095]"></span>
        <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">COLLECTIONS / ALL PORTFOLIO</span>
      </div>
      <h1 class="text-3xl sm:text-5xl lg:text-6xl font-black tracking-tighter text-[#024095] leading-none uppercase">Advanced Product Portfolio.</h1>
      <p class="text-sm text-black font-light max-w-xl mt-4 leading-relaxed">A meticulously calibrated ecosystem of high-end multi-brand water purification architectures. Select a configuration tier below to initiate structural integration.</p>
    </div>
  </section>

  <!-- PRODUCTS GRID: 1 col mobile, 2 col tablet, 3 col desktop -->
  <section class="bg-white text-slate-900 py-12 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 sm:gap-0 sm:border sm:border-slate-200 sm:shadow-sm sm:rounded-lg sm:overflow-hidden">
        {products.map((product, index) => (
          <div class="p-6 sm:p-8 lg:p-10 sm:border-b xl:border-b sm:last:border-b-0 bg-[#F9F9FB] flex flex-col justify-between hover:bg-white transition-all duration-300 group rounded-lg sm:rounded-none border border-slate-200 sm:border-slate-0"
               style={`border-color: rgba(226,232,240,0.6)`}>
            <div class="space-y-4 sm:space-y-5">
              <!-- Header row -->
              <div class="flex justify-between items-center gap-2 flex-wrap">
                <span class="text-[9px] sm:text-[10px] font-mono text-[#07bee8] uppercase tracking-widest">[ {product.tier} ]</span>
                <span class={`text-[8px] sm:text-[9px] font-bold px-2.5 py-1 uppercase tracking-wider rounded ${product.availability === 'In Stock' ? 'bg-emerald-50 text-emerald-700' : 'bg-orange-50 text-orange-700'}`}>
                  {product.availability}
                </span>
              </div>

              <!-- Product image -->
              <div class="w-full bg-white rounded-md flex items-center justify-center overflow-hidden p-3 sm:p-4 shadow-inner border border-slate-100" style="aspect-ratio: 4/3">
                <img src={product.image} alt={product.name} loading="lazy"
                     class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-500" />
              </div>

              <!-- Name & specs -->
              <div>
                <h3 class="text-lg sm:text-xl lg:text-2xl font-black tracking-tight text-[#024095] group-hover:text-[#07bee8] transition-colors uppercase leading-tight">{product.name}</h3>
                <p class="text-xs font-bold text-black mt-1 tracking-wide">{product.specs}</p>
              </div>

              <!-- Details -->
              <div class="space-y-3 pt-3 sm:pt-4 border-t border-slate-200/40">
                <div>
                  <p class="text-[9px] font-bold text-black uppercase tracking-widest">Target Mitigation</p>
                  <p class="text-xs font-medium text-black mt-0.5">{product.contaminants}</p>
                </div>
                <div>
                  <p class="text-[9px] font-bold text-black uppercase tracking-widest">Hydrological Calibration</p>
                  <p class="text-xs font-medium text-black mt-0.5">{product.suitability}</p>
                </div>
              </div>
            </div>

            <!-- CTA button -->
            <div class="pt-6 sm:pt-8">
              <a href={`https://wa.me/919645830994?text=Hi, I am interested in checking stock specs for the ${product.name}.`}
                 target="_blank"
                 class="w-full flex items-center justify-center min-h-[48px] py-3 bg-[#024095] text-white text-[10px] font-black uppercase tracking-[0.2em] hover:bg-[#07bee8] transition-all rounded-md shadow-md">
                Request Configuration Audit
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>