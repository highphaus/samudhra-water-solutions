---
// src/pages/shop.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const products = [
  { name: "Commercial & Industrial Water Treatment Plant", image: "/images/products/Commerical%20and%20Industrial%20water%20treatment%20plant.jpeg", tier: "Infrastructure Tier", specs: "High-Capacity Filtration System", contaminants: "Mud, Turbidity, Iron, Odor", suitability: "Communities, Factories, Commercial", availability: "Built to Order" },
  { name: "Residential Water Treatment Plant", image: "/images/products/Residential%20water%20treatment%20plant.jpeg", tier: "Residential Purity", specs: "Multi-Stage Pre-filtration", contaminants: "Suspended Solids, Odor, Mud", suitability: "Independent Houses, Villas", availability: "In Stock" },
  { name: "100LPH-10000LPH RO Plant", image: "/images/products/100LPH-10000LPH%20RO%20Plant.jpg", tier: "Commercial Tier", specs: "Customizable Output", contaminants: "TDS, Pathogens, Silt", suitability: "Hospitals, Offices, Institutions", availability: "Built to Order" },
  { name: "100000 LPH RO Plant", image: "/images/products/100000%20LPH%20RO%20plant.jpg", tier: "Industrial Tier", specs: "High Capacity RO Filtration", contaminants: "Heavy TDS, Pathogens, Minerals", suitability: "Large Scale Industries, Factories", availability: "Built to Order" },
  { name: "Sewage Treatment Plant", image: "/images/products/Sewage%20Treatment%20Plant.jpg", tier: "Infrastructure Tier", specs: "Sewage and Wastewater Recycling", contaminants: "Organic Waste, Pathogens", suitability: "Apartments, Hotels, Municipalities", availability: "Built to Order" },
  { name: "Effluent Treatment Plant", image: "/images/products/Effluent%20Treatment%20Plant.jpg", tier: "Infrastructure Tier", specs: "Industrial Wastewater Processing", contaminants: "Chemicals, Effluents", suitability: "Factories, Manufacturing Units", availability: "Built to Order" },
  { name: "Hot and Cold Water Dispenser", image: "/images/products/HOT%20AND%20COLD%20Water%20Dispenser.jpg", tier: "Commercial Tier", specs: "Temperature Controlled Dispensing", contaminants: "Integrated Filtration Options", suitability: "Offices, Clinics, Waiting Areas", availability: "In Stock" },
  { name: "DM Plant", image: "/images/products/DM%20plant.jpg", tier: "Industrial Tier", specs: "Demineralization System", contaminants: "Dissolved Mineral Salts", suitability: "Laboratories, Power Plants", availability: "Built to Order" },
  { name: "Desalination Water Filtration", image: "/images/products/Desalination%20Water%20Filtration.jpg", tier: "Industrial Tier", specs: "Seawater Desalination", contaminants: "High Salt Content", suitability: "Coastal Resorts, Marine Applications", availability: "Built to Order" },
  { name: "UF Plant", image: "/images/products/Uf%20Plant.jpg", tier: "Commercial Tier", specs: "Ultrafiltration Technology", contaminants: "Suspended Solids, Bacteria", suitability: "Pre-treatment, Municipal Water", availability: "Built to Order" },
  { name: "Commercial & Industrial Water Softener", image: "/images/products/commerical%20water%20softner.jpg", tier: "Infrastructure Tier", specs: "Heavy-duty Ion Exchange Process", contaminants: "Calcium, Magnesium (Hardness)", suitability: "Commercial Buildings, Industries, Boilers", availability: "Built to Order" },
  { name: "Residential Water Softener", image: "/images/products/Residential%20Water%20Softner.jpeg", tier: "Residential Purity", specs: "Ion-Exchange Hardness Removal", contaminants: "Calcium, Magnesium (Scaling)", suitability: "Whole House, Apartments", availability: "In Stock" },
  { name: "Industrial Water Softener", image: "/images/products/Industrial%20water%20softner.jpg", tier: "Industrial Tier", specs: "High Capacity Ion Exchange", contaminants: "Hardness, Scaling Minerals", suitability: "Large Boilers, Factories, Laundries", availability: "Built to Order" },
  { name: "Swimming Pool Filtration Plant", image: "/images/products/Swimming%20Pool%20Filtration%20Plant.jpeg", tier: "Commercial Tier", specs: "Sand and Cartridge Filtration", contaminants: "Debris, Algae, Bacteria", suitability: "Hotels, Resorts, Public Pools", availability: "Built to Order" },
  { name: "Stainless Steel Water Tanks", image: "/images/products/Stainless%20steel%20water%20tanks.jpg", tier: "Storage Solutions", specs: "Food Grade SS 304/316", contaminants: "Prevents Algae and Rust", suitability: "Residential, Commercial Storage", availability: "In Stock" },
  { name: "Multibrand Water Purifiers", image: "/images/products/Multibrand%20Water%20Purifiers.png", tier: "Residential/Commercial", specs: "Various Top Brands", contaminants: "All Water Issues", suitability: "Homes, Shops, Offices", availability: "In Stock" },
  { name: "AQUA C3", image: "/images/products/AQUA%20C3.jpg", tier: "Residential Purity", specs: "Advanced Purification", contaminants: "Pathogens, Hardness", suitability: "Home and Apartment use", availability: "In Stock" },
  { name: "AQUA XZORA", image: "/images/products/AQUA%20XZORA.jpg", tier: "Residential Purity", specs: "Multi-Stage Filtration", contaminants: "TDS, Chemicals, Odor", suitability: "Home, Municipal Water", availability: "In Stock" },
  { name: "AQUA9090", image: "/images/products/AQUA9090.jpg", tier: "Residential Purity", specs: "Premium Water Purifier", contaminants: "Pathogens, Heavy Metals", suitability: "Home use", availability: "In Stock" },
  { name: "BELLA+ & AVA+", image: "/images/products/BELLA+%20&%20AVA+.jpg", tier: "Residential Purity", specs: "Compact Modern Purifiers", contaminants: "Bacteria, Cysts, Silt", suitability: "Kitchen, Small Office", availability: "In Stock" },
  { name: "PZONE BLACK Water Purifier", image: "/images/products/PZONE%20BLACK%20Water%20purifier.jpg", tier: "Residential Purity", specs: "Elegant Black Design, RO+UV", contaminants: "TDS, Bacteria", suitability: "Modern Kitchens", availability: "In Stock" },
  { name: "SALVADOR RO Water Purifier", image: "/images/products/SALVADOR%20RO%20water%20purifier.jpg", tier: "Residential Purity", specs: "RO Technology", contaminants: "Hard Water, Chemicals", suitability: "Household Drinking Water", availability: "In Stock" },
  { name: "ZEDERA Water Purifiers", image: "/images/products/ZEDERA%20WATER%20PURIFIERS.jpg", tier: "Residential Purity", specs: "Advanced Home Filtration", contaminants: "Common Impurities", suitability: "Home use", availability: "In Stock" },
  { name: "CONWAY Commercial Water Dispensers", image: "/images/products/CONWAY.jpeg", tier: "Commercial Tier", specs: "High-Volume Stainless Steel Dispensing", contaminants: "Authorized Dealer Sales & Service", suitability: "Schools, Colleges, Offices, Hospitals, Factories, Public Spaces", availability: "In Stock" },
  { name: "Aquaguard Water Purifiers", image: "/images/products/Aquaguard%20Water%20Purifiers.jpeg", tier: "Residential Purity", specs: "Advanced RO+UV+UF + Active Copper", contaminants: "TDS, Chemicals, Heavy Metals, Pathogens", suitability: "Homes, Apartments, Small Offices, Kitchens", availability: "In Stock" },
  { name: "KENT Water Purifiers", image: "/images/products/KENT%20Water%20Purifiers.jpeg", tier: "Residential/Commercial", specs: "Mineral RO, Alkaline & Copper Models", contaminants: "High TDS, Bacteria, Dissolved Impurities", suitability: "Homes, Offices, Apartments, Clinics", availability: "In Stock" }
];
---

<Layout title="Advanced Product Portfolio | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="bg-[#F9F9FB] text-slate-900 pt-28 sm:pt-36 pb-12 sm:pb-16 border-b border-slate-200/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-5 sm:mb-6">
        <span class="h-[1px] w-10 sm:w-12 bg-[#024095]"></span>
        <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">COLLECTIONS / ALL PORTFOLIO</span>
      </div>
      <h1 class="text-[clamp(1.25rem,6vw,3rem)] max-sm:whitespace-nowrap sm:text-5xl lg:text-6xl font-black tracking-tighter text-[#024095] leading-none uppercase">Advanced Product Portfolio.</h1>
      <p class="text-sm text-black font-light max-w-xl mt-4 leading-relaxed">A meticulously calibrated ecosystem of high-end multi-brand water purification architectures. Select a configuration tier below to initiate structural integration.</p>
    </div>
  </section>

  <!-- PRODUCTS GRID: 1 col mobile, 2 col tablet, 3 col desktop -->
  <section class="bg-[#FAF9F6] text-slate-900 py-12 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6 sm:gap-8">
        {products.map((product, index) => (
          <div class="p-6 sm:p-8 lg:p-10 bg-white hover:bg-slate-50 flex flex-col justify-between transition-all duration-300 group rounded-2xl border border-slate-200 shadow-sm hover:shadow-md hover:-translate-y-1">
            <div class="space-y-4 sm:space-y-5">
              <!-- Header row -->
              <div class="flex justify-between items-center gap-2 flex-wrap">
                <span class="text-[9px] sm:text-[10px] font-mono text-[#07bee8] uppercase tracking-widest">[ {product.tier} ]</span>
                <span class={`text-[8px] sm:text-[9px] font-bold px-2.5 py-1 uppercase tracking-wider rounded ${product.availability === 'In Stock' ? 'bg-emerald-50 text-emerald-700' : 'bg-orange-50 text-orange-700'}`}>
                  {product.availability}
                </span>
              </div>

              <!-- Product image -->
              <div class="w-full bg-white rounded-md flex items-center justify-center overflow-hidden p-3 sm:p-4 shadow-inner border border-slate-100" style="aspect-ratio: 4/3">
                <img src={product.image} alt={product.name} loading="lazy"
                     class="max-h-full max-w-full object-contain group-hover:scale-105 transition-transform duration-500" />
              </div>

              <!-- Name & specs -->
              <div>
                <h3 class="text-lg sm:text-xl lg:text-2xl font-black tracking-tight text-[#024095] group-hover:text-[#07bee8] transition-colors uppercase leading-tight">{product.name}</h3>
                <p class="text-xs font-bold text-black mt-1 tracking-wide">{product.specs}</p>
              </div>

              <!-- Details -->
              <div class="space-y-3 pt-3 sm:pt-4 border-t border-slate-200/40">
                <div>
                  <p class="text-[9px] font-bold text-black uppercase tracking-widest">Target Mitigation</p>
                  <p class="text-xs font-medium text-black mt-0.5">{product.contaminants}</p>
                </div>
                <div>
                  <p class="text-[9px] font-bold text-black uppercase tracking-widest">Hydrological Calibration</p>
                  <p class="text-xs font-medium text-black mt-0.5">{product.suitability}</p>
                </div>
              </div>
            </div>

            <!-- Enquiry Input and Button -->
            <div class="pt-5 flex flex-col gap-2 border-t border-slate-200/40 mt-5">
              <input 
                type="text" 
                id={`shop-inquiry-input-${index}`}
                placeholder="Ask about price, delivery, etc..." 
                class="w-full px-3 py-2 text-xs border border-slate-200 rounded-lg focus:outline-none focus:border-[#024095] bg-white text-slate-800 transition-colors placeholder:text-slate-400"
              />
              <button
                data-name={product.name}
                data-index={index}
                class="shop-enquiry-btn w-full flex items-center justify-between min-h-[44px] px-4 py-2.5 bg-[#024095] text-white hover:bg-[#07bee8] rounded-lg transition-all duration-300"
              >
                <span class="text-[10px] font-black uppercase tracking-[0.2em]">Send Enquiry</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    // Handle shop product custom enquiries on WhatsApp
    document.querySelectorAll('.shop-enquiry-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const index = btn.getAttribute('data-index');
        const name = btn.getAttribute('data-name');
        const input = document.getElementById(`shop-inquiry-input-${index}`);
        const customText = input ? input.value.trim() : '';
        let message = `Hi, I am interested in checking stock specs for the ${name}.`;
        if (customText) {
          message += ` Details: ${customText}`;
        }
        const encoded = encodeURIComponent(message);
        window.open(`https://wa.me/919645830994?text=${encoded}`, '_blank');
      });

      // Press Enter key to submit
      const index = btn.getAttribute('data-index');
      const input = document.getElementById(`shop-inquiry-input-${index}`);
      if (input) {
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            btn.click();
          }
        });
      }
    });
  </script>
  <!-- LEADERSHIP & ENGINEERING QUALITY ASSURANCE -->
  <section class="bg-white py-16 sm:py-24 border-t border-slate-200/60 relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 left-0 w-80 h-80 bg-[#07bee8]/5 rounded-full blur-3xl -ml-20 -mt-20"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-[#024095]/5 rounded-full blur-3xl -mr-20 -mb-20"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
      <!-- Section Header -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-xs font-mono text-[#07bee8] font-black uppercase tracking-[0.25em] block mb-2">Leadership & Assurance</span>
        <h2 class="text-[clamp(1rem,4vw,2.25rem)] font-black text-[#024095] uppercase tracking-tight">
          FOUNDER'S TRUST & <span class="text-[#07bee8]">FIELD ENGAGEMENTS</span>
        </h2>
        <p class="text-slate-500 text-xs sm:text-sm mt-4 font-light leading-relaxed max-w-xl mx-auto">
          Every custom commercial and industrial installation is personally overseen and inspected by our founding leadership to guarantee compliance and operational longevity.
        </p>
      </div>

      <!-- Founder Image Gallery/Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <!-- Founder Image 1: Main Portrait -->
        <div class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-200/80 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col">
          <div class="aspect-[3/4] overflow-hidden bg-slate-100">
            <img src="/images/founder.jpeg" alt="Rajesh — Founder & Managing Director" class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
          <div class="p-4 text-center border-t border-slate-100">
            <p class="text-sm font-bold text-[#024095] uppercase">Rajesh</p>
            <p class="text-[10px] font-medium text-slate-500 uppercase tracking-wider mt-0.5">Founder & Managing Director</p>
          </div>
        </div>

        <!-- Founder Image 2: Showroom/Office -->
        <div class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-200/80 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col">
          <div class="aspect-[3/4] overflow-hidden bg-slate-100">
            <img src="/images/founder%202.png" alt="Founder Rajesh - Office Checkpoint" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
          <div class="p-4 text-center border-t border-slate-100">
            <p class="text-sm font-bold text-[#024095] uppercase">Showroom Oversight</p>
            <p class="text-[10px] font-medium text-slate-500 uppercase tracking-wider mt-0.5">Inventory & Logistics Check</p>
          </div>
        </div>

        <!-- Founder Image 3: Field Audit -->
        <div class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-200/80 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col">
          <div class="aspect-[3/4] overflow-hidden bg-slate-100">
            <img src="/images/founder%203.png" alt="Founder Rajesh - Engineering Operations" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
          <div class="p-4 text-center border-t border-slate-100">
            <p class="text-sm font-bold text-[#024095] uppercase">Engineering Site Check</p>
            <p class="text-[10px] font-medium text-slate-500 uppercase tracking-wider mt-0.5">Field Inspection & Audits</p>
          </div>
        </div>

        <!-- Founder Image 4: Client Consultation -->
        <div class="bg-slate-50 rounded-2xl overflow-hidden border border-slate-200/80 shadow-sm hover:shadow-md transition-all duration-300 group flex flex-col">
          <div class="aspect-[3/4] overflow-hidden bg-slate-100">
            <img src="/images/founder%204.png" alt="Founder Rajesh - Plant Calibration" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
          <div class="p-4 text-center border-t border-slate-100">
            <p class="text-sm font-bold text-[#024095] uppercase">Quality Validation</p>
            <p class="text-[10px] font-medium text-slate-500 uppercase tracking-wider mt-0.5">Testing & Commissioning</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>