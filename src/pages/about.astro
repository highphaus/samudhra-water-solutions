---
// src/pages/about.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="About Us - Mission and Vision | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- 1. HERO HEADER -->
  <section class="bg-[#F9F9FB] text-slate-900 pt-28 sm:pt-36 pb-16 sm:pb-24 border-b border-slate-200/60">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex items-center gap-3 mb-5 sm:mb-6">
        <span class="h-[1px] w-10 sm:w-12 bg-[#024095]"></span>
        <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-[0.3em] text-[#07bee8]">INTRODUCTION</span>
      </div>
      <h1 class="text-3xl sm:text-5xl lg:text-6xl font-black tracking-tighter text-[#024095] leading-[1.02] uppercase">
        Clean water...<br class="hidden sm:inline" /> for a healthy life.
      </h1>
      <div class="text-sm sm:text-base lg:text-lg font-light text-black mt-6 sm:mt-8 leading-relaxed max-w-4xl space-y-4">
        <p>Samudhra Water Solutions is your trusted partner for customized water treatment solutions. We offer advanced filtration technologies, including reverse osmosis and controlled mineralization, backed by extensive experience in the field.</p>
        <p>Samudhra Water Solutions is known in Thiruvananthapuram as one of the most dependable and respected commercial water purifier dealers, with an exceptional presence in the business for over 15 years.</p>
        <p>With 15 years of experience, Samudhra offers customized and branded water purifiers and water treatment plants that are aesthetically and scientifically designed for maximum reliability and value across Kerala.</p>
      </div>
    </div>
  </section>

  <!-- 2. NARRATIVE & PARTNERSHIPS -->
  <section class="bg-white text-slate-900 py-16 sm:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-12 gap-8 sm:gap-12 items-start">

        <!-- Left Side Note -->
        <div class="md:col-span-4 space-y-2 border-l-4 border-[#07bee8] bg-[#F9F9FB] p-5 sm:p-6 rounded-r">
          <span class="text-[9px] font-mono text-black font-bold uppercase tracking-widest">[ HEALTH STANDARDS ]</span>
          <p class="text-xl sm:text-2xl font-black text-[#024095] uppercase tracking-tight">Indian Standards</p>
          <p class="text-xs text-black leading-relaxed font-medium">Systems built to deliver pure drinking water matching strict safety and efficiency norms.</p>
        </div>

        <!-- Right Side Content -->
        <div class="md:col-span-8 space-y-6 sm:space-y-8">
          <div class="space-y-3">
            <h3 class="text-lg sm:text-xl font-bold tracking-tight text-[#024095] uppercase">Customized Water Treatment</h3>
            <p class="text-sm text-black font-light leading-relaxed">
              Our customized treatment plant treats water as per Indian drinking water standards for colour, odour, suspended particles, bad taste, turbidity, iron, and hardness.
            </p>
          </div>

          <div class="space-y-3">
            <h3 class="text-lg sm:text-xl font-bold tracking-tight text-[#024095] uppercase">Our Trusted Partners</h3>
            <p class="text-sm text-black font-light leading-relaxed mb-4">
              For this we have partnered with India's leading manufacturers to give you systems that match international standards in efficiency:
            </p>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3 text-xs font-black uppercase tracking-wider text-[#024095]">
              <div class="bg-[#F9F9FB] p-3 rounded border border-slate-100">PZONE</div>
              <div class="bg-[#F9F9FB] p-3 rounded border border-slate-100">ZEDSYSTEMS</div>
              <div class="bg-[#F9F9FB] p-3 rounded border border-slate-100">Pentair</div>
              <div class="bg-[#F9F9FB] p-3 rounded border border-slate-100">Conway Water Purifier</div>
              <div class="bg-[#F9F9FB] p-3 rounded border border-slate-100">Flonix</div>
              <div class="bg-[#F9F9FB] p-3 rounded border border-slate-100">Kairox</div>
              <div class="bg-[#F9F9FB] p-3 rounded border border-slate-100">TATA</div>
              <div class="bg-[#024095] text-white p-3 rounded text-center font-bold">Authorized</div>
            </div>
          </div>

          <div class="space-y-3 pt-2">
            <h3 class="text-lg sm:text-xl font-bold tracking-tight text-[#024095] uppercase">Government &amp; Public Projects</h3>
            <p class="text-sm text-black font-light leading-relaxed">
              We also undertake community projects for drinking water treatment initiated by the government and local self-government agencies to secure healthy and safe water supplies for everyone.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. MISSION, VISION, VALUES -->
  <section class="bg-[#F9F9FB] text-slate-900 py-16 sm:py-24 border-t border-b border-slate-200/50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6">

        <div class="bg-white p-6 sm:p-8 rounded-md shadow-sm border-t-4 border-[#024095] space-y-3">
          <p class="text-[10px] font-black tracking-widest uppercase text-[#07bee8]">MISSION</p>
          <h4 class="text-lg sm:text-xl font-black text-[#024095] uppercase">Our Mission</h4>
          <p class="text-xs text-black font-light leading-relaxed">
            Our mission is to improve water quality to support human development and the environment.
          </p>
        </div>

        <div class="bg-white p-6 sm:p-8 rounded-md shadow-sm border-t-4 border-[#024095] space-y-3">
          <p class="text-[10px] font-black tracking-widest uppercase text-[#07bee8]">VISION</p>
          <h4 class="text-lg sm:text-xl font-black text-[#024095] uppercase">Our Vision</h4>
          <p class="text-xs text-black font-light leading-relaxed">
            To provide permanent relief from bad water by making professional water treatments easily available to everyone in Kerala.
          </p>
        </div>

        <div class="bg-white p-6 sm:p-8 rounded-md shadow-sm border-t-4 border-[#024095] space-y-3 sm:col-span-2 md:col-span-1">
          <p class="text-[10px] font-black tracking-widest uppercase text-[#07bee8]">VALUES</p>
          <h4 class="text-lg sm:text-xl font-black text-[#024095] uppercase">Our Values</h4>
          <p class="text-xs text-black font-light leading-relaxed">
            Purity assured, transparent water testing, customer care, and complete reliability across all installations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. CORE REASONS -->
  <section class="bg-white text-slate-900 py-16 sm:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-xl mx-auto mb-10 sm:mb-16 space-y-2">
        <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#07bee8]">PURITY ASSURED</p>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-[#024095] uppercase tracking-tight">Most Trusted Water Treatment Service.</h2>
      </div>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-0 border border-slate-100 shadow-sm rounded-lg overflow-hidden">
        <div class="p-6 sm:p-8 bg-[#F9F9FB] border-b sm:border-b md:border-b-0 md:border-r border-slate-200/60 space-y-3 hover:bg-white transition-colors duration-300">
          <h4 class="text-base sm:text-lg font-black text-[#024095] uppercase">Purity Assured</h4>
          <p class="text-xs text-black font-light leading-relaxed">Using latest purification technologies with genuine components that assure pure and safe drinking water for your family.</p>
        </div>
        <div class="p-6 sm:p-8 bg-[#F9F9FB] border-b md:border-b-0 md:border-r border-slate-200/60 space-y-3 hover:bg-white transition-colors duration-300">
          <h4 class="text-base sm:text-lg font-black text-[#024095] uppercase">Wide Range</h4>
          <p class="text-xs text-black font-light leading-relaxed">Our exclusive showroom offers water treatment solutions tailored to your needs based on water quality.</p>
        </div>
        <div class="p-6 sm:p-8 bg-[#F9F9FB] space-y-3 hover:bg-white transition-colors duration-300 sm:col-span-2 md:col-span-1">
          <h4 class="text-base sm:text-lg font-black text-[#024095] uppercase">Excellent Service</h4>
          <p class="text-xs text-black font-light leading-relaxed">Partner with Samudra Water Solutions to get the highest quality and best customer services.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <section class="bg-[#024095] text-white py-16 sm:py-20 border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex flex-col md:flex-row items-center justify-between gap-6 sm:gap-8">
      <div class="text-center md:text-left">
        <h4 class="text-lg sm:text-xl lg:text-2xl font-black uppercase tracking-tight">Looking for professional and trusted equipment?</h4>
        <p class="text-xs text-slate-200 font-light mt-1">Do not hesitate to contact us. We are always here to help you choose the best system.</p>
      </div>
      <a href="https://wa.me/919645830994?text=Hi Samudhra, I want to inquire about professional water treatment equipment." target="_blank"
         class="w-full sm:w-auto min-h-[48px] px-8 py-4 bg-white text-[#024095] font-black text-xs uppercase tracking-[0.22em] hover:bg-[#07bee8] hover:text-white transition-all duration-300 text-center shadow-xl rounded flex items-center justify-center">
        Contact Us Now
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#F9F9FB] text-black py-10 sm:py-12 border-t border-slate-200/60">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4 sm:gap-6 text-[10px] font-bold uppercase tracking-[0.25em] text-center">
      <p>&copy; {new Date().getFullYear()} Samudhra Water Solutions. All Rights Reserved.</p>
      <p class="text-[#024095] font-black">Trivandrum, Kerala</p>
    </div>
  </footer>
</Layout>