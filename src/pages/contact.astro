---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Contact Hub & Operations | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- Immersive Page Header Canvas -->
  <section class="bg-[#F9F9FB] text-slate-900 pt-36 pb-24 border-b border-slate-200/60">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <span class="h-[1px] w-12 bg-[#024095]"></span>
        <span class="text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">CONNECT / OFFICE REGISTRY</span>
      </div>
      <h1 class="text-5xl sm:text-7xl font-black tracking-tighter text-[#024095] leading-[1.02] uppercase">Initiate <br /> Consultation.</h1>
      <p class="text-lg sm:text-xl font-light text-slate-600 mt-8 leading-relaxed max-w-3xl">Connect with our corporate advisors or distribution hubs directly. We ensure direct parameter reviews for home arrays and commercial turnkey layouts.</p>
    </div>
  </section>

  <!-- Clean Scandinavian Showroom & Directory Contact Grid -->
  <section class="bg-white text-slate-900 py-24">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-6">
        
        <!-- Poojappura Central Display Station -->
        <div class="p-10 bg-[#F9F9FB] border-t-4 border-[#024095] shadow-sm rounded-b-md space-y-6 flex flex-col justify-between">
          <div class="space-y-4">
            <span class="text-xs font-mono text-[#07bee8] font-bold uppercase tracking-widest">// CENTRAL SITE DIVISION 01</span>
            <h3 class="text-2xl font-black tracking-tight text-[#024095] uppercase">Poojappura Showroom</h3>
            
            <div class="space-y-1 text-sm text-slate-500 font-light leading-relaxed">
              <p>Soorya Nidhi, TC 42/1231, Near Canara Bank,</p>
              <p>Poojappura, Thiruvananthapuram, Kerala, India</p>
            </div>

            <!-- Direct Node Channels -->
            <div class="pt-4 border-t border-slate-200/50 space-y-2 text-xs font-bold uppercase tracking-wider text-slate-600">
              <div class="flex items-center gap-2">
                <span class="text-slate-400 font-light">Phn:</span>
                <a href="tel:+919645830994" class="hover:text-[#024095] transition-colors">+91 9645830994</a>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-slate-400 font-light">Mail:</span>
                <a href="mailto:mail@samudhra.co.in" class="hover:text-[#024095] transition-colors lowercase font-medium text-sm tracking-normal">mail@samudhra.co.in</a>
              </div>
            </div>
          </div>

          <div class="pt-6"><a href="https://wa.me/919645830994?text=Hi, I want to arrange a consulting slot at your Poojappura facility." target="_blank" class="w-full sm:w-auto inline-block text-center px-6 py-3.5 bg-[#024095] text-white text-[10px] font-black uppercase tracking-wider hover:bg-[#07bee8] transition-all rounded shadow-md shadow-[#024095]/10">Schedule Site Visit</a></div>
        </div>

        <!-- Thirumala Logistics Distribution Node -->
        <div class="p-10 bg-[#F9F9FB] border-t-4 border-[#07bee8] shadow-sm rounded-b-md space-y-6 flex flex-col justify-between">
          <div class="space-y-4">
            <span class="text-xs font-mono text-[#024095] font-bold uppercase tracking-widest">// LOGISTICS DIVISION 02</span>
            <h3 class="text-2xl font-black tracking-tight text-[#024095] uppercase">Thirumala Showroom</h3>
            
            <div class="space-y-1 text-sm text-slate-500 font-light leading-relaxed">
              <p>No.TC 40/147-1, Near MRA Restaurant,</p>
              <p>Thirumala, Thiruvananthapuram, Kerala, India</p>
            </div>

            <!-- Direct Node Channels -->
            <div class="pt-4 border-t border-slate-200/50 space-y-2 text-xs font-bold uppercase tracking-wider text-slate-600">
              <div class="flex items-center gap-2">
                <span class="text-slate-400 font-light">Phn:</span>
                <a href="tel:+919645830994" class="hover:text-[#024095] transition-colors">+91 9645830994</a>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-slate-400 font-light">Mail:</span>
                <a href="mailto:mail@samudhra.co.in" class="hover:text-[#024095] transition-colors lowercase font-medium text-sm tracking-normal">mail@samudhra.co.in</a>
              </div>
            </div>
          </div>

          <div class="pt-6"><a href="https://wa.me/919645830994?text=Hi, I am checking component tracking at the Thirumala distribution center." target="_blank" class="w-full sm:w-auto inline-block text-center px-6 py-3.5 bg-white border-2 border-[#024095] text-[#024095] text-[10px] font-black uppercase tracking-wider hover:bg-[#024095] hover:text-white transition-all rounded">Contact Logistics Desk</a></div>
        </div>

      </div>
    </div>
  </section>

  <!-- Clean Corporate Footer Baseline -->
  <footer class="bg-white text-slate-400 py-16 border-t border-slate-100">
    <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-8">
      <div class="space-y-1">
        <p class="text-black font-black text-lg tracking-widest">SAMUDHRA</p>
        <p class="text-[9px] font-bold uppercase tracking-[0.2em]">Purity Standards &copy; {new Date().getFullYear()}</p>
      </div>
      <p class="text-xs font-light max-w-sm text-center sm:text-right leading-relaxed text-slate-400">
        Corporate operations engineered cleanly in Thiruvananthapuram. Multi-brand customized components and site maintenance compliance. All rights protected.
      </p>
    </div>
  </footer>
</Layout>