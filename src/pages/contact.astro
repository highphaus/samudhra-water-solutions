---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Hub and Operations | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="bg-[#FAF9F6] text-slate-900 pt-28 sm:pt-36 pb-16 sm:pb-24 border-b border-slate-200/60">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7">
          <div class="flex items-center gap-3 mb-5 sm:mb-6">
            <span class="h-[1px] w-10 sm:w-12 bg-[#024095]"></span>
            <span class="text-[9px] sm:text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">CONNECT WITH US</span>
          </div>
          <h1 class="text-3xl sm:text-5xl lg:text-7xl font-black tracking-tighter text-[#024095] leading-[1.02] uppercase">
            Get In Touch.
          </h1>
          <p class="text-base sm:text-lg lg:text-xl font-light text-black mt-6 sm:mt-8 leading-relaxed">
            Call now or write a message to us. Get in touch with us everytime. Our 24x7 service unit will help you to process your needs at anytime.
          </p>
        </div>
        <div class="lg:col-span-5">
          <div class="w-full rounded-2xl overflow-hidden border border-slate-200/60 shadow-lg bg-white p-2">
            <img src="/images/office%20image/Samdhura%20Office.jpg" alt="Samudhra Water Solutions Office" class="w-full h-auto rounded-xl hover:scale-105 transition-transform duration-700 ease-out" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT GRID -->
  <section class="bg-[#FAF9F6] text-slate-900 py-14 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 grid grid-cols-1 lg:grid-cols-12 gap-8 sm:gap-12 items-start">

      <!-- Left: Email Enquiry Form -->
      <div class="col-span-1 lg:col-span-7 bg-white border-t-4 border-[#024095] p-6 sm:p-8 lg:p-10 rounded-b-md shadow-sm space-y-6">
        <div>
          <h2 class="text-xl sm:text-2xl font-black text-[#024095] uppercase tracking-tight">Email Enquiry</h2>
          <p class="text-xs text-black font-bold uppercase tracking-widest mt-0.5">Send us a direct message</p>
        </div>

        <form id="enquiry-form" class="space-y-5 pt-4 border-t border-slate-200/60">
          <div>
            <label for="enquiry-name" class="block text-[10px] font-black text-[#07bee8] uppercase tracking-widest mb-1.5">Full Name</label>
            <input type="text" id="enquiry-name" required placeholder="John Doe" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-sm text-black focus:outline-none focus:ring-2 focus:ring-[#024095]/20 focus:border-[#024095] transition-all" />
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="enquiry-email" class="block text-[10px] font-black text-[#07bee8] uppercase tracking-widest mb-1.5">Email Address</label>
              <input type="email" id="enquiry-email" required placeholder="john@example.com" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-sm text-black focus:outline-none focus:ring-2 focus:ring-[#024095]/20 focus:border-[#024095] transition-all" />
            </div>
            <div>
              <label for="enquiry-phone" class="block text-[10px] font-black text-[#07bee8] uppercase tracking-widest mb-1.5">Phone Number</label>
              <input type="tel" id="enquiry-phone" required placeholder="9645830994" class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-sm text-black focus:outline-none focus:ring-2 focus:ring-[#024095]/20 focus:border-[#024095] transition-all" />
            </div>
          </div>
          <div>
            <label for="enquiry-message" class="block text-[10px] font-black text-[#07bee8] uppercase tracking-widest mb-1.5">Message / Requirement</label>
            <textarea id="enquiry-message" required rows="4" placeholder="Describe your water problems, requirements or query here..." class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-sm text-black focus:outline-none focus:ring-2 focus:ring-[#024095]/20 focus:border-[#024095] transition-all resize-none"></textarea>
          </div>
          <div id="form-feedback" class="hidden text-xs font-bold rounded-lg p-4 transition-all"></div>
          <button type="submit" id="submit-btn" class="w-full inline-flex items-center justify-center min-h-[52px] px-8 py-4 bg-[#024095] text-white font-black text-xs uppercase tracking-[0.2em] hover:bg-[#07bee8] transition-all rounded shadow-md">
            SUBMIT ENQUIRY
          </button>
        </form>
      </div>

      <!-- Right: Contact info, Schedule & Emergency -->
      <div class="col-span-1 lg:col-span-5 space-y-4 sm:space-y-6">

        <!-- Contact Info Card -->
        <div class="bg-white border-t-4 border-[#024095] p-6 sm:p-8 rounded-b-md shadow-sm space-y-4">
          <div>
            <h3 class="text-lg sm:text-xl font-black text-[#024095] uppercase tracking-tight">Contact Information</h3>
            <p class="text-xs text-black font-bold uppercase tracking-widest mt-0.5">Central Showroom Registry</p>
          </div>
          <div class="space-y-4 pt-2 text-sm text-black font-medium border-t border-slate-200/40">
            <div>
              <p class="text-[10px] font-black text-[#07bee8] uppercase tracking-widest">Our Location</p>
              <p class="text-xs text-black leading-relaxed mt-1">
                Soorya nidhi, TC 42/1231, main road, near canara bank, Poojapura, Thiruvananthapuram, Kerala 695012
              </p>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-[10px] font-black text-[#07bee8] uppercase tracking-widest">Phone Number</p>
                <a href="tel:+919645830994" class="text-sm font-bold text-[#024095] hover:text-[#07bee8] transition-colors mt-1 block">
                  9645830994
                </a>
              </div>
              <div>
                <p class="text-[10px] font-black text-[#07bee8] uppercase tracking-widest">Email Addresses</p>
                <a href="mailto:mail@samudhra.co.in" class="text-xs font-medium text-black hover:text-[#024095] transition-colors break-all mt-1 block leading-tight">
                  mail@samudhra.co.in
                </a>
                <a href="mailto:info.samudhra10@gmail.com" class="text-xs font-medium text-black hover:text-[#024095] transition-colors break-all mt-1 block leading-tight">
                  info.samudhra10@gmail.com
                </a>
              </div>
            </div>
            <div class="pt-2">
              <a href="https://wa.me/919645830994?text=Hi, I want to get in touch with your water filtration service team."
                 target="_blank"
                 class="w-full inline-flex items-center justify-center min-h-[44px] px-4 py-2.5 bg-[#024095] text-white font-black text-xs uppercase tracking-widest hover:bg-[#07bee8] transition-all rounded shadow-md">
                WhatsApp Chat
              </a>
            </div>
          </div>
        </div>

        <!-- Schedule Hours -->
        <div class="bg-white border-t-4 border-[#07bee8] p-6 sm:p-8 rounded-b-md shadow-sm space-y-4">
          <p class="text-[10px] font-black text-black uppercase tracking-widest">TIMELINE COMPLIANCE</p>
          <h3 class="text-lg sm:text-xl font-black text-[#024095] uppercase tracking-tight">Schedule Hours</h3>
          <div class="space-y-3 pt-2 text-sm text-black font-medium">
            <div class="flex justify-between pb-2 border-b border-slate-200/40">
              <span class="font-light">Monday – Saturday</span>
              <span class="text-[#024095] font-semibold">08:00 AM – 08:00 PM</span>
            </div>
            <div class="flex justify-between">
              <span class="font-light">Sunday</span>
              <span class="text-black font-medium">Closed *</span>
            </div>
          </div>
        </div>

        <!-- Emergency -->
        <div class="bg-red-50 border-l-4 border-red-600 p-6 sm:p-8 rounded-r-md shadow-sm space-y-2">
          <p class="text-[9px] font-black text-red-600 uppercase tracking-widest">CRITICAL SUPPORT</p>
          <h4 class="text-base sm:text-lg font-black text-[#024095] uppercase tracking-tight">Emergency Cases</h4>
          <p class="text-xs text-black font-light leading-relaxed">
            For urgent pipe leaks, mainline plant shutdowns, or sudden filtration breakdowns, call our field line instantly.
          </p>
          <div class="pt-2">
            <a href="tel:+919645830994" class="inline-flex items-center gap-2 text-lg sm:text-xl font-black text-red-600 hover:text-red-700 transition-colors min-h-[48px]">
              &#9742; 9645830994
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- MAP SECTION -->
  <section class="bg-[#FAF9F6] pb-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">

      <!-- Section Heading -->
      <div class="flex items-center gap-3 mb-4">
        <span class="h-[1px] w-10 bg-[#024095]"></span>
        <span class="text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">FIND US HERE</span>
      </div>
      <h2 class="text-2xl sm:text-3xl font-black text-[#024095] uppercase mb-8">Our Office Location</h2>

      <!-- Map + Info Card -->
      <div class="w-full rounded-2xl shadow-2xl border border-slate-200 overflow-hidden flex flex-col lg:flex-row">

        <!-- Left: Info Panel -->
        <div class="bg-[#024095] lg:w-[340px] shrink-0 p-8 flex flex-col justify-between gap-8">
          <div class="space-y-6">
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#07bee8] mb-2">Company</p>
              <p class="text-white font-black text-lg leading-tight">Samudhra Water Solutions</p>
            </div>
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#07bee8] mb-2">Address</p>
              <p class="text-blue-100 text-sm font-medium leading-relaxed">
                Soorya Nidhi, TC 42/1231,<br/>
                Near Canara Bank, Poojapura,<br/>
                Thiruvananthapuram, Kerala 695012
              </p>
            </div>
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#07bee8] mb-2">Phone</p>
              <a href="tel:+919645830994" class="text-white font-black text-base hover:text-[#07bee8] transition-colors">
                +91 96458 30994
              </a>
            </div>
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#07bee8] mb-2">Hours</p>
              <p class="text-blue-100 text-sm font-medium">Mon – Sat: 8:00 AM – 8:00 PM</p>
              <p class="text-blue-200 text-xs font-medium mt-1">Sunday: Closed</p>
            </div>
          </div>

          <a href="https://maps.app.goo.gl/f9PezLmRUYLq52998" target="_blank" rel="noopener noreferrer"
             class="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-[#07bee8] text-[#024095] text-xs font-black uppercase tracking-widest rounded-xl hover:bg-white transition-all shadow-lg">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            Open in Google Maps
          </a>
        </div>

        <!-- Right: Map Embed (OpenStreetMap - always works!) -->
        <div class="flex-1 min-h-[300px] sm:min-h-[400px] lg:min-h-full">
          <iframe
            src="https://www.openstreetmap.org/export/embed.html?bbox=76.9708414%2C8.4891369%2C76.9808414%2C8.4991369&layer=mapnik&marker=8.4941369%2C76.9758414"
            width="100%"
            height="100%"
            style="border:0; display:block;"
            class="w-full h-full min-h-[300px] sm:min-h-[400px] lg:min-h-[500px]"
            allowfullscreen=""
            loading="lazy"
            title="Samudhra Water Solutions - Poojapura, Thiruvananthapuram">
          </iframe>
        </div>

      </div>

    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('enquiry-form');
      const feedback = document.getElementById('form-feedback');
      const submitBtn = document.getElementById('submit-btn');
      if (!form || !feedback || !submitBtn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Clear previous feedback
        feedback.className = 'hidden text-xs font-bold rounded-lg p-4 transition-all';
        feedback.innerText = '';

        const name = document.getElementById('enquiry-name').value;
        const email = document.getElementById('enquiry-email').value;
        const phone = document.getElementById('enquiry-phone').value;
        const message = document.getElementById('enquiry-message').value;

        // Set loading state
        submitBtn.disabled = true;
        submitBtn.innerText = 'SENDING...';
        submitBtn.style.opacity = '0.7';

        try {
          const response = await fetch('/api/send-enquiry', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ name, email, phone, message }),
          });

          const result = await response.json();

          if (response.ok) {
            feedback.innerText = result.message || 'Enquiry sent successfully!';
            feedback.className = 'text-xs font-bold rounded-lg p-4 transition-all bg-emerald-50 text-emerald-700 border border-emerald-200';
            form.reset();
          } else {
            feedback.innerText = result.error || 'Failed to send enquiry. Please try again.';
            feedback.className = 'text-xs font-bold rounded-lg p-4 transition-all bg-rose-50 text-rose-700 border border-rose-200';
          }
        } catch (error) {
          console.error('Enquiry submission error:', error);
          feedback.innerText = 'An error occurred while sending your enquiry. Please check your connection and try again.';
          feedback.className = 'text-xs font-bold rounded-lg p-4 transition-all bg-rose-50 text-rose-700 border border-rose-200';
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerText = 'SUBMIT ENQUIRY';
          submitBtn.style.opacity = '1';
        }
      });
    });
  </script>

  <Footer />
</Layout>