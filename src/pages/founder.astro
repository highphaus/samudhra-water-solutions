---
// src/pages/founder.astro
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="Founder Statement | Samudhra Water Solutions">
  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <Navbar />

  <section class="bg-[#F9F9FB] text-slate-900 pt-36 pb-24 border-b border-slate-200/60">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <span class="h-[1px] w-12 bg-[#024095]"></span>
        <span class="text-[10px] font-extrabold uppercase tracking-[0.4em] text-[#07bee8]">LEADERSHIP PROFILE / MD STATEMENT</span>
      </div>
      <h1 class="text-5xl sm:text-7xl font-black tracking-tighter text-[#024095] leading-[1.02] uppercase">Engineering <br /> Trust By Volume.</h1>
      <p class="text-lg sm:text-xl font-light text-slate-600 mt-8 leading-relaxed max-w-3xl">
        "Pure water is an uncompromised structural baseline. At Samudhra, we built our reputation over 17 years by refusing to deploy stock pre-packaged shortcuts, configuring every system to the actual water chemistry parameters of Kerala."
      </p>
    </div>
  </section>

  <section class="bg-white text-slate-900 py-24">
    <div class="max-w-5xl mx-auto px-6 grid md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-4 space-y-6 border-l-4 border-[#024095] bg-[#F9F9FB] p-6 rounded-r">
        <div>
          <span class="text-[9px] font-mono text-[#07bee8] uppercase tracking-widest">[ EXECUTIVE CHAIR ]</span>
          <p class="text-2xl font-black text-[#024095] tracking-tight uppercase mt-1">Rajesh</p>
          <p class="text-xs font-bold text-slate-500 tracking-wider uppercase mt-0.5">Founder & Managing Director</p>
        </div>
      </div>

      <div class="md:col-span-8 space-y-12">
        <div class="space-y-3">
          <span class="text-xs font-mono text-[#07bee8] font-bold uppercase tracking-widest">// STRATEGIC VISION</span>
          <h3 class="text-2xl font-black tracking-tight text-[#024095] uppercase">The Architecture of Performance</h3>
          <p class="text-sm text-slate-500 font-light leading-relaxed">When I established this organization in 2009, the community was forced to settle for standardized generic filtration equipment. We rejected that layout model entirely. By committing our engineering teams to meticulous pre-assembly site analysis, we ensured that residential and commercial clients receive long-lasting operational certainty.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>